---
// ParticleMorph.astro — particles that morph between tech-stack icons.
// Requires: npm install three   (you already have it)
// Drop <ParticleMorph /> into the right card of Page2.
---

<div class="particle-morph">
  <div class="pm-label" data-pm-label>python</div>
</div>

<style>
  .particle-morph { position:relative; width:100%; height:100%; min-height:420px; }
  .particle-morph canvas { display:block; width:100% !important; height:100% !important; }
  .pm-label {
    position:absolute; bottom:16px; left:0; right:0; text-align:center;
    font-family:"JetBrains Mono","Space Mono",monospace; font-size:13px;
    letter-spacing:0.15em; text-transform:uppercase; color:rgba(255,255,255,0.55);
    pointer-events:none;
  }
</style>

<script>
  import * as THREE from "three";

  /* ---------- your tech stack (order = morph order) ---------- */
  const ICONS = [
    { slug:"python",            color:"#4B8BBE", label:"python" },
    { slug:"javascript",        color:"#F7DF1E", label:"javascript" },
    { slug:"nodedotjs",         color:"#5FA04E", label:"node.js" },
    { slug:"express",           color:"#CFCFCF", label:"express" },
    { slug:"postgresql",        color:"#5A8FE6", label:"postgresql" },
    { slug:"mongodb",           color:"#47A248", label:"mongodb" },
    { slug:"react",             color:"#61DAFB", label:"react" },
    { slug:"mysql",             color:"#5b9bd5", label:"sql" },
    { slug:"figma",             color:"#F24E1E", label:"figma" },
    { slug:"adobecreativecloud",color:"#EB4B35", label:"adobe cc" },
  ];
  const N = 2600;            // particle count
  const HOLD = 2.4;          // seconds each icon is shown
  const MORPH = 1.1;         // seconds to morph between icons
  const HOVER_RADIUS = 0.5;  // cursor influence radius
  const HOVER_PULL = 0.35;   // viscous attraction strength
  /* ----------------------------------------------------------- */

  const wrap = document.querySelector(".particle-morph");
  const labelEl = document.querySelector("[data-pm-label]");
  if (wrap) init();

  async function sampleIcon(slug) {
    const res = await fetch(`https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/${slug}.svg`);
    const txt = await res.text();
    const d = (txt.match(/\sd="([^"]+)"/) || [])[1];
    const S = 240, cvs = document.createElement("canvas"); cvs.width = cvs.height = S;
    const ctx = cvs.getContext("2d");
    const sc = S / 24; ctx.setTransform(sc,0,0,sc,0,0); ctx.fillStyle = "#fff";
    ctx.fill(new Path2D(d)); ctx.setTransform(1,0,0,1,0,0);
    const px = ctx.getImageData(0,0,S,S).data, pts = [];
    for (let y=0;y<S;y+=2) for (let x=0;x<S;x+=2)
      if (px[(y*S+x)*4+3] > 128) pts.push([(x/S-0.5)*2.2, -(y/S-0.5)*2.2]);
    const out = new Float32Array(N*3);
    for (let i=0;i<N;i++){ const p = pts[(Math.random()*pts.length)|0] || [0,0];
      out[i*3]=p[0]; out[i*3+1]=p[1]; out[i*3+2]=(Math.random()-0.5)*0.05; }
    return out;
  }

  async function init() {
    const clouds = [];
    for (const ic of ICONS) { try { clouds.push(await sampleIcon(ic.slug)); } catch(e){ clouds.push(new Float32Array(N*3)); } }

    const renderer = new THREE.WebGLRenderer({ antialias:true, alpha:true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio||1, 2));
    wrap.appendChild(renderer.domElement);
    const scene = new THREE.Scene();
    let asp = wrap.clientWidth / wrap.clientHeight, F = 1.35;
    const cam = new THREE.OrthographicCamera(-F*asp, F*asp, F, -F, 0.1, 10);
    cam.position.z = 3;

    // round soft particle sprite
    const tc = document.createElement("canvas"); tc.width = tc.height = 64;
    const tx = tc.getContext("2d");
    const g = tx.createRadialGradient(32,32,0,32,32,32);
    g.addColorStop(0,"rgba(255,255,255,1)"); g.addColorStop(0.4,"rgba(255,255,255,0.7)"); g.addColorStop(1,"rgba(255,255,255,0)");
    tx.fillStyle=g; tx.fillRect(0,0,64,64);
    const sprite = new THREE.CanvasTexture(tc);

    const geo = new THREE.BufferGeometry();
    const pos = new Float32Array(clouds[0]);            // current render positions
    const col = new Float32Array(N*3);
    geo.setAttribute("position", new THREE.BufferAttribute(pos,3));
    geo.setAttribute("color", new THREE.BufferAttribute(col,3));
    const mat = new THREE.PointsMaterial({
      size:0.05, map:sprite, vertexColors:true, transparent:true,
      depthWrite:false, blending:THREE.AdditiveBlending,
    });
    const points = new THREE.Points(geo, mat); scene.add(points);

    // per-particle random phase for idle drift
    const phase = new Float32Array(N); for (let i=0;i<N;i++) phase[i]=Math.random()*6.28;

    let from = 0, to = 0, colFrom = new THREE.Color(ICONS[0].color), colTo = new THREE.Color(ICONS[0].color);
    for (let i=0;i<N;i++){ col[i*3]=colFrom.r; col[i*3+1]=colFrom.g; col[i*3+2]=colFrom.b; }
    geo.attributes.color.needsUpdate = true;

    function resize(){ asp = wrap.clientWidth/wrap.clientHeight;
      cam.left=-F*asp; cam.right=F*asp; cam.top=F; cam.bottom=-F; cam.updateProjectionMatrix();
      renderer.setSize(wrap.clientWidth, wrap.clientHeight, false); }
    resize(); window.addEventListener("resize", resize);

    // mouse in world space (on z=0 plane)
    let mouse = new THREE.Vector2(999,999), hasMouse=false;
    wrap.addEventListener("pointermove",(e)=>{ const r=wrap.getBoundingClientRect();
      const nx=((e.clientX-r.left)/r.width)*2-1, ny=-(((e.clientY-r.top)/r.height)*2-1);
      mouse.set(nx*F*asp, ny*F); hasMouse=true; });
    wrap.addEventListener("pointerleave",()=> hasMouse=false);

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const clock = new THREE.Clock();
    let t=0, phaseT=0, morphing=false, mp=0;

    function startMorph(){ from=to; to=(to+1)%ICONS.length; colFrom.copy(colTo); colTo.set(ICONS[to].color);
      if (labelEl) labelEl.textContent = ICONS[to].label; morphing=true; mp=0; }

    function frame(){
      const dt = Math.min(clock.getDelta(), 0.05); t += dt;
      if (!reduce){ phaseT += dt; if (!morphing && phaseT>HOLD){ startMorph(); phaseT=0; } }
      if (morphing){ mp += dt/MORPH; if (mp>=1){ mp=1; morphing=false; } }
      const e = mp<0.5 ? 2*mp*mp : 1-Math.pow(-2*mp+2,2)/2;  // easeInOut

      const A = clouds[from], B = clouds[to];
      const cr = colFrom.r+(colTo.r-colFrom.r)*e, cg = colFrom.g+(colTo.g-colFrom.g)*e, cb = colFrom.b+(colTo.b-colFrom.b)*e;
      for (let i=0;i<N;i++){
        const ix=i*3;
        let x = A[ix]+(B[ix]-A[ix])*e;
        let y = A[ix+1]+(B[ix+1]-A[ix+1])*e;
        let z = A[ix+2]+(B[ix+2]-A[ix+2])*e;
        if (!reduce){ const ph=phase[i];               // lively idle drift
          x += Math.sin(t*0.9+ph)*0.012; y += Math.cos(t*0.8+ph*1.3)*0.012; }
        if (hasMouse){                                  // viscous attraction to cursor
          const dx=mouse.x-x, dy=mouse.y-y, dd=dx*dx+dy*dy;
          if (dd < HOVER_RADIUS*HOVER_RADIUS){ const f=(1-Math.sqrt(dd)/HOVER_RADIUS)*HOVER_PULL;
            x += dx*f; y += dy*f; }
        }
        // ease render pos toward target for viscous smoothing
        pos[ix]   += (x-pos[ix])*0.25;
        pos[ix+1] += (y-pos[ix+1])*0.25;
        pos[ix+2] += (z-pos[ix+2])*0.25;
        col[ix]=cr; col[ix+1]=cg; col[ix+2]=cb;
      }
      geo.attributes.position.needsUpdate = true;
      geo.attributes.color.needsUpdate = true;
      renderer.render(scene, cam);
      requestAnimationFrame(frame);
    }
    frame();
  }
</script>