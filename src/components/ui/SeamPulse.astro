---
/**
 * SeamPulse.astro — the Page 2 ↔ Page 3 boundary.
 * A thin ventilator/ECG heartbeat that lives EXACTLY at the seam where the
 * two sections meet (not pinned to either). It scrolls through naturally as
 * you cross the border. The band blends Page 2's background into Page 3's.
 *   - dark  : pink → red aurora trace
 *   - light : cool blue trace
 * Interactive: the pulse quickens on hover and a glow dot tracks the cursor.
 */
const BEATS = 7;
let ECG = "M0 44";
for (let i = 0; i < BEATS; i++) {
  const o = i * 200;
  ECG += ` L${o + 70} 44 L${o + 82} 36 L${o + 94} 44 L${o + 108} 50 L${o + 116} 12 L${o + 124} 78 L${o + 132} 44 L${o + 150} 34 L${o + 168} 44 L${o + 200} 44`;
}
const ECG_W = BEATS * 200;
---

<div class="seam-pulse" data-seam aria-hidden="true">
  <svg class="sp-ecg" viewBox={`0 0 ${ECG_W} 88`} preserveAspectRatio="none">
    <defs>
      <linearGradient id="sp-grad" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0"   stop-color="var(--sp-a)" />
        <stop offset="0.5" stop-color="var(--sp-b)" />
        <stop offset="1"   stop-color="var(--sp-a)" />
      </linearGradient>
    </defs>
    <path class="sp-track" d={ECG} />
    <path class="sp-live"  d={ECG} />
  </svg>
  <span class="sp-cursor" data-seam-cursor></span>
</div>

<style>
  .seam-pulse {
    position: relative;
    width: 100%;
    height: clamp(96px, 13vh, 132px);
    display: flex;
    align-items: center;
    overflow: hidden;
    /* blend Page 2 (top) into Page 3 (bottom) so the border is seamless */
    --sp-top: #fbfbfa; --sp-bot: #f4f6f9;
    --sp-a: #3b82f6; --sp-b: #2f7bff;         /* light: blue trace */
    --sp-glow: rgba(47,123,255,0.55);
    --sp-line: rgba(30,120,255,0.22);
    background: linear-gradient(to bottom, var(--sp-top) 0%, var(--sp-bot) 100%);
  }
  :global(html[data-theme='dark']) .seam-pulse {
    --sp-top: #0a0a0a; --sp-bot: #0f131b;      /* black → Page 3 graphite */
    --sp-a: #ff5a8a; --sp-b: #ff3b46;          /* dark: pink → red aurora */
    --sp-glow: rgba(255,70,110,0.6);
    --sp-line: rgba(255,90,130,0.22);
    background: linear-gradient(to bottom, var(--sp-top) 0%, #0b0e15 62%, var(--sp-bot) 100%);
  }

  .sp-ecg { width: 100%; height: 62%; display: block; }
  .sp-track { fill: none; stroke: var(--sp-line); stroke-width: 2; }
  .sp-live {
    fill: none; stroke: url(#sp-grad); stroke-width: 2.8; stroke-linecap: round; stroke-linejoin: round;
    filter: drop-shadow(0 0 5px var(--sp-glow)) drop-shadow(0 0 12px var(--sp-glow));
    stroke-dasharray: 110 1290; stroke-dashoffset: 1400;
    animation: sp-scan 3s linear infinite;
  }
  @keyframes sp-scan { to { stroke-dashoffset: 0; } }
  .seam-pulse:hover .sp-live { animation-duration: 1.3s; }

  .sp-cursor {
    position: absolute; top: 50%; left: -60px; width: 11px; height: 11px; border-radius: 50%;
    transform: translate(-50%, -50%);
    background: var(--sp-b); box-shadow: 0 0 16px 4px var(--sp-glow);
    opacity: 0; transition: opacity 0.25s ease; pointer-events: none;
  }
  .seam-pulse:hover .sp-cursor { opacity: 1; }

  @media (prefers-reduced-motion: reduce) {
    .sp-live { animation: none; stroke-dasharray: none; stroke-dashoffset: 0; opacity: 0.8; }
  }
</style>

<script>
  const seam = document.querySelector<HTMLElement>("[data-seam]");
  const dot = document.querySelector<HTMLElement>("[data-seam-cursor]");
  if (seam && dot) {
    seam.addEventListener("pointermove", (e) => {
      const r = seam.getBoundingClientRect();
      dot.style.left = `${e.clientX - r.left}px`;
      dot.style.top = `${e.clientY - r.top}px`;
    });
  }
</script>
