---
/**
 * TechDeck.astro — six flip-cards, one per skill area.
 * FRONT: animated vector pictogram (tinted to the card's niche colour)
 * BACK (hover-flip): the skills as glassy chips (icon + proper name), stacked
 * CLICK: pins the card flipped so the skills stay until you leave the deck
 *
 * Each card owns a niche colour (--accent / --accentrgb) so both the
 * pictogram and the glow are distinct — fixes the monotone dark mode.
 */
const CARDS = [
  {
    id: "lang", title: "Languages", color: "#f5b301", rgb: "245,179,1",
    skills: [
      { n: "Python", i: "python" }, { n: "JavaScript", i: "javascript" },
      { n: "TypeScript", i: "typescript" }, { n: "SQL", i: null },
    ],
  },
  {
    id: "db", title: "Databases", color: "#3b82f6", rgb: "59,130,246",
    skills: [
      { n: "PostgreSQL", i: "postgresql" }, { n: "MySQL", i: "mysql" },
      { n: "MongoDB", i: "mongodb" }, { n: "Qdrant", i: "qdrant" },
    ],
  },
  {
    id: "fullstack", title: "Fullstack", color: "#8b5cf6", rgb: "139,92,246",
    skills: [
      { n: "HTML5", i: "html5" }, { n: "CSS", i: "css" },
      { n: "JavaScript", i: "javascript" }, { n: "React", i: "react" },
      { n: "Express", i: "express" }, { n: "Node.js", i: "nodedotjs" },
      { n: "FastAPI", i: "fastapi" }, { n: "Mongoose", i: "mongoose" },
    ],
  },
  {
    id: "aiml", title: "AI / ML", color: "#10b981", rgb: "16,185,129",
    skills: [
      { n: "LangChain", i: "langchain" }, { n: "LangGraph", i: null },
      { n: "RAG", i: null }, { n: "AI/ML Concepts", i: null },
      { n: "Prompt Engineering", i: null },
    ],
  },
  {
    id: "tools", title: "Tools, Automation & Dev", color: "#f97316", rgb: "249,115,22",
    skills: [
      { n: "Figma", i: "figma" }, { n: "Adobe CC", i: "adobe" },
      { n: "Claude", i: "claude" }, { n: "ChatGPT", i: "openai" },
      { n: "n8n", i: "n8n" }, { n: "Git", i: "git" },
      { n: "GitHub", i: "github" }, { n: "Docker", i: "docker" },
    ],
  },
  {
    id: "data", title: "Data Analytics", color: "#ec4899", rgb: "236,72,153",
    skills: [
      { n: "Python", i: "python" }, { n: "NumPy", i: "numpy" },
      { n: "pandas", i: "pandas" }, { n: "Power BI", i: "powerbi" },
      { n: "Excel", i: "microsoftexcel" }, { n: "ETL", i: null }, { n: "EDA", i: null },
    ],
  },
];
---

<div class="deck" data-deck>
  {CARDS.map((c) => (
    <button class="flip-card" type="button" data-card
      style={`--accent:${c.color}; --accentrgb:${c.rgb};`}
      aria-label={`${c.title} — click to pin the skills`}>
      <div class="flip-inner">
        <!-- ============ FRONT: animated pictogram ============ -->
        <div class="face front">
          {c.id === "lang" && (
            <svg class="viz viz-lang" viewBox="0 0 120 80">
              <path class="brace" d="M 38 14 q -12 2 -12 14 q 0 8 -8 12 q 8 4 8 12 q 0 12 12 14" />
              <path class="brace" d="M 82 14 q 12 2 12 14 q 0 8 8 12 q -8 4 -8 12 q 0 12 -12 14" />
              <circle class="tdot d1" cx="48" cy="40" r="4" />
              <circle class="tdot d2" cx="60" cy="40" r="4" />
              <circle class="tdot d3" cx="72" cy="40" r="4" />
            </svg>
          )}
          {c.id === "db" && (
            <svg class="viz viz-db" viewBox="0 0 120 80">
              <ellipse class="lid" cx="60" cy="16" rx="30" ry="8" />
              <path class="wall" d="M 30 16 v 44 q 30 14 60 0 v -44" />
              <path class="ring r1" d="M 30 31 q 30 14 60 0" />
              <path class="ring r2" d="M 30 46 q 30 14 60 0" />
              <circle class="led l1" cx="82" cy="24" r="2.6" />
              <circle class="led l2" cx="82" cy="39" r="2.6" />
              <circle class="led l3" cx="82" cy="54" r="2.6" />
            </svg>
          )}
          {c.id === "fullstack" && (
            <svg class="viz viz-fs" viewBox="0 0 120 80">
              <rect class="frame" x="22" y="8" width="76" height="42" rx="5" />
              <line class="frame" x1="22" y1="19" x2="98" y2="19" />
              <rect class="blk b1" x="28" y="25" width="18" height="19" rx="2" />
              <rect class="blk b2" x="50" y="25" width="42" height="8" rx="2" />
              <rect class="blk b3" x="50" y="36" width="30" height="8" rx="2" />
              <path class="pipe" d="M 60 50 v 12" />
              <rect class="frame" x="38" y="62" width="44" height="12" rx="3" />
              <circle class="led l1" cx="46" cy="68" r="2.4" />
              <circle class="led l2" cx="55" cy="68" r="2.4" />
            </svg>
          )}
          {c.id === "aiml" && (
            <svg class="viz viz-ai" viewBox="0 0 120 80">
              <g class="wires">
                <path class="wire" d="M 26 24 L 60 16" /><path class="wire" d="M 26 24 L 60 40" />
                <path class="wire" d="M 26 56 L 60 40" /><path class="wire" d="M 26 56 L 60 64" />
                <path class="wire" d="M 60 16 L 94 32" /><path class="wire" d="M 60 40 L 94 32" />
                <path class="wire" d="M 60 40 L 94 48" /><path class="wire" d="M 60 64 L 94 48" />
              </g>
              <circle class="node n1" cx="26" cy="24" r="6" /><circle class="node n2" cx="26" cy="56" r="6" />
              <circle class="node n3" cx="60" cy="16" r="6" /><circle class="node n4" cx="60" cy="40" r="6" />
              <circle class="node n5" cx="60" cy="64" r="6" />
              <circle class="node n6" cx="94" cy="32" r="6" /><circle class="node n7" cx="94" cy="48" r="6" />
            </svg>
          )}
          {c.id === "tools" && (
            <svg class="viz viz-tools" viewBox="0 0 120 80">
              <g class="gear g1">
                {Array.from({ length: 8 }).map((_, i) => (
                  <rect x="44" y="12" width="8" height="10" rx="2" transform={`rotate(${i * 45} 48 40)`} />
                ))}
                <circle cx="48" cy="40" r="15" class="gbody" />
                <circle cx="48" cy="40" r="6" class="ghole" />
              </g>
              <g class="gear g2">
                {Array.from({ length: 8 }).map((_, i) => (
                  <rect x="78" y="34" width="6" height="8" rx="2" transform={`rotate(${i * 45 + 22.5} 81 58)`} />
                ))}
                <circle cx="81" cy="58" r="11" class="gbody" />
                <circle cx="81" cy="58" r="4.5" class="ghole" />
              </g>
            </svg>
          )}
          {c.id === "data" && (
            <svg class="viz viz-data" viewBox="0 0 120 80">
              <line class="axis" x1="22" y1="70" x2="100" y2="70" />
              <rect class="bar bar1" x="30" y="46" width="12" height="24" rx="2" />
              <rect class="bar bar2" x="48" y="34" width="12" height="36" rx="2" />
              <rect class="bar bar3" x="66" y="52" width="12" height="18" rx="2" />
              <rect class="bar bar4" x="84" y="26" width="12" height="44" rx="2" />
              <path class="trend" d="M 30 42 L 52 28 L 70 44 L 92 18" />
              <circle class="tip" cx="92" cy="18" r="3.4" />
            </svg>
          )}
          <p class="card-title">{c.title}</p>
          <p class="card-hint">hover to peek · click to pin</p>
        </div>

        <!-- ============ BACK: the skills (glassy chips, stacked) ============ -->
        <div class="face back">
          <p class="card-title back-title">{c.title}</p>
          <div class="chips">
            {c.skills.map((s) => (
              <span class="chip">
                <span class="chip-ico">
                  <span class="mono">{(s.n.match(/[A-Za-z0-9]/) || [s.n[0]])[0]}</span>
                  {s.i && (
                    <img src={`https://cdn.simpleicons.org/${s.i}/${c.color.slice(1)}`} alt="" width="15" height="15" loading="lazy"
                      onload="this.previousElementSibling.style.display='none'"
                      onerror="this.remove()" />
                  )}
                </span>
                <span class="chip-name">{s.n}</span>
              </span>
            ))}
          </div>
        </div>
      </div>
    </button>
  ))}
</div>

<style>
  .deck {
    width: 100%; height: 100%;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-template-rows: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  /* ---------------- flip mechanics ---------------- */
  .flip-card {
    perspective: 1100px; border: none; background: none; padding: 0;
    cursor: pointer; min-height: 0; text-align: center; font: inherit; color: inherit;
    border-radius: 16px;
    transition: box-shadow 0.4s ease, transform 0.4s ease;
  }
  .flip-inner {
    position: relative; width: 100%; height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.7s cubic-bezier(0.35, 0.1, 0.25, 1);
  }
  @media (hover: hover) { .flip-card:hover .flip-inner { transform: rotateY(180deg); } }
  /* clicked = PINNED flipped (stays until the deck leaves view) */
  .flip-card.pinned .flip-inner { transform: rotateY(180deg); }

  /* outer bloom on hover / pinned (stationary — on the un-rotated card) */
  .flip-card:hover, .flip-card.pinned {
    box-shadow: 0 0 0 1px rgba(var(--accentrgb), 0.45), 0 18px 50px rgba(var(--accentrgb), 0.28);
  }

  .face {
    position: absolute; inset: 0;
    backface-visibility: hidden; -webkit-backface-visibility: hidden;
    border-radius: 16px;
    border: 1px solid rgba(var(--accentrgb), 0.28);   /* VISIBLE border, niche-tinted */
    background: var(--card-bg);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.07);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 10px; padding: 16px; overflow: hidden;
  }
  .face.back { transform: rotateY(180deg); }

  /* faint, gently-breathing inner glow at rest; blooms on hover/pin */
  .face::before {
    content: ""; position: absolute; inset: 0; border-radius: inherit; pointer-events: none;
    box-shadow: inset 0 0 26px rgba(var(--accentrgb), 0.10);
    opacity: 0.5; animation: cardBreath 4.5s ease-in-out infinite; transition: box-shadow 0.4s ease, opacity 0.4s ease;
  }
  @keyframes cardBreath { 0%, 100% { opacity: 0.35; } 50% { opacity: 0.8; } }
  .flip-card:hover .face, .flip-card.pinned .face { border-color: rgba(var(--accentrgb), 0.6); }
  .flip-card:hover .face::before, .flip-card.pinned .face::before {
    box-shadow: inset 0 0 46px rgba(var(--accentrgb), 0.22); opacity: 1; animation: none;
  }

  .card-title {
    margin: 0; font-family: "Space Grotesk", sans-serif; font-weight: 700;
    font-size: clamp(0.9rem, 1.1vw, 1.15rem); letter-spacing: 0.01em; color: var(--text);
  }
  .card-hint {
    margin: 0; font-family: "JetBrains Mono", monospace; font-size: 10px;
    letter-spacing: 0.06em; color: var(--text-faint);
  }
  .back-title { color: var(--accent); margin-bottom: 4px; flex-shrink: 0; }

  /* ------- skills: glassy chips in a 2-col grid (everything fits, no clipping) ------- */
  .chips {
    display: grid; grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px; width: 100%;
  }
  .chip {
    display: flex; align-items: center; gap: 8px; min-width: 0;
    padding: 6px 10px; border-radius: 10px;
    font-family: "Space Grotesk", sans-serif; font-weight: 500;
    font-size: clamp(10.5px, 0.8vw, 12.5px); color: var(--text);
    background: rgba(var(--accentrgb), 0.07);
    border: 1px solid rgba(var(--accentrgb), 0.18);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06), inset 0 1px 0 rgba(255, 255, 255, 0.28);
    -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);
  }
  :global(html[data-theme='dark']) .chip {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.35), inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }
  /* the icon badge — real logo when it loads, niche-colored initial as fallback */
  .chip-ico {
    flex: none; width: 24px; height: 24px; border-radius: 7px; position: relative; overflow: hidden;
    background: rgba(140, 140, 140, 0.14); display: grid; place-items: center;
  }
  .chip-ico img { width: 15px; height: 15px; object-fit: contain; }
  .mono { font-family: "Space Grotesk", sans-serif; font-weight: 800; font-size: 11px; color: var(--accent); line-height: 1; }
  .chip-name { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  /* ================= pictograms (front faces) ================= */
  .viz { width: clamp(84px, 7.6vw, 120px); height: auto; fill: none;
    stroke: var(--text-muted); stroke-width: 3; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }

  .tdot { fill: var(--accent); stroke: none; animation: type 1.4s ease-in-out infinite; }
  .d2 { animation-delay: 0.22s; } .d3 { animation-delay: 0.44s; }
  @keyframes type { 0%, 60%, 100% { opacity: 0.25; } 30% { opacity: 1; } }

  .ring { stroke: var(--text-faint); animation: ringGlow 2.4s ease-in-out infinite; }
  .r2 { animation-delay: 0.8s; }
  .lid { animation: ringGlow 2.4s ease-in-out infinite 1.6s; }
  @keyframes ringGlow { 0%, 100% { stroke: var(--text-faint); } 45% { stroke: var(--accent); } }
  .led { fill: var(--accent); stroke: none; animation: blink 1.8s ease-in-out infinite; }
  .l2 { animation-delay: 0.5s; } .l3 { animation-delay: 1s; }
  @keyframes blink { 0%, 55%, 100% { opacity: 0.15; } 25% { opacity: 1; } }

  .blk { fill: var(--text-faint); stroke: none; animation: assemble 3s ease-in-out infinite; transform-origin: center; }
  .b2 { animation-delay: 0.35s; } .b3 { animation-delay: 0.7s; }
  @keyframes assemble { 0%, 12% { opacity: 0; } 26%, 84% { opacity: 1; } 96%, 100% { opacity: 0; } }
  .pipe { stroke: var(--accent); stroke-dasharray: 4 5; animation: march 1.1s linear infinite; }
  @keyframes march { to { stroke-dashoffset: -9; } }

  .wire { stroke: var(--text-faint); stroke-width: 2; stroke-dasharray: 5 7; animation: march 1.6s linear infinite; }
  .node { fill: var(--card-bg); animation: fire 2.4s ease-in-out infinite; }
  .n3, .n4, .n5 { animation-delay: 0.5s; } .n6, .n7 { animation-delay: 1s; }
  @keyframes fire { 0%, 45%, 100% { stroke: var(--text-muted); fill: var(--card-bg); } 18% { stroke: var(--accent); fill: var(--accent); } }

  .gear rect, .gbody { fill: var(--text-muted); stroke: none; }
  .ghole { fill: var(--card-bg); stroke: none; }
  .gear { transform-box: fill-box; transform-origin: center; }
  .g1 { animation: spin-cw 6s linear infinite; } .g2 { animation: spin-ccw 4.4s linear infinite; }
  @keyframes spin-cw { to { transform: rotate(360deg); } }
  @keyframes spin-ccw { to { transform: rotate(-360deg); } }

  .axis { stroke: var(--text-faint); }
  .bar { fill: var(--text-faint); stroke: none; transform-origin: center 70px; animation: grow 2.6s ease-in-out infinite; }
  .bar2 { animation-delay: 0.2s; fill: var(--accent); opacity: 0.75; }
  .bar3 { animation-delay: 0.4s; }
  .bar4 { animation-delay: 0.6s; fill: var(--accent); opacity: 0.75; }
  @keyframes grow { 0%, 100% { transform: scaleY(0.55); } 50% { transform: scaleY(1); } }
  .trend { stroke: var(--accent); stroke-dasharray: 130; animation: draw 3s ease-in-out infinite; }
  @keyframes draw { 0% { stroke-dashoffset: 130; } 55%, 80% { stroke-dashoffset: 0; } 100% { stroke-dashoffset: -130; } }
  .tip { fill: var(--accent); stroke: none; animation: blink 3s ease-in-out infinite 1.6s; }

  @media (max-width: 899px) {
    .deck { grid-template-columns: repeat(2, minmax(0, 1fr)); grid-template-rows: none; grid-auto-rows: minmax(210px, auto); }
  }
  @media (max-width: 520px) { .deck { grid-template-columns: 1fr; } }
</style>

<script>
  /* click = PIN the flip (skills stay) · leaving the deck resets every pin */
  const deck = document.querySelector<HTMLElement>("[data-deck]");
  if (deck) {
    const cards = Array.from(deck.querySelectorAll<HTMLElement>("[data-card]"));
    cards.forEach((c) => c.addEventListener("click", () => c.classList.toggle("pinned")));
    new IntersectionObserver(([e]) => {
      if (!e.isIntersecting) cards.forEach((c) => c.classList.remove("pinned"));
    }, { threshold: 0.15 }).observe(deck);
  }
</script>
