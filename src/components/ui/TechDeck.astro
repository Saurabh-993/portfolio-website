---
/**
 * TechDeck.astro — six flip-cards, one per skill area.
 *
 * FRONT: a clean, animated vector pictogram conveying the category
 * BACK  (hover-flip): the actual skills as chips
 * CLICK : the card spins forever (until the deck scrolls out of view,
 *         which resets every spinning card)
 *
 * Pictograms are inline SVG + CSS keyframes — cheap, theme-aware
 * (currentColor + var(--accent)), auto-disabled by the global
 * prefers-reduced-motion rule.
 */
const CARDS = [
  {
    id: "lang", title: "Languages",
    skills: ["python", "javascript", "sql", "typescript"],
  },
  {
    id: "db", title: "Databases",
    skills: ["postgresql", "mysql", "mongodb", "qdrant"],
  },
  {
    id: "fullstack", title: "Fullstack",
    skills: ["html5", "css", "js", "express", "node.js", "mongoose"],
  },
  {
    id: "aiml", title: "AI / ML",
    skills: ["langchain", "langgraph", "RAG", "ai/ml concepts", "prompt engineering"],
  },
  {
    id: "tools", title: "Tools, Automation & Dev",
    skills: ["adobe cc", "figma", "claude", "chatgpt", "n8n", "git", "github", "docker"],
  },
  {
    id: "data", title: "Data Analytics",
    skills: ["python", "numpy", "ETL", "pandas", "EDA", "power bi", "excel"],
  },
];
---

<div class="deck" data-deck>
  {CARDS.map((c) => (
    <button class="flip-card" type="button" data-card
      aria-label={`${c.title} — click to keep flipping`}>
      <div class="flip-inner">
        <!-- ============ FRONT: animated pictogram ============ -->
        <div class="face front">
          {c.id === "lang" && (
            <svg class="viz viz-lang" viewBox="0 0 120 80">
              <path class="brace" d="M 38 14 q -12 2 -12 14 q 0 8 -8 12 q 8 4 8 12 q 0 12 12 14" />
              <path class="brace" d="M 82 14 q 12 2 12 14 q 0 8 8 12 q -8 4 -8 12 q 0 12 -12 14" />
              <circle class="tdot d1" cx="48" cy="40" r="4" />
              <circle class="tdot d2" cx="60" cy="40" r="4" />
              <circle class="tdot d3" cx="72" cy="40" r="4" />
            </svg>
          )}
          {c.id === "db" && (
            <svg class="viz viz-db" viewBox="0 0 120 80">
              <ellipse class="lid" cx="60" cy="16" rx="30" ry="8" />
              <path class="wall" d="M 30 16 v 44 q 30 14 60 0 v -44" />
              <path class="ring r1" d="M 30 31 q 30 14 60 0" />
              <path class="ring r2" d="M 30 46 q 30 14 60 0" />
              <circle class="led l1" cx="82" cy="24" r="2.6" />
              <circle class="led l2" cx="82" cy="39" r="2.6" />
              <circle class="led l3" cx="82" cy="54" r="2.6" />
            </svg>
          )}
          {c.id === "fullstack" && (
            <svg class="viz viz-fs" viewBox="0 0 120 80">
              <rect class="frame" x="22" y="8" width="76" height="42" rx="5" />
              <line class="frame" x1="22" y1="19" x2="98" y2="19" />
              <rect class="blk b1" x="28" y="25" width="18" height="19" rx="2" />
              <rect class="blk b2" x="50" y="25" width="42" height="8" rx="2" />
              <rect class="blk b3" x="50" y="36" width="30" height="8" rx="2" />
              <path class="pipe" d="M 60 50 v 12" />
              <rect class="frame" x="38" y="62" width="44" height="12" rx="3" />
              <circle class="led l1" cx="46" cy="68" r="2.4" />
              <circle class="led l2" cx="55" cy="68" r="2.4" />
            </svg>
          )}
          {c.id === "aiml" && (
            <svg class="viz viz-ai" viewBox="0 0 120 80">
              <g class="wires">
                <path class="wire" d="M 26 24 L 60 16" /><path class="wire" d="M 26 24 L 60 40" />
                <path class="wire" d="M 26 56 L 60 40" /><path class="wire" d="M 26 56 L 60 64" />
                <path class="wire" d="M 60 16 L 94 32" /><path class="wire" d="M 60 40 L 94 32" />
                <path class="wire" d="M 60 40 L 94 48" /><path class="wire" d="M 60 64 L 94 48" />
              </g>
              <circle class="node n1" cx="26" cy="24" r="6" /><circle class="node n2" cx="26" cy="56" r="6" />
              <circle class="node n3" cx="60" cy="16" r="6" /><circle class="node n4" cx="60" cy="40" r="6" />
              <circle class="node n5" cx="60" cy="64" r="6" />
              <circle class="node n6" cx="94" cy="32" r="6" /><circle class="node n7" cx="94" cy="48" r="6" />
            </svg>
          )}
          {c.id === "tools" && (
            <svg class="viz viz-tools" viewBox="0 0 120 80">
              <g class="gear g1">
                {Array.from({ length: 8 }).map((_, i) => (
                  <rect x="44" y="12" width="8" height="10" rx="2"
                    transform={`rotate(${i * 45} 48 40)`} />
                ))}
                <circle cx="48" cy="40" r="15" class="gbody" />
                <circle cx="48" cy="40" r="6" class="ghole" />
              </g>
              <g class="gear g2">
                {Array.from({ length: 8 }).map((_, i) => (
                  <rect x="78" y="34" width="6" height="8" rx="2"
                    transform={`rotate(${i * 45 + 22.5} 81 58)`} />
                ))}
                <circle cx="81" cy="58" r="11" class="gbody" />
                <circle cx="81" cy="58" r="4.5" class="ghole" />
              </g>
            </svg>
          )}
          {c.id === "data" && (
            <svg class="viz viz-data" viewBox="0 0 120 80">
              <line class="axis" x1="22" y1="70" x2="100" y2="70" />
              <rect class="bar bar1" x="30" y="46" width="12" height="24" rx="2" />
              <rect class="bar bar2" x="48" y="34" width="12" height="36" rx="2" />
              <rect class="bar bar3" x="66" y="52" width="12" height="18" rx="2" />
              <rect class="bar bar4" x="84" y="26" width="12" height="44" rx="2" />
              <path class="trend" d="M 30 42 L 52 28 L 70 44 L 92 18" />
              <circle class="tip" cx="92" cy="18" r="3.4" />
            </svg>
          )}
          <p class="card-title">{c.title}</p>
          <p class="card-hint">hover · click to pin the flip</p>
        </div>

        <!-- ============ BACK: the skills ============ -->
        <div class="face back">
          <p class="card-title back-title">{c.title}</p>
          <div class="chips">
            {c.skills.map((s) => <span class="chip">{s}</span>)}
          </div>
        </div>
      </div>
    </button>
  ))}
</div>

<style>
  .deck {
    width: 100%;
    height: 100%;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-template-rows: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  /* ---------------- flip mechanics ---------------- */
  .flip-card {
    perspective: 1100px;
    border: none;
    background: none;
    padding: 0;
    cursor: pointer;
    min-height: 0;
    text-align: center;
    font: inherit;
    color: inherit;
  }
  .flip-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.7s cubic-bezier(0.35, 0.1, 0.25, 1);
  }
  @media (hover: hover) {
    .flip-card:hover .flip-inner { transform: rotateY(180deg); }
  }
  /* clicked: spin forever (cleared when the deck leaves the viewport) */
  .flip-card.spinning .flip-inner {
    animation: deck-spin 2.8s linear infinite;
  }
  @keyframes deck-spin { from { transform: rotateY(0deg); } to { transform: rotateY(360deg); } }

  .face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: 14px;
    border: 1px solid var(--glass-border);
    background: var(--card-bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px;
    overflow: hidden;
  }
  .face.back { transform: rotateY(180deg); }

  .card-title {
    margin: 0;
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: clamp(0.82rem, 1vw, 1rem);
    letter-spacing: 0.02em;
    color: var(--text);
  }
  .card-hint {
    margin: 0;
    font-family: "JetBrains Mono", monospace;
    font-size: 9.5px;
    letter-spacing: 0.08em;
    color: var(--text-faint);
  }
  .back-title { color: var(--accent); margin-bottom: 2px; }

  .chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px;
    max-width: 95%;
  }
  .chip {
    font-family: "JetBrains Mono", monospace;
    font-size: clamp(9px, 0.72vw, 11.5px);
    padding: 3px 9px;
    border-radius: 999px;
    border: 1px solid var(--glass-border);
    color: var(--text-muted);
    white-space: nowrap;
  }

  /* ================= pictograms (front faces) ================= */
  .viz {
    width: clamp(84px, 7.6vw, 120px);
    height: auto;
    fill: none;
    stroke: var(--text-muted);
    stroke-width: 3;
    stroke-linecap: round;
    stroke-linejoin: round;
    flex-shrink: 0;
  }

  /* Languages: braces + "typing" dots */
  .tdot { fill: var(--accent); stroke: none; animation: type 1.4s ease-in-out infinite; }
  .d2 { animation-delay: 0.22s; }
  .d3 { animation-delay: 0.44s; }
  @keyframes type { 0%, 60%, 100% { opacity: 0.25; } 30% { opacity: 1; } }

  /* Databases: cylinder + scanning rings + blinking LEDs */
  .ring { stroke: var(--text-faint); animation: ringGlow 2.4s ease-in-out infinite; }
  .r2 { animation-delay: 0.8s; }
  .lid { animation: ringGlow 2.4s ease-in-out infinite 1.6s; }
  @keyframes ringGlow { 0%, 100% { stroke: var(--text-faint); } 45% { stroke: var(--accent); } }
  .led { fill: var(--accent); stroke: none; animation: blink 1.8s ease-in-out infinite; }
  .l2 { animation-delay: 0.5s; }
  .l3 { animation-delay: 1s; }
  @keyframes blink { 0%, 55%, 100% { opacity: 0.15; } 25% { opacity: 1; } }

  /* Fullstack: UI blocks assembling + data pipe down to the server */
  .blk { fill: var(--text-faint); stroke: none; animation: assemble 3s ease-in-out infinite; transform-origin: center; }
  .b2 { animation-delay: 0.35s; }
  .b3 { animation-delay: 0.7s; }
  @keyframes assemble { 0%, 12% { opacity: 0; } 26%, 84% { opacity: 1; } 96%, 100% { opacity: 0; } }
  .pipe { stroke: var(--accent); stroke-dasharray: 4 5; animation: march 1.1s linear infinite; }
  @keyframes march { to { stroke-dashoffset: -9; } }

  /* AI/ML: pulses travel the wires, nodes fire in sequence */
  .wire { stroke: var(--text-faint); stroke-width: 2; stroke-dasharray: 5 7; animation: march 1.6s linear infinite; }
  .node { fill: var(--card-bg); animation: fire 2.4s ease-in-out infinite; }
  .n3, .n4, .n5 { animation-delay: 0.5s; }
  .n6, .n7 { animation-delay: 1s; }
  @keyframes fire {
    0%, 45%, 100% { stroke: var(--text-muted); fill: var(--card-bg); }
    18% { stroke: var(--accent); fill: var(--accent); }
  }

  /* Tools: meshing gears, opposite spins */
  .gear rect, .gbody { fill: var(--text-muted); stroke: none; }
  .ghole { fill: var(--card-bg); stroke: none; }
  .gear { transform-box: fill-box; transform-origin: center; }
  .g1 { animation: spin-cw 6s linear infinite; }
  .g2 { animation: spin-ccw 4.4s linear infinite; }
  @keyframes spin-cw { to { transform: rotate(360deg); } }
  @keyframes spin-ccw { to { transform: rotate(-360deg); } }

  /* Data Analytics: bars breathe up, trend line redraws */
  .axis { stroke: var(--text-faint); }
  .bar { fill: var(--text-faint); stroke: none; transform-origin: center 70px; animation: grow 2.6s ease-in-out infinite; }
  .bar2 { animation-delay: 0.2s; fill: var(--accent); opacity: 0.75; }
  .bar3 { animation-delay: 0.4s; }
  .bar4 { animation-delay: 0.6s; fill: var(--accent); opacity: 0.75; }
  @keyframes grow { 0%, 100% { transform: scaleY(0.55); } 50% { transform: scaleY(1); } }
  .trend { stroke: var(--accent); stroke-dasharray: 130; animation: draw 3s ease-in-out infinite; }
  @keyframes draw { 0% { stroke-dashoffset: 130; } 55%, 80% { stroke-dashoffset: 0; } 100% { stroke-dashoffset: -130; } }
  .tip { fill: var(--accent); stroke: none; animation: blink 3s ease-in-out infinite 1.6s; }

  /* ---------------- responsive ---------------- */
  @media (max-width: 899px) {
    .deck {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-template-rows: none;
      grid-auto-rows: minmax(190px, auto);
    }
  }
  @media (max-width: 520px) {
    .deck { grid-template-columns: 1fr; }
  }
</style>

<script>
  /* click = spin forever · scrolling the deck out of view resets all */
  const deck = document.querySelector<HTMLElement>("[data-deck]");
  if (deck) {
    const cards = Array.from(deck.querySelectorAll<HTMLElement>("[data-card]"));
    cards.forEach((c) =>
      c.addEventListener("click", () => c.classList.toggle("spinning"))
    );
    new IntersectionObserver(([e]) => {
      if (!e.isIntersecting) cards.forEach((c) => c.classList.remove("spinning"));
    }).observe(deck);
  }
</script>
