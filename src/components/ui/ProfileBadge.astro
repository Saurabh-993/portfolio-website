---
/**
 * ProfileBadge.astro — small profile image, fixed top-left.
 *
 *  - Default shows IMG1; hovering OR opening the card crossfades to IMG2.
 *    (Both use the placeholder for now — IMG1 is grayscaled so the swap is
 *    visible. Drop img1.jpg / img2.jpg into assets/images and update the
 *    imports below.)
 *  - Click: badge enlarges + quick-links card reveals (GSAP):
 *    Resume / LinkedIn / GitHub — recruiter-in-a-hurry shortcuts.
 *  - A sketchy hand-drawn arrow + note ("in a hurry? check it!") points at
 *    the badge: draws itself in on load, then idles with a gentle wiggle.
 */
import profile from '../../assets/images/profile-placeholder.svg';

const PLACEHOLDER = profile.src;
const IMG1 = '/profile/img1.jpg'; // default (shown grayscale); falls back to placeholder
const IMG2 = '/profile/img2.jpg'; // revealed on hover / open (colour)

const RESUME_URL = '/resume.pdf'; // served from public/
const LINKEDIN_URL = 'https://www.linkedin.com/in/saurabh-sharma-375393336';
const GITHUB_URL = 'https://github.com/Saurabh-993';
---

<div class="profile-badge" id="profile-badge">
  <button class="badge-btn glass" aria-label="Profile — quick links" aria-expanded="false">
    <!-- img1 under, img2 over; opacity crossfade on hover / open -->
    <img class="photo photo-img1" src={IMG1} alt="" width="52" height="52" onerror={`this.onerror=null;this.src='${PLACEHOLDER}'`} />
    <img class="photo photo-img2" src={IMG2} alt="Saurabh" width="52" height="52" onerror={`this.onerror=null;this.src='${PLACEHOLDER}'`} />
  </button>

  <!-- sketchy "look here" hint -->
  <div class="badge-hint" aria-hidden="true">
    <svg class="hint-arrow" viewBox="0 0 64 30" width="72" height="34">
      <!-- wobbly marker line, drawn right→left toward the badge -->
      <path class="arrow-line" d="M 60 7 C 44 3, 30 13, 18 15 C 14 15.7, 11 16, 7 17" />
      <!-- arrowhead -->
      <path class="arrow-head" d="M 14 11 L 6 17 L 15 21" />
    </svg>
    <span class="hint-text">in a hurry? check it!</span>
  </div>

  <!-- Quick-links card for recruiters in a hurry -->
  <div class="profile-card glass" hidden>
    <p class="card-name serif">Saurabh</p>
    <a class="card-link" href={RESUME_URL} target="_blank" rel="noopener">
      <span class="dot"></span> Resume
    </a>
    <a class="card-link" href={LINKEDIN_URL} target="_blank" rel="noopener">
      <span class="dot"></span> LinkedIn
    </a>
    <a class="card-link" href={GITHUB_URL} target="_blank" rel="noopener">
      <span class="dot"></span> GitHub
    </a>
  </div>
</div>

<style>
  /* Caveat = the handwritten/marker voice of the hint */
  @import url('https://fonts.googleapis.com/css2?family=Caveat:wght@600&display=swap');

  .profile-badge {
    position: fixed;
    top: 18px;
    left: 22px;
    z-index: 110;
  }

  .badge-btn {
    position: relative;
    width: 56px;
    height: 56px;
    padding: 2px;
    border-radius: 50%;
    overflow: hidden;
    display: block;
  }

  .photo {
    position: absolute;
    inset: 2px;
    width: calc(100% - 4px);
    height: calc(100% - 4px);
    border-radius: 50%;
    object-fit: cover;
  }

  /* IMG1 base (full colour, centered, crisp pixels for a pixel-avatar),
     IMG2 crossfades over on hover (desktop) or whenever the card is open */
  .photo-img1 { object-position: center; image-rendering: pixelated; }
  .photo-img2 { opacity: 0; transition: opacity 0.35s ease; }
  @media (hover: hover) and (min-width: 1024px) {
    .badge-btn:hover .photo-img2 { opacity: 1; }
  }
  .profile-badge.open .photo-img2 { opacity: 1; }
  /* Mobile: show the real photo (img2) directly */
  @media (max-width: 1023px) {
    .photo-img2 { opacity: 1; }
  }

  /* ---------------- sketchy hint ---------------- */
  .badge-hint {
    position: absolute;
    left: calc(100% + 8px);
    top: 4px;
    display: flex;
    align-items: center;
    gap: 4px;
    width: max-content;
    pointer-events: none;
    transform: rotate(-4.5deg); /* matches the sway's `from` — no jump when it kicks in */
    transform-origin: left center;
    /* gentle idle sway (killed by reduced-motion rule in global.css) */
    animation: hint-sway 3.4s ease-in-out 2.2s infinite alternate;
    opacity: 1;
    transition: opacity 0.25s ease;
  }
  /* get out of the way once the card is open — it did its job */
  .profile-badge.open .badge-hint { opacity: 0; }

  @keyframes hint-sway {
    from { transform: rotate(-4.5deg) translateY(0); }
    to   { transform: rotate(-1.5deg) translateY(2px); }
  }

  .hint-arrow {
    overflow: visible;
    flex-shrink: 0;
  }
  .arrow-line,
  .arrow-head {
    fill: none;
    stroke: var(--text-muted);
    stroke-width: 2.4;           /* medium weight — marker, not Sharpie */
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  /* draw-in: line sketches itself right→left, then the head + text pop in.
     (Under prefers-reduced-motion, global.css collapses durations → the
     final drawn state appears instantly.) */
  .arrow-line {
    stroke-dasharray: 90;
    stroke-dashoffset: 90;
    animation: hint-draw 0.8s ease-out 1.1s forwards;
  }
  .arrow-head {
    opacity: 0;
    animation: hint-pop 0.3s ease-out 1.8s forwards;
  }
  .hint-text {
    font-family: 'Caveat', 'Comic Sans MS', cursive;
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--text-muted);
    white-space: nowrap;
    opacity: 0;
    animation: hint-pop 0.45s ease-out 1.5s forwards;
  }
  @keyframes hint-draw { to { stroke-dashoffset: 0; } }
  @keyframes hint-pop  { to { opacity: 0.9; } }

  @media (max-width: 1023px) {
    .hint-text { font-size: 1.05rem; }
    .hint-arrow { width: 56px; height: 26px; }
  }

  /* ---------------- quick-links card ---------------- */
  .profile-card[hidden] { display: none; } /* keep [hidden] working despite display:flex */
  .profile-card {
    position: absolute;
    top: calc(100% + 10px);
    left: 0;
    min-width: 170px;
    padding: 14px 16px;
    border-radius: 16px;
    background: var(--card-bg);
    display: flex;
    flex-direction: column;
    gap: 8px;
    transform-origin: top left;
  }

  .card-name {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 2px;
  }

  .card-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.2s ease;
  }
  .card-link:hover { color: var(--text); }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent-glow);
  }
</style>

<script>
  /**
   * Click/tap: enlarge badge slightly + reveal card (GSAP).
   * One-shot, event-driven tweens — cheap enough for all devices.
   */
  import { gsap } from 'gsap';

  const badge = document.getElementById('profile-badge')!;
  const btn = badge.querySelector<HTMLButtonElement>('.badge-btn')!;
  const card = badge.querySelector<HTMLElement>('.profile-card')!;
  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

  let open = false;

  const show = () => {
    card.hidden = false;
    badge.classList.add('open'); // → img2 crossfade + hint fades away
    if (reduced) return;
    gsap.fromTo(
      card,
      { autoAlpha: 0, y: -8, scale: 0.92 },
      { autoAlpha: 1, y: 0, scale: 1, duration: 0.35, ease: 'back.out(1.6)' }
    );
    gsap.to(btn, { scale: 1.12, duration: 0.3, ease: 'back.out(2)' });
  };

  const hide = () => {
    badge.classList.remove('open');
    if (reduced) {
      card.hidden = true;
      return;
    }
    gsap.to(card, {
      autoAlpha: 0, y: -8, scale: 0.92, duration: 0.25, ease: 'power2.in',
      onComplete: () => { card.hidden = true; },
    });
    gsap.to(btn, { scale: 1, duration: 0.25, ease: 'power2.out' });
  };

  btn.addEventListener('click', () => {
    open = !open;
    btn.setAttribute('aria-expanded', String(open));
    open ? show() : hide();
  });

  // Close when clicking anywhere else
  document.addEventListener('click', (e) => {
    if (open && !badge.contains(e.target as Node)) {
      open = false;
      btn.setAttribute('aria-expanded', 'false');
      hide();
    }
  });
</script>
