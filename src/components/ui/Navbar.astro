---
/**
 * Navbar.astro — glassmorphic floating pill, fixed top-center.
 * Desktop: theme toggle | links | highlighted "Start project" button.
 * Mobile (<1024px): pill collapses to toggle + hamburger; links open in a
 * small glass panel below the pill.
 * Anchor clicks scroll via Lenis when available.
 */
import ThemeToggle from './ThemeToggle.astro';

const links = [
  { label: 'Home', href: '#hero' },
  { label: 'Skills', href: '#work' },
  { label: 'Story', href: '#story' },
  { label: 'Projects', href: '#projects' },
];
---

<header class="navbar">
  <nav class="pill glass" aria-label="Main navigation">
    <ThemeToggle />

    <!-- Desktop links -->
    <ul class="nav-links">
      {links.map((l) => (
        <li><a class="nav-link" href={l.href}>{l.label}</a></li>
      ))}
    </ul>

    <a class="cta" href="#connect">Let's connect</a>

    <!-- Hamburger (mobile only) -->
    <button class="hamburger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- Mobile dropdown panel -->
  <div class="nav-panel glass" hidden>
    {links.map((l) => (
      <a class="panel-link" href={l.href}>{l.label}</a>
    ))}
    <a class="cta panel-cta" href="#connect">Let's connect</a>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 18px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .pill {
    display: flex;
    align-items: center;
    gap: clamp(0.6rem, 2vw, 1.4rem);
    padding: 8px 10px;
    border-radius: 999px;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: clamp(0.8rem, 2vw, 1.6rem);
  }

  .nav-link {
    font-size: clamp(0.8rem, 1vw, 0.9rem);
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.2s ease;
  }
  .nav-link:hover { color: var(--text); }

  .cta {
    font-size: clamp(0.8rem, 1vw, 0.9rem);
    font-weight: 600;
    padding: 8px 16px;
    border-radius: 999px;
    background: var(--accent);
    color: #14101f;
    box-shadow: 0 0 18px var(--accent-glow);
    transition: transform 0.2s ease, box-shadow 0.3s ease, background-color 0.3s ease;
    white-space: nowrap;
  }
  .cta:hover { transform: translateY(-1px); box-shadow: 0 0 28px var(--accent-glow); }

  /* Hamburger — hidden on desktop */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 4px;
    padding: 8px;
  }
  .hamburger span {
    width: 18px;
    height: 2px;
    border-radius: 2px;
    background: var(--text);
    transition: transform 0.25s ease, opacity 0.25s ease;
  }
  .hamburger[aria-expanded='true'] span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .hamburger[aria-expanded='true'] span:nth-child(2) { opacity: 0; }
  .hamburger[aria-expanded='true'] span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  .nav-panel[hidden] { display: none; } /* keep [hidden] working despite display:flex */
  .nav-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    padding: 20px 40px;
    border-radius: 20px;
  }
  .panel-link { font-weight: 500; }
  .panel-cta { margin-top: 4px; }

  /* Mobile: collapse links/cta into hamburger panel */
  @media (max-width: 1023px) {
    .nav-links, .pill > .cta { display: none; }
    .hamburger { display: flex; }
  }
</style>

<script>
  // Hamburger toggle + Lenis-powered anchor scrolling.
  const header = document.querySelector<HTMLElement>('.navbar')!;
  const burger = header.querySelector<HTMLButtonElement>('.hamburger')!;
  const panel = header.querySelector<HTMLElement>('.nav-panel')!;

  burger.addEventListener('click', () => {
    const open = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!open));
    panel.hidden = open;
  });

  // Smooth-scroll anchors through Lenis (falls back to native if absent)
  header.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
    a.addEventListener('click', (e) => {
      const target = document.querySelector(a.hash);
      if (!target) return;
      e.preventDefault();
      panel.hidden = true;
      burger.setAttribute('aria-expanded', 'false');
      // @ts-ignore — set in Base.astro when motion is allowed
      const lenis = window.lenis;
      if (lenis) lenis.scrollTo(target, { offset: 0 });
      else target.scrollIntoView();
    });
  });
</script>
