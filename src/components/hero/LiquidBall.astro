---
// LiquidBall.astro — a real 3D water ball (three.js).
// Requires:  npm install three
// Reads light/dark from <html data-theme="..."> or the .dark class.
---

<div class="liquid-ball"></div>

<style>
  .liquid-ball {
    width: min(300px, 48vw);   /* smaller, near the original size */
    aspect-ratio: 1 / 1;
    margin: 0 auto;
    position: relative;
  }
  .liquid-ball canvas { display:block; width:100% !important; height:100% !important; }
</style>

<script>
  import * as THREE from "three";
  import { RoomEnvironment } from "three/examples/jsm/environments/RoomEnvironment.js";
  import { SimplexNoise } from "three/examples/jsm/math/SimplexNoise.js";

  /* ---------- feel ---------- */
  const TUNE = {
    wobbleAmp:   0.03,   // smoother/rounder (raise for more molten, 0 = perfect ball)
    wobbleFreq:  1.25,
    wobbleSpeed: 0.25,
    spin:        0.12,
    mousePull:   0.5,
    mouseLag:    0.06,
  };
  /* water = pale blue body + blue absorption; a warm SUN light hits the right side */
  const THEMES = {
    day: {
      color:0xdcefff, attenuation:0x4fa6ff, attnDist:2.3, envInt:1.2,
      emissive:0x000000, emInt:0.0,
      sunColor:0xffcf7a, sunInt:1.5,          // warm yellow sun from the right
      keyColor:0xffffff, keyInt:1.6,
    },
    night: {
      color:0xbcd2ff, attenuation:0x2740c8, attnDist:1.25, envInt:1.0,
      emissive:0x24346e, emInt:0.35,          // soft cool glow
      sunColor:0x9fb4ff, sunInt:0.8,
      keyColor:0xdfe6ff, keyInt:1.2,
    },
  };
  /* -------------------------- */

  const wrap = document.querySelector(".liquid-ball");
  if (wrap) {
    const isDark = () => {
      const el = document.documentElement;
      return el.classList.contains("dark") ||
        el.getAttribute("data-theme") === "dark" || el.getAttribute("data-theme") === "night";
    };
    let theme = isDark() ? "night" : "day";

    const renderer = new THREE.WebGLRenderer({ antialias:true, alpha:true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
    renderer.setClearColor(0x000000, 0);
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    wrap.appendChild(renderer.domElement);

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(35, 1, 0.1, 100);
    camera.position.set(0, 0, 5.3);   // further back = smaller ball, more margin

    const pmrem = new THREE.PMREMGenerator(renderer);
    scene.environment = pmrem.fromScene(new RoomEnvironment(), 0.04).texture;

    const key = new THREE.DirectionalLight(0xffffff, 1.6);
    key.position.set(-2.5, 3, 3);
    scene.add(key);
    const sun = new THREE.DirectionalLight(0xffcf7a, 1.5);   // the RIGHT-side sun tint
    sun.position.set(4, 1, 2);
    scene.add(sun);
    scene.add(new THREE.AmbientLight(0xffffff, 0.28));

    const geo = new THREE.IcosahedronGeometry(1, 24);
    const basePos = geo.attributes.position.array.slice(0);

    const mat = new THREE.MeshPhysicalMaterial({
      transmission: 1.0, thickness: 1.1, roughness: 0.05, metalness: 0.0,
      ior: 1.33, clearcoat: 0.5, clearcoatRoughness: 0.12, transparent: true,
    });
    const mesh = new THREE.Mesh(geo, mat);
    scene.add(mesh);

    function applyTheme() {
      const T = THEMES[theme];
      mat.color = new THREE.Color(T.color);
      mat.attenuationColor = new THREE.Color(T.attenuation);
      mat.attenuationDistance = T.attnDist;
      mat.envMapIntensity = T.envInt;
      mat.emissive = new THREE.Color(T.emissive);
      mat.emissiveIntensity = T.emInt;
      mat.needsUpdate = true;
      sun.color = new THREE.Color(T.sunColor); sun.intensity = T.sunInt;
      key.color = new THREE.Color(T.keyColor); key.intensity = T.keyInt;
    }
    applyTheme();
    new MutationObserver(() => { theme = isDark() ? "night" : "day"; applyTheme(); })
      .observe(document.documentElement, { attributes:true, attributeFilter:["class","data-theme"] });

    function resize() {
      const w = wrap.clientWidth, h = wrap.clientHeight;
      renderer.setSize(w, h, false);
      camera.aspect = w / h; camera.updateProjectionMatrix();
    }
    resize(); window.addEventListener("resize", resize);

    const simplex = new SimplexNoise();
    let mx=0, my=0, tx=0, ty=0;
    window.addEventListener("pointermove", (e) => {
      const r = renderer.domElement.getBoundingClientRect();
      tx = ((e.clientX - r.left) / r.width) * 2 - 1;
      ty = ((e.clientY - r.top) / r.height) * 2 - 1;
    });

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const pos = geo.attributes.position;
    const clock = new THREE.Clock();

    function deform(t) {
      const A = TUNE.wobbleAmp, F = TUNE.wobbleFreq;
      for (let i = 0; i < pos.count; i++) {
        const ox = basePos[i*3], oy = basePos[i*3+1], oz = basePos[i*3+2];
        const n = simplex.noise3d(ox*F + t, oy*F + t*0.8, oz*F - t*0.6);
        const s = 1 + n * A;
        pos.setXYZ(i, ox*s, oy*s, oz*s);
      }
      pos.needsUpdate = true;
      geo.computeVertexNormals();
    }

    function frame() {
      requestAnimationFrame(frame);
      if (!wrap.clientWidth) return;   // hidden (e.g. mobile shows the SVG orb) — skip WebGL work
      const t = clock.getElapsedTime();
      if (!reduce) {
        deform(t * TUNE.wobbleSpeed);
        mx += (tx - mx) * TUNE.mouseLag;
        my += (ty - my) * TUNE.mouseLag;
        mesh.rotation.y = t * TUNE.spin + mx * TUNE.mousePull;
        mesh.rotation.x = -my * TUNE.mousePull * 0.7;
      }
      renderer.render(scene, camera);
    }
    frame();
  }
</script>