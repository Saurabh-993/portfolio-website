---
// StrikeHeadline.astro
// Animated hero headline. Uses your installed GSAP (npm i gsap).
---

<h1 class="strike-headline">
  <span class="row one">
    <span class="static">I'm the one who</span>
    <span class="slot" data-slot="verb"><span class="txt">Designs</span><i class="line"></i></span>
    <span class="slot" data-slot="noun"><span class="txt">visions</span></span>
  </span>
  <span class="row two">
    <span class="static">essentially, a</span>
    <span class="slot" data-slot="role"><span class="txt">Designer</span><i class="line"></i></span>
  </span>
</h1>

<style>
  .strike-headline {
    text-align:center;
    font-weight:700;
    letter-spacing:-0.01em;
    color:var(--text, #111);
    min-height:2.6em;                 /* reserves 2 lines so nothing jumps */
    font-family:"Helvetica Neue", Helvetica, Arial, sans-serif;
    margin:0;
    /* To try ALL CAPS, uncomment: */
    /* text-transform:uppercase; */
  }

  .strike-headline .row {
    display:block; white-space:nowrap;   /* each line stays on ONE row, always */
    font-size:clamp(1.2rem, 4vw, 2.45rem);   /* a bit smaller now */
    line-height:1.3;
  }

  .strike-headline .static { display:inline-block; }
  .strike-headline .slot { position:relative; display:inline-block; white-space:nowrap; }
  .strike-headline .slot .txt { display:inline-block; }

  /* GUARANTEED SPACING: gap comes from CSS, not text whitespace (Astro can strip that) */
  .strike-headline .slot { margin-left:0.3em; }

  /* focus words: bold + italic + slightly larger */
  .strike-headline .slot[data-slot="verb"] .txt,
  .strike-headline .slot[data-slot="role"] .txt {
    font-style:italic; font-weight:700;
    font-size:1.05em; letter-spacing:-0.02em;
  }

  /* the changing noun stays quiet/muted */
  .strike-headline .slot[data-slot="noun"] .txt { color:var(--muted, #9a968c); font-weight:500; }

  /* strike line: overlay, matches word color, never affects spacing */
  .strike-headline .slot .line {
    position:absolute; left:0; top:56%;
    width:100%; height:0.1em;
    background:currentColor; border-radius:2px;
    transform:scaleX(0); transform-origin:left center;
    pointer-events:none;
  }
</style>

<script>
  import gsap from "gsap";

  /* ============ EDIT WORDS + COLORS HERE ============ */
  const states = [
    { verb:"Designs",    noun:"visions",     role:"Designer",       color:"#E5674F" },
    { verb:"Develops",   noun:"ideas",       role:"Developer",      color:"#2F7FE5" },
    { verb:"Architects", noun:"systems",     role:"Thinker",        color:"#3FA06B" },
    { verb:"Solves",     noun:"problems",    role:"Problem-Solver", color:"#9B5CF6" },
    { verb:"Builds",     noun:"imagination", role:"Builder",        color:"#E0A200", final:true },
  ];

  /* ============ TIMING / FEEL KNOBS ============
     STRIKE = how fast the line dashes across (smaller = faster/snappier zap)
     KNOCK  = how far the word gets shoved by the hit (px). 0 = word doesn't move at all
     SETTLE_EASE = how the word returns. "power2.out" = clean stop.
                   "back.out(2)" = tiny overshoot. "elastic.out(1,0.35)" = bouncy (artificial)
  */
  const FADE_IN  = 0.5, STRIKE = 0.26, HOLD = 0.8, FADE_OUT = 0.4, GAP = 0.06;
  const KNOCK    = 5;
  const SETTLE_EASE = "power2.out";
  /* ============================================ */

  const root = document.querySelector(".strike-headline");
  if (root) {
    const S = (n) => root.querySelector('[data-slot="' + n + '"]');
    const verb=S("verb"), noun=S("noun"), role=S("role");
    const setText=(s,v)=>{ s.querySelector(".txt").textContent=v; };
    const setColor=(s,c)=>{ s.querySelector(".txt").style.color=c; };
    const line=(s)=>s.querySelector(".line");

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (reduce) {
      const f = states[states.length-1];
      setText(verb,f.verb); setText(noun,f.noun); setText(role,f.role);
      setColor(verb,f.color); setColor(role,f.color);
    } else {
      const tl = gsap.timeline({ delay:0.5 });
      states.forEach((s)=>{
        tl.add(()=>{
          setText(verb,s.verb); setText(noun,s.noun); setText(role,s.role);
          setColor(verb,s.color); setColor(role,s.color);
          gsap.set([line(verb),line(role)],{ scaleX:0 });
          gsap.set([verb,role],{ x:0 });
        });
        tl.fromTo([verb,role],
          { opacity:0, filter:"blur(4px)", y:6 },
          { opacity:1, filter:"blur(0px)", y:0, duration:FADE_IN, ease:"sine.out" });
        tl.fromTo(noun, { opacity:0 }, { opacity:0.55, duration:FADE_IN*1.1, ease:"sine.out" }, "<");

        if (!s.final) {
          // line dashes across...
          tl.to([line(verb),line(role)], { scaleX:1, duration:STRIKE, ease:"power4.out" }, "+="+GAP);
          // ...word gets a quick shove from the hit, then a clean settle (no rubbery bounce)
          tl.to([verb,role], { x:KNOCK, duration:STRIKE*0.5, ease:"power3.out" }, "<");
          tl.to([verb,role], { x:0, duration:0.35, ease:SETTLE_EASE });
          tl.to({}, { duration:HOLD });
          tl.to([verb,role], { opacity:0, filter:"blur(4px)", y:-6, duration:FADE_OUT, ease:"sine.inOut" }, "+="+GAP);
          tl.to(noun, { opacity:0, duration:FADE_OUT, ease:"sine.inOut" }, "<");
        }
      });
    }
  }
</script>