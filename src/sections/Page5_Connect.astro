---
/**
 * Page5_Connect.astro — closing page (LIGHT pass).
 *
 *   HEADING  : "Let's [connect]" — the "connect" is THE isometric 3D button
 *              (danielsun.space style): dark cap sitting on a light base
 *              plate, perspective tilt, hand-drawn sketch bursts at its
 *              sides, generous golden glow on hover, realistic press on
 *              click → opens mailto.
 *   EMAIL    : glassy slide-to-reveal pill — hover hints, click slides the
 *              cover away, email revealed + copied.
 *   AURORA   : hiartem-grade white → black join: a TALL, many-stop vertical
 *              dissolve with warm pools varying horizontally. No hard line.
 *   FOOTER   : unchanged (approved) — wiggle/race link, clipped glowing name.
 */
const EMAIL = "saurabhsharma090903@gmail.com";
const LETTERS = "SAURABH".split("");
---

<section class="connect section" id="connect">
  <div class="c5-inner">
    <!-- ================= WHITE upper portion ================= -->
    <div class="c5-top">
      <h2 class="c5-heading">
        <span class="lets">Let's</span>

        <!-- THE isometric connect button (in the headline itself) -->
        <button class="iso-btn" type="button" aria-label={`Email me: ${EMAIL}`}>
          <!-- golden halo (hover) -->
          <span class="iso-glow" aria-hidden="true"></span>

          <!-- sketchy WINGS, fanning out on hover -->
          <svg class="sketch sketch-l" viewBox="0 0 90 90" aria-hidden="true">
            <path d="M 80 46 C 56 40 38 26 30 8" />
            <path d="M 78 55 C 52 51 33 41 20 24" />
            <path d="M 78 64 C 50 64 30 56 14 44" />
            <path d="M 80 73 C 54 78 34 74 20 66" />
          </svg>
          <svg class="sketch sketch-r" viewBox="0 0 90 90" aria-hidden="true">
            <path d="M 10 46 C 34 40 52 26 60 8" />
            <path d="M 12 55 C 38 51 57 41 70 24" />
            <path d="M 12 64 C 40 64 60 56 76 44" />
            <path d="M 10 73 C 36 78 56 74 70 66" />
          </svg>

          <span class="iso-cap">Connect</span>
        </button>
      </h2>

      <p class="c5-note" aria-hidden="true">go on — press it :)</p>

      <!-- glassy slide-to-reveal email pill -->
      <div class="email-slider" data-email={EMAIL} role="button" tabindex="0"
        aria-label="Reveal email address">
        <span class="es-email">{EMAIL}</span>
        <div class="es-cover">
          <span class="es-label">get my email</span>
          <span class="es-hint">click to reveal ›</span>
        </div>
        <span class="es-copied" aria-hidden="true">copied!</span>
      </div>

      <p class="c5-sub">Got an idea worth building? Let's turn it into reality.</p>
    </div>

    <!-- ================= aurora: white → black, NO blunt line ================= -->
    <div class="c5-aurora" aria-hidden="true">
      <!-- blending veil: melts the (unchanged) gradient into the white
           above and the black below — sits over the drifting blobs too -->
      <span class="aurora-blend"></span>
    </div>

    <!-- ================= BLACK footer (approved — unchanged) ================= -->
    <footer class="c5-footer">
      <div class="foot-top">
        <div class="foot-left">
          <p class="foot-copy">© 2026 Saurabh. All rights reserved.</p>
          <p class="foot-muted">Fueled by Green Tea and creativity.</p>

          <div class="foot-socials">
            <a class="soc soc-li" href="https://www.linkedin.com/in/saurabh-sharma-375393336" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/></svg>
            </a>
            <a class="soc soc-gh" href="https://github.com/Saurabh-993" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-1.95c-3.2.7-3.88-1.37-3.88-1.37-.53-1.34-1.29-1.7-1.29-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.78 1.2 1.78 1.2 1.04 1.79 2.73 1.27 3.4.97.1-.76.41-1.27.74-1.56-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.24 2.76.12 3.05.74.81 1.18 1.83 1.18 3.09 0 4.42-2.69 5.39-5.25 5.68.42.36.79 1.06.79 2.14v3.17c0 .31.2.67.8.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z"/></svg>
            </a>
            <a class="soc soc-x" href="#" aria-label="X (Twitter) — coming soon" onclick="event.preventDefault()">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18.24 2.25h3.31l-7.23 8.26 8.5 11.24h-6.66l-5.22-6.82-5.97 6.82H1.66l7.73-8.84L1.24 2.25h6.83l4.72 6.23 5.45-6.23zm-1.16 17.52h1.83L7.01 4.13H5.05l12.03 15.64z"/></svg>
            </a>
          </div>
        </div>

        <a class="foot-right" href="#hero" data-totop>
          <span class="small">
            wanna check what I <span class="wiggle w1">d</span>o<span class="wiggle w2">?</span>
          </span>
          <span class="big">
            HERE<span class="chev c1">›</span><span class="chev c2">›</span><span class="chev c3">›</span>
          </span>
        </a>
      </div>

      <div class="foot-name" data-glow-zone>
        <span class="name-row" data-stretch>
          {LETTERS.map((ch) => <span class="ltr">{ch}</span>)}
        </span>
      </div>
    </footer>
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Caveat:wght@600&display=swap');

  .connect {
    --c5-white: #ffffff;
    --c5-black: #0b0b0d;
    --c5-gold: #ffd94d;       /* accent color              */
    --c5-glow: 255, 217, 77;  /* accent as rgb triplet     */
    --btn-glow: 255, 217, 77; /* Connect halo: GOLD by day */
    --c5-ink: #131313;       /* main text               */
    --c5-ink-soft: #77756e;  /* secondary text          */
    background: var(--c5-white);
    color: var(--c5-ink);
    overflow: hidden;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  /* ============ DARK MODE: teal → deep navy (the reference image) ============
     The whole upper portion becomes the mint/teal-to-navy wash, darkening
     downward so it hands off seamlessly to the (untouched) black footer.
     Every accent flips gold → luminous cyan via the vars above. */
  :global(html[data-theme='dark']) .connect {
    --c5-gold: #4fe3c1;
    --c5-glow: 79, 227, 193;
    --btn-glow: 226, 234, 240; /* Connect halo: SILVER by night */
    --c5-ink: #f2fbf8;
    --c5-ink-soft: rgba(230, 250, 244, 0.62);
    /* The gradient must be FULLY BLACK by the time the footer starts
       (~62% of section height) — previously it was still navy there, which
       is exactly what drew the visible lines. The band above the footer now
       shows this same continuous descent, nothing else. */
    background: linear-gradient(180deg,
      #86e5c4 0%,
      #5ec7ab 10%,
      #37ab98 20%,
      #1d8a8c 29%,
      #12687c 37%,
      #0e4a68 44%,
      #0a3553 50%,
      #082441 55%,
      #06172c 59%,
      #04101e 62%,
      var(--c5-black) 67%,
      var(--c5-black) 100%);
  }
  /* desktop: hard-lock the whole page to exactly one viewport */
  @media (min-width: 900px) and (min-height: 620px) {
    .connect { height: 100dvh; }
  }
  /* creative touch: hovering the email pill re-lights the sunset behind —
     the whole gradient warms and shifts hue, then settles back */
  .connect:has(.email-slider:hover) .c5-aurora {
    filter: hue-rotate(-42deg) saturate(1.25) brightness(1.06);
  }
  /* dark: the band is deep, so the hover reaction must LIFT it — the
     drifting pools brighten into a violet-indigo aurora */
  :global(html[data-theme='dark']) .connect:has(.email-slider:hover) .c5-aurora {
    filter: hue-rotate(95deg) saturate(1.6) brightness(1.7);
  }
  .c5-inner { 
    flex: 1;
    display: flex;
    flex-direction: column;
    will-change: transform; 
  }

  /* ---------------- upper portion ---------------- */
  .c5-top {
    flex: 1; /* Automatically stretches to balance the height perfectly! */
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; padding: 2.5vh 5vw 1.5vh; gap: 8px;
    min-height: 0; /* let flex compress it into the viewport */
  }
  .c5-heading {
    display: flex; align-items: center; justify-content: center; flex-wrap: wrap;
    gap: clamp(16px, 2.4vw, 34px);
    font-family: "Clash Display", "Space Grotesk", sans-serif;
    font-weight: 700; font-size: clamp(2.1rem, 4.4vw, 3.8rem); /* compact enough to fit */
    letter-spacing: -0.02em; color: var(--c5-ink); margin: 0 0 4px;
  }
  /* "Let's" a touch bigger so it holds its own against the 3D Connect */
  .c5-heading .lets { font-size: 1.18em; line-height: 1; }

  /* ============ THE isometric connect button (danielsun style) ============ */
  .iso-btn {
    position: relative; border: none; background: none; cursor: pointer;
    padding: 0 32px; /* room for the sketch bursts */
    font: inherit;
    margin-top: 8px; /* visual balance with text */
    /* idle: a slow, fluid wiggle — the button floats like it's alive
       (killed automatically by the reduced-motion rule in global.css) */
    animation: iso-float 7s ease-in-out infinite;
  }
  @keyframes iso-float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    28%      { transform: translateY(-4px) rotate(0.7deg); }
    55%      { transform: translateY(1px) rotate(-0.5deg); }
    80%      { transform: translateY(-2px) rotate(0.4deg); }
  }
  /* dark cap riding on a light base plate; perspective tilt = isometric */
  .iso-cap {
    display: inline-block;
    padding: 0.35em 1.2em 0.4em;
    border-radius: 999px;
    font-family: inherit; font-weight: 700; font-size: 1.05em;
    letter-spacing: -0.01em;
    color: #e6e6e6; /* Light grey text normally */
    /* Dark grey face like Image 5 */
    background: linear-gradient(180deg, #333333 0%, #1a1a1a 100%);
    transform: perspective(800px) rotateX(22deg) rotateZ(-2.5deg);
    /* Thick silver rim like Image 5 */
    box-shadow:
      0 12px 0 -1px #b3b3b3,                     /* silver base plate  */
      0 12px 2px -1px rgba(0, 0, 0, 0.2),      /* plate's contact edge  */
      0 20px 30px rgba(0, 0, 0, 0.15),          /* ground shadow         */
      inset 0 2px 3px rgba(255, 255, 255, 0.15),
      inset 0 -4px 8px rgba(0, 0, 0, 0.6);
    transition: transform 0.15s cubic-bezier(0.3, 0.8, 0.3, 1), box-shadow 0.3s ease, color 0.3s ease, background 0.3s ease;
  }

  /* AURORA RIM (the clip's contour glow, in theme colors): a pill-shaped
     gradient hugging the cap's edge. As a ::before of the cap it inherits
     the isometric transform automatically — the glow tilts WITH the button. */
  /* (the inner rim glow that sat over the button is removed — the button
     now gets ONE bigger halo behind it, via .iso-glow below) */
  .iso-cap { position: relative; } /* anchors the rim pseudo */

  /* hover: cap warms, text + rim take the theme accent.
     The TEXT itself blooms (soft layered glow, like a lit sign) —
     golden by day, silver-white by night via --btn-glow. */
  .iso-btn:hover .iso-cap {
    color: var(--c5-gold);
    text-shadow:
      0 0 10px rgba(var(--btn-glow), 0.65),
      0 0 26px rgba(var(--btn-glow), 0.4),
      0 0 54px rgba(var(--btn-glow), 0.22);
    background: linear-gradient(180deg, #2b2718 0%, #171505 100%);
    box-shadow:
      0 12px 0 -1px #e6d9a0, /* accent rim */
      0 12px 2px -1px rgba(120, 90, 0, 0.3),
      0 24px 44px rgba(var(--c5-glow), 0.4), /* accent ground glow */
      inset 0 2px 3px rgba(255, 240, 160, 0.3),
      inset 0 -4px 8px rgba(0, 0, 0, 0.5);
  }
  /* dark: SILVER treatment — bright steel text + rim, cool ground glow */
  :global(html[data-theme='dark']) .iso-btn:hover .iso-cap {
    color: #f0f4f7;
    background: linear-gradient(180deg, #2c2e32 0%, #131417 100%);
    box-shadow:
      0 12px 0 -1px #cfd6dc,
      0 12px 2px -1px rgba(40, 50, 60, 0.45),
      0 24px 44px rgba(var(--btn-glow), 0.35),
      inset 0 2px 3px rgba(240, 246, 250, 0.35),
      inset 0 -4px 8px rgba(0, 0, 0, 0.5);
  }
  
  /* click: sinks onto its plate */
  .iso-btn:active .iso-cap {
    transform: perspective(800px) rotateX(28deg) rotateZ(-2.5deg) translateY(8px);
    box-shadow:
      0 4px 0 -1px #dcd096,
      0 4px 2px -1px rgba(120, 90, 0, 0.3),
      0 12px 24px rgba(255, 217, 77, 0.3),
      inset 0 2px 5px rgba(0, 0, 0, 0.55);
  }

  /* wide AURORA bloom behind everything — gold heart, orange mid,
     violet-blue fringe (matches the sunset band below) */
  /* ONE clean, BIG halo behind the button:
     GOLDEN in light mode, SILVER in dark mode (via --btn-glow). */
  .iso-glow {
    position: absolute; inset: -62% -30%;
    border-radius: 50%;
    background: radial-gradient(50% 55% at 50% 52%,
      rgba(var(--btn-glow), 0.45) 0%, rgba(var(--btn-glow), 0.16) 48%, rgba(var(--btn-glow), 0) 72%);
    filter: blur(16px);
    opacity: 0; transform: scale(0.85);
    transition: opacity 0.35s ease, transform 0.35s ease;
    pointer-events: none; z-index: -1;
  }
  .iso-btn:hover .iso-glow {
    opacity: 1; transform: scale(1);
    animation: aurora-breathe 4s ease-in-out infinite alternate;
  }
  /* gentle breathing only — no hue cycling (that's what looked ugly) */
  @keyframes aurora-breathe {
    from { filter: blur(16px); transform: scale(1); }
    to   { filter: blur(20px); transform: scale(1.05); }
  }

  /* hand-drawn bursts, appearing with the glow */
  .sketch {
    position: absolute; top: 40%; width: clamp(38px, 4vw, 56px); height: auto;
    fill: none; stroke: #1d1d1b; stroke-width: 4.5; stroke-linecap: round;
    opacity: 0; transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
  }
  .sketch-l { left: -6px; transform: translate(-100%, -50%) rotate(-10deg) scale(0.8); }
  .sketch-r { right: -6px; transform: translate(100%, -50%) rotate(10deg) scale(0.8); }
  .iso-btn:hover .sketch-l {
    opacity: 1; transform: translate(-100%, -50%) rotate(-2deg) scale(1.1);
    animation: wing-l 1.6s ease-in-out 0.35s infinite alternate;
  }
  @keyframes wing-l {
    from { transform: translate(-100%, -50%) rotate(-2deg) scale(1.1); }
    to   { transform: translate(-100%, -50%) rotate(-7deg) scale(1.15); }
  }
  .iso-btn:hover .sketch-r {
    opacity: 1; transform: translate(100%, -50%) rotate(2deg) scale(1.1);
    animation: wing-r 1.6s ease-in-out 0.35s infinite alternate;
  }
  @keyframes wing-r {
    from { transform: translate(100%, -50%) rotate(2deg) scale(1.1); }
    to   { transform: translate(100%, -50%) rotate(7deg) scale(1.15); }
  }

  .c5-note {
    font-family: "Caveat", cursive; font-size: 1.4rem; font-weight: 600;
    color: #9a9a96; margin: 2px 0 14px; transform: rotate(-3deg);
  }
  :global(html[data-theme='dark']) .c5-note { color: rgba(235, 252, 246, 0.66); }
  /* wings: ink strokes read on white; in dark they go pale mint */
  :global(html[data-theme='dark']) .sketch { stroke: rgba(226, 250, 242, 0.85); }

  /* ============ glassy slide-to-reveal email ============ */
  .email-slider {
    position: relative; overflow: hidden; cursor: pointer;
    padding: 15px 34px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.55);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow:
      0 10px 26px rgba(0, 0, 0, 0.07),
      inset 0 1px 1px rgba(255, 255, 255, 0.9);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }
  .email-slider:hover { transform: translateY(-1px); box-shadow: 0 14px 32px rgba(0, 0, 0, 0.1), inset 0 1px 1px rgba(255, 255, 255, 0.9); }

  .es-email {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: clamp(0.85rem, 1.5vw, 1.05rem); font-weight: 500;
    color: #2b2b28; letter-spacing: 0.01em;
    filter: blur(5px);                 
    transition: filter 0.45s ease 0.1s;
    user-select: all;
  }
  .email-slider.open .es-email { filter: blur(0); }

  .es-cover {
    position: absolute; inset: 0;
    display: grid; place-items: center;
    background: linear-gradient(180deg, rgba(252, 250, 244, 0.96), rgba(240, 236, 226, 0.96));
    border-radius: 999px;
    transition: transform 0.5s cubic-bezier(0.65, 0, 0.35, 1);
  }
  .email-slider.open .es-cover { transform: translateX(104%); }
  .es-label, .es-hint {
    grid-area: 1 / 1;
    font-family: "Space Grotesk", sans-serif; font-weight: 600;
    font-size: 0.95rem; color: #55534d;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .es-hint { opacity: 0; transform: translateX(-6px); color: #8a7223; }
  .email-slider:not(.open):hover .es-label { opacity: 0; transform: translateX(6px); }
  .email-slider:not(.open):hover .es-hint { opacity: 1; transform: translateX(0); }

  .es-copied {
    position: absolute; right: 14px; top: 50%; transform: translateY(-50%);
    font-family: "Caveat", cursive; font-size: 1rem; color: #b98f13;
    opacity: 0; transition: opacity 0.3s ease; pointer-events: none;
  }
  .email-slider.copied .es-copied { opacity: 1; }

  .c5-sub { color: var(--c5-ink-soft); font-size: clamp(13px, 1.3vw, 16px); margin: 10px 0 0; max-width: 40ch; }

  /* ---- dark mode: the glassy slider goes deep-teal glass ---- */
  :global(html[data-theme='dark']) .email-slider {
    background: rgba(8, 34, 44, 0.45);
    border-color: rgba(255, 255, 255, 0.14);
    box-shadow: 0 10px 26px rgba(0, 0, 0, 0.35), inset 0 1px 1px rgba(255, 255, 255, 0.12);
  }
  :global(html[data-theme='dark']) .es-email { color: #d9f8ee; }
  :global(html[data-theme='dark']) .es-cover {
    background: linear-gradient(180deg, rgba(11, 44, 54, 0.96), rgba(6, 27, 36, 0.96));
  }
  :global(html[data-theme='dark']) .es-label { color: rgba(226, 248, 240, 0.75); }
  :global(html[data-theme='dark']) .es-hint { color: #5fe8c8; }
  :global(html[data-theme='dark']) .es-copied { color: #5fe8c8; }

  /* ============ aurora join: Organic Sunset Mesh Gradient ============ */
  .c5-aurora {
    height: clamp(120px, 20vh, 220px); /* slimmer → whole page fits one viewport */
    width: 100%;
    position: relative;
    transition: filter 0.9s ease; /* lets the sunset react to the email pill */
    flex-shrink: 0;
    /* Smooth base fade matching a sunset */
    background: linear-gradient(to bottom, 
      #ffffff 0%, 
      #fff4ce 20%, 
      #ff984d 50%, 
      #2b3a6b 80%, 
      var(--c5-black) 100%
    );
    overflow: hidden;
    flex-shrink: 0; 
  }
  
  /* Add organic blobs for the hiartem style mesh look */
  .c5-aurora::before,
  .c5-aurora::after {
    content: "";
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
  }

  /* Golden/Orange bloom */
  .c5-aurora::before {
    width: 70%; height: 140%;
    background: radial-gradient(circle, rgba(255, 179, 71, 0.7) 0%, transparent 60%);
    top: 5%; left: -15%;
    animation: sunset-drift-1 12s ease-in-out infinite alternate;
  }

  /* Deep purple/blue twilight bloom */
  .c5-aurora::after {
    width: 70%; height: 140%;
    background: radial-gradient(circle, rgba(43, 39, 105, 0.9) 0%, transparent 60%);
    top: 20%; right: -15%;
    animation: sunset-drift-2 15s ease-in-out infinite alternate;
  }

  @keyframes sunset-drift-1 {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(12%, -8%) scale(1.1); }
  }
  @keyframes sunset-drift-2 {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(-12%, 12%) scale(1.05); }
  }

  /* ---- DARK MODE band: the page is already the teal→navy wash, so the
     band just deepens it into the footer black, with faint cyan + blue
     pools drifting (same animated blobs, recolored). ---- */
  /* DARK band: NO background of its own — the section's continuous descent
     shows through, so there is literally no seam to see. Only the two
     drifting color pools remain, and a vertical mask feathers them so
     their blurred edges can never draw a line either. */
  :global(html[data-theme='dark']) .c5-aurora {
    background: none;
    -webkit-mask-image: linear-gradient(to bottom,
      transparent 0%, black 30%, black 65%, transparent 96%);
    mask-image: linear-gradient(to bottom,
      transparent 0%, black 30%, black 65%, transparent 96%);
  }
  :global(html[data-theme='dark']) .c5-aurora::before {
    background: radial-gradient(circle, rgba(46, 211, 175, 0.26) 0%, transparent 60%);
  }
  :global(html[data-theme='dark']) .c5-aurora::after {
    background: radial-gradient(circle, rgba(64, 105, 224, 0.35) 0%, transparent 60%);
  }
  /* the light-mode veil would paint white at the top — disable it in dark */
  :global(html[data-theme='dark']) .aurora-blend { background: none; }

  /* ---- blending veil (colors untouched — edges only) ----
     Sits ABOVE the base gradient and the animated blooms, so even when the
     blobs drift near an edge, the band still dissolves cleanly:
     white feathers in from the top, black rises from the bottom. */
  .aurora-blend {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(
      to bottom,
      var(--c5-white) 0%,
      rgba(255, 255, 255, 0.55) 9%,
      rgba(255, 255, 255, 0) 28%,
      rgba(11, 11, 13, 0) 60%,
      rgba(11, 11, 13, 0.55) 82%,
      var(--c5-black) 100%
    );
  }

  /* ---------------- black footer (approved) ---------------- */
  .c5-footer { background: var(--c5-black); color: #f4f4f2; }
  .foot-top {
    display: flex; justify-content: space-between; align-items: flex-start;
    gap: 2rem; padding: 4vh 5vw 2vh; flex-wrap: wrap;
  }
  .foot-copy { margin: 0 0 4px; font-size: 14.5px; font-weight: 600; }
  .foot-muted { margin: 0; font-size: 13px; color: rgba(244, 244, 242, 0.42); }

  /* social links — minimalistic icon buttons; brand colour on hover */
  .foot-socials { display: flex; gap: 10px; margin-top: 16px; }
  .soc {
    display: grid; place-items: center; width: 34px; height: 34px; border-radius: 10px;
    color: rgba(244, 244, 242, 0.5);
    background: rgba(244, 244, 242, 0.04);
    border: 1px solid rgba(244, 244, 242, 0.12);
    transition: color 0.25s ease, background-color 0.25s ease, border-color 0.25s ease, transform 0.2s ease;
  }
  .soc svg { width: 17px; height: 17px; fill: currentColor; display: block; }
  .soc:hover { transform: translateY(-2px); }
  .soc-li:hover { color: #0a66c2; background: rgba(10, 102, 194, 0.14); border-color: rgba(10, 102, 194, 0.6); }
  .soc-gh:hover { color: #ffffff; background: rgba(255, 255, 255, 0.10); border-color: rgba(255, 255, 255, 0.5); }
  .soc-x:hover  { color: #ffffff; background: rgba(255, 255, 255, 0.10); border-color: rgba(255, 255, 255, 0.5); }

  .foot-right {
    text-align: right; text-decoration: none;
    display: inline-flex; flex-direction: column; align-items: flex-end; gap: 2px;
    color: #f4f4f2;
  }
  .foot-right .small {
    font-family: "Space Grotesk", sans-serif; font-size: 14px; font-weight: 600;
    color: rgba(244, 244, 242, 0.65);
  }
  .wiggle { display: inline-block; animation: c5-wiggle 3.4s ease-in-out infinite; transform-origin: 60% 80%; }
  .w2 { animation-delay: 0.35s; }
  @keyframes c5-wiggle {
    0%, 78%, 100% { transform: rotate(0deg); }
    84%  { transform: rotate(10deg) translateY(-1px); }
    90%  { transform: rotate(-8deg); }
    95%  { transform: rotate(4deg); }
  }

  .foot-right .big {
    font-family: "Clash Display", "Space Grotesk", sans-serif; font-weight: 700;
    font-size: clamp(1.7rem, 3.4vw, 2.6rem); line-height: 1;
    display: inline-flex; align-items: center;
    transition: color 0.3s ease, text-shadow 0.3s ease;
  }
  .foot-right:hover .big {
    color: var(--c5-gold);
    text-shadow: 0 0 18px rgba(var(--c5-glow), 0.35);
  }
  /* dark: HERE warms to periwinkle-violet instead of more cyan */
  :global(html[data-theme='dark']) .foot-right:hover .big {
    color: #a7b6ff;
    text-shadow: 0 0 18px rgba(143, 157, 255, 0.42);
  }
  .chev { display: inline-block; margin-left: 0.04em; animation: c5-race 1.5s ease-in-out infinite; }
  .c2 { animation-delay: 0.12s; }
  .c3 { animation-delay: 0.24s; }
  /* dark: the racing chevrons carry the aurora hues even at rest */
  :global(html[data-theme='dark']) .chev.c1 { color: #4fe3c1; }
  :global(html[data-theme='dark']) .chev.c2 { color: #58b6ff; }
  :global(html[data-theme='dark']) .chev.c3 { color: #b48cff; }
  @keyframes c5-race {
    0%, 55%, 100% { transform: translateX(0); opacity: 1; }
    25% { transform: translateX(0.28em); opacity: 0.35; }
    40% { transform: translateX(0.12em); opacity: 1; }
  }

  .foot-name {
    overflow: hidden;
    height: clamp(4.6rem, 17.5vw, 20rem);
    margin-top: 1vh;
  }
  .name-row {
    display: block; text-align: center; white-space: nowrap;
    font-family: "Clash Display", "Space Grotesk", sans-serif; font-weight: 800;
    font-size: clamp(7rem, 26vw, 30rem);
    letter-spacing: -0.02em; line-height: 0.74;
    transform: scaleX(0.85); transform-origin: center bottom; will-change: transform;
  }
  .ltr {
    --g: 0;
    --lc: var(--c5-gold); /* per-letter glow color (overridden in dark) */
    display: inline-block;
    color: color-mix(in srgb, #ffffff calc((1 - var(--g)) * 100%), var(--lc) calc(var(--g) * 100%));
    text-shadow: 0 0 calc(var(--g) * 42px)
      color-mix(in srgb, var(--lc) calc(var(--g) * 55%), transparent);
    transition: color 0.18s linear, text-shadow 0.18s linear;
  }
  /* DARK: the name becomes a mini-aurora — each letter glows its own hue,
     mint → cyan → sky → periwinkle → violet → pink → coral across SAURABH */
  :global(html[data-theme='dark']) .ltr:nth-child(1) { --lc: #4fe3c1; }
  :global(html[data-theme='dark']) .ltr:nth-child(2) { --lc: #3ccfe0; }
  :global(html[data-theme='dark']) .ltr:nth-child(3) { --lc: #58b6ff; }
  :global(html[data-theme='dark']) .ltr:nth-child(4) { --lc: #8f9dff; }
  :global(html[data-theme='dark']) .ltr:nth-child(5) { --lc: #b48cff; }
  :global(html[data-theme='dark']) .ltr:nth-child(6) { --lc: #ef9de0; }
  :global(html[data-theme='dark']) .ltr:nth-child(7) { --lc: #ff9d80; }
  @media (hover: hover) {
    .foot-name:hover .ltr:hover { --g: 1; }
  }

  @media (max-width: 700px) {
    .foot-top { flex-direction: column; }
    .foot-right { text-align: left; align-items: flex-start; }
    .sketch { display: none; }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const section = document.querySelector<HTMLElement>("#connect");
  const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
  const EMAIL = section?.querySelector<HTMLElement>(".email-slider")?.dataset.email || "";

  /* ---------- isometric connect (headline) → mailto ---------- */
  section?.querySelector(".iso-btn")?.addEventListener("click", () => {
    // small delay so the press animation reads before the mail app steals focus
    setTimeout(() => { window.location.href = `mailto:${EMAIL}`; }, 180);
  });

  /* ---------- glassy slider → reveal + copy ---------- */
  const slider = section?.querySelector<HTMLElement>(".email-slider");
  if (slider) {
    const reveal = () => {
      if (slider.classList.contains("open")) return;
      slider.classList.add("open");
      navigator.clipboard?.writeText(EMAIL).then(() => {
        slider.classList.add("copied");
        setTimeout(() => slider.classList.remove("copied"), 2000);
      }).catch(() => {});
    };
    slider.addEventListener("click", reveal);
    slider.addEventListener("keydown", (e) => {
      if ((e as KeyboardEvent).key === "Enter" || (e as KeyboardEvent).key === " ") {
        e.preventDefault(); reveal();
      }
    });
  }

  /* ---------- HERE ›› → back to top ---------- */
  section?.querySelector("[data-totop]")?.addEventListener("click", (e) => {
    e.preventDefault();
    // @ts-ignore — Lenis set by Base.astro when motion is allowed
    const lenis = window.lenis;
    if (lenis) lenis.scrollTo(0);
    else window.scrollTo({ top: 0, behavior: reduce ? "auto" : "smooth" });
  });

  /* ---------- cursor-proximity GOLD glow on the giant letters ---------- */
  const zone = section?.querySelector<HTMLElement>("[data-glow-zone]");
  const letters = zone ? Array.from(zone.querySelectorAll<HTMLElement>(".ltr")) : [];
  if (zone && letters.length && !reduce && matchMedia("(hover: hover)").matches) {
    let raf = 0, mx = 0, my = 0;
    const paint = () => {
      raf = 0;
      for (const el of letters) {
        const r = el.getBoundingClientRect();
        const d = Math.hypot(mx - (r.left + r.width / 2), my - (r.top + r.height / 2));
        const g = Math.max(0, 1 - d / (r.width * 1.6));
        el.style.setProperty("--g", (g * g).toFixed(3));
      }
    };
    zone.addEventListener("pointermove", (e) => {
      mx = e.clientX; my = e.clientY;
      if (!raf) raf = requestAnimationFrame(paint);
    });
    zone.addEventListener("pointerleave", () => {
      letters.forEach((el) => el.style.setProperty("--g", "0"));
    });
  }

  /* ---------- reveal transition + name stretch ---------- */
  const mm = gsap.matchMedia();
  mm.add("(min-width: 1024px) and (prefers-reduced-motion: no-preference)", () => {
    const anims: gsap.core.Tween[] = [];
    anims.push(
      gsap.fromTo(".connect .c5-inner",
        { yPercent: -14 },
        { yPercent: 0, ease: "none",
          scrollTrigger: { trigger: "#connect", start: "top bottom", end: "top 15%", scrub: 0.5 } }
      )
    );
    anims.push(
      gsap.fromTo(".connect [data-stretch]",
        { scaleX: 0.85 },
        { scaleX: 1.12, ease: "none",
          scrollTrigger: { trigger: "#connect", start: "top 70%", end: "bottom bottom", scrub: 0.6 } }
      )
    );
    return () => anims.forEach((a) => a.scrollTrigger?.kill());
  });

  if (reduce) {
    const row = section?.querySelector<HTMLElement>("[data-stretch]");
    if (row) row.style.transform = "scaleX(1)";
  }
</script>
