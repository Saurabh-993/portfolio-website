---
/**
 * Page5_Connect.astro — closing page (LIGHT pass).
 *
 *   HEADING  : "Let's [connect]" — the "connect" is THE isometric 3D button
 *              (danielsun.space style): dark cap sitting on a light base
 *              plate, perspective tilt, hand-drawn sketch bursts at its
 *              sides, generous golden glow on hover, realistic press on
 *              click → opens mailto.
 *   EMAIL    : glassy slide-to-reveal pill — hover hints, click slides the
 *              cover away, email revealed + copied.
 *   AURORA   : hiartem-grade white → black join: a TALL, many-stop vertical
 *              dissolve with warm pools varying horizontally. No hard line.
 *   FOOTER   : unchanged (approved) — wiggle/race link, clipped glowing name.
 */
const EMAIL = "saurabhsharma090903@gmail.com";
const LETTERS = "SAURABH".split("");
---

<section class="connect section" id="connect">
  <div class="c5-inner">
    <!-- ================= WHITE upper portion ================= -->
    <div class="c5-top">
      <h2 class="c5-heading">
        <span class="lets">Let's</span>

        <!-- THE isometric connect button (in the headline itself) -->
        <button class="iso-btn" type="button" aria-label={`Email me: ${EMAIL}`}>
          <!-- golden halo (hover) -->
          <span class="iso-glow" aria-hidden="true"></span>

          <!-- hand-drawn bursts, sidewise (hover) -->
          <svg class="sketch sketch-l" viewBox="0 0 70 90" aria-hidden="true">
            <path d="M 52 14 C 30 22 24 40 34 56" />
            <path d="M 26 8 C 16 24 12 44 20 62" />
            <path d="M 58 70 C 46 74 38 72 30 66" />
          </svg>
          <svg class="sketch sketch-r" viewBox="0 0 70 90" aria-hidden="true">
            <path d="M 18 14 C 40 22 46 40 36 56" />
            <path d="M 44 8 C 54 24 58 44 50 62" />
            <path d="M 12 70 C 24 74 32 72 40 66" />
          </svg>

          <span class="iso-cap">connect</span>
        </button>
      </h2>

      <p class="c5-note" aria-hidden="true">go on — press it :)</p>

      <!-- glassy slide-to-reveal email pill -->
      <div class="email-slider" data-email={EMAIL} role="button" tabindex="0"
        aria-label="Reveal email address">
        <span class="es-email">{EMAIL}</span>
        <div class="es-cover">
          <span class="es-label">get my email</span>
          <span class="es-hint">click to reveal ›</span>
        </div>
        <span class="es-copied" aria-hidden="true">copied!</span>
      </div>

      <p class="c5-sub">Got an idea worth building? Let's turn it into reality.</p>
    </div>

    <!-- ================= aurora: white → black, NO blunt line ================= -->
    <div class="c5-aurora" aria-hidden="true"></div>

    <!-- ================= BLACK footer (approved — unchanged) ================= -->
    <footer class="c5-footer">
      <div class="foot-top">
        <div class="foot-left">
          <p class="foot-copy">© 2026 Saurabh. All rights reserved.</p>
          <p class="foot-muted">made with love — or any line like this.</p>
        </div>

        <a class="foot-right" href="#hero" data-totop>
          <span class="small">
            wanna check what I <span class="wiggle w1">d</span>o<span class="wiggle w2">?</span>
          </span>
          <span class="big">
            HERE<span class="chev c1">›</span><span class="chev c2">›</span><span class="chev c3">›</span>
          </span>
        </a>
      </div>

      <div class="foot-name" data-glow-zone>
        <span class="name-row" data-stretch>
          {LETTERS.map((ch) => <span class="ltr">{ch}</span>)}
        </span>
      </div>
    </footer>
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Caveat:wght@600&display=swap');

  .connect {
    --c5-white: #fefefe;
    --c5-black: #0b0b0d;
    --c5-gold: #ffd94d;
    background: var(--c5-white);
    color: #131313;
    overflow: hidden;
  }
  .c5-inner { will-change: transform; }

  /* ---------------- upper portion ---------------- */
  .c5-top {
    min-height: 58vh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; padding: 12vh 5vw 2vh; gap: 12px;
  }
  .c5-heading {
    display: flex; align-items: center; justify-content: center; flex-wrap: wrap;
    gap: clamp(16px, 2.4vw, 34px);
    font-family: "Clash Display", "Space Grotesk", sans-serif;
    font-weight: 700; font-size: clamp(2.6rem, 6vw, 5rem);
    letter-spacing: -0.02em; color: #131313; margin: 0 0 6px;
  }

  /* ============ THE isometric connect button (danielsun style) ============ */
  .iso-btn {
    position: relative; border: none; background: none; cursor: pointer;
    padding: 0 26px; /* room for the sketch bursts */
    font: inherit;
  }
  /* dark cap riding on a light base plate; perspective tilt = isometric */
  .iso-cap {
    display: inline-block;
    padding: 0.28em 0.9em 0.34em;
    border-radius: 999px;
    font-family: inherit; font-weight: 700; font-size: 0.94em;
    letter-spacing: -0.01em;
    color: #f3f3f1;
    background:
      radial-gradient(130% 170% at 50% -20%, #3a3a3e 0%, #232326 48%, #161618 100%);
    transform: perspective(820px) rotateX(24deg) rotateZ(-3.5deg);
    box-shadow:
      0 13px 0 -2px #dcdcda,                     /* the light base plate  */
      0 15px 2px -2px rgba(0, 0, 0, 0.18),      /* plate's contact edge  */
      0 26px 34px rgba(0, 0, 0, 0.22),          /* ground shadow         */
      inset 0 2px 3px rgba(255, 255, 255, 0.22),
      inset 0 -6px 10px rgba(0, 0, 0, 0.5);
    transition: transform 0.14s ease, box-shadow 0.3s ease, color 0.3s ease,
      background 0.3s ease;
  }
  /* hover: cap warms, text goes gold, halo blooms (we have the space) */
  .iso-btn:hover .iso-cap {
    color: var(--c5-gold);
    background:
      radial-gradient(130% 170% at 50% -20%, #45400f 0%, #2b2708 48%, #171505 100%);
    box-shadow:
      0 13px 0 -2px #e6d9a0,
      0 15px 2px -2px rgba(120, 90, 0, 0.25),
      0 26px 44px rgba(214, 168, 40, 0.35),
      inset 0 2px 3px rgba(255, 240, 160, 0.3),
      inset 0 -6px 10px rgba(0, 0, 0, 0.45);
  }
  /* click: sinks onto its plate — a real key press */
  .iso-btn:active .iso-cap {
    transform: perspective(820px) rotateX(30deg) rotateZ(-3.5deg) translateY(10px);
    box-shadow:
      0 3px 0 -2px #dcd096,
      0 5px 2px -2px rgba(120, 90, 0, 0.3),
      0 14px 26px rgba(214, 168, 40, 0.3),
      inset 0 2px 5px rgba(0, 0, 0, 0.55);
  }

  /* golden halo behind the cap */
  .iso-glow {
    position: absolute; inset: -34% -18%;
    border-radius: 50%;
    background: radial-gradient(50% 50% at 50% 52%,
      rgba(255, 217, 77, 0.55) 0%, rgba(255, 217, 77, 0.18) 45%, rgba(255, 217, 77, 0) 72%);
    filter: blur(6px);
    opacity: 0; transform: scale(0.85);
    transition: opacity 0.35s ease, transform 0.35s ease;
    pointer-events: none; z-index: -1;
  }
  .iso-btn:hover .iso-glow { opacity: 1; transform: scale(1); }

  /* hand-drawn bursts, appearing with the glow */
  .sketch {
    position: absolute; top: 50%; width: clamp(34px, 3.6vw, 54px); height: auto;
    fill: none; stroke: #1d1d1b; stroke-width: 5; stroke-linecap: round;
    opacity: 0; transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
  }
  .sketch-l { left: -14px; transform: translate(-100%, -55%) rotate(-8deg) scale(0.8); }
  .sketch-r { right: -14px; transform: translate(100%, -55%) rotate(8deg) scale(0.8); }
  .iso-btn:hover .sketch-l { opacity: 1; transform: translate(-100%, -55%) rotate(-2deg) scale(1); }
  .iso-btn:hover .sketch-r { opacity: 1; transform: translate(100%, -55%) rotate(2deg) scale(1); }

  .c5-note {
    font-family: "Caveat", cursive; font-size: 1.3rem; font-weight: 600;
    color: #9a9a96; margin: 4px 0 26px; transform: rotate(-3deg);
  }

  /* ============ glassy slide-to-reveal email ============ */
  .email-slider {
    position: relative; overflow: hidden; cursor: pointer;
    padding: 15px 34px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.55);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow:
      0 10px 26px rgba(0, 0, 0, 0.07),
      inset 0 1px 1px rgba(255, 255, 255, 0.9);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }
  .email-slider:hover { transform: translateY(-1px); box-shadow: 0 14px 32px rgba(0, 0, 0, 0.1), inset 0 1px 1px rgba(255, 255, 255, 0.9); }

  .es-email {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: clamp(0.85rem, 1.5vw, 1.05rem); font-weight: 500;
    color: #2b2b28; letter-spacing: 0.01em;
    filter: blur(5px);                 /* teased, unreadable under the cover */
    transition: filter 0.45s ease 0.1s;
    user-select: all;
  }
  .email-slider.open .es-email { filter: blur(0); }

  /* the cover shutter */
  .es-cover {
    position: absolute; inset: 0;
    display: grid; place-items: center;
    background: linear-gradient(180deg, rgba(252, 250, 244, 0.96), rgba(240, 236, 226, 0.96));
    border-radius: 999px;
    transition: transform 0.5s cubic-bezier(0.65, 0, 0.35, 1);
  }
  .email-slider.open .es-cover { transform: translateX(104%); }
  .es-label, .es-hint {
    grid-area: 1 / 1;
    font-family: "Space Grotesk", sans-serif; font-weight: 600;
    font-size: 0.95rem; color: #55534d;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .es-hint { opacity: 0; transform: translateX(-6px); color: #8a7223; }
  .email-slider:not(.open):hover .es-label { opacity: 0; transform: translateX(6px); }
  .email-slider:not(.open):hover .es-hint { opacity: 1; transform: translateX(0); }

  .es-copied {
    position: absolute; right: 14px; top: 50%; transform: translateY(-50%);
    font-family: "Caveat", cursive; font-size: 1rem; color: #b98f13;
    opacity: 0; transition: opacity 0.3s ease; pointer-events: none;
  }
  .email-slider.copied .es-copied { opacity: 1; }

  .c5-sub { color: #77756e; font-size: clamp(14px, 1.4vw, 17px); margin: 18px 0 0; max-width: 40ch; }

  /* ============ aurora join: hiartem-grade, no blunt line ============
     TALL band; many-stop vertical dissolve (white → cream → olive-gold →
     deep bronze → black) with warm pools drifting across it horizontally.
     The last stops approach #0b0b0d GRADUALLY — no edge against the footer. */
  .c5-aurora {
    height: clamp(240px, 36vh, 420px);
    background:
      radial-gradient(58% 85% at 10% 58%,  rgba(206, 168, 74, 0.4) 0%, rgba(206, 168, 74, 0) 68%),
      radial-gradient(72% 95% at 48% 66%,  rgba(232, 205, 130, 0.35) 0%, rgba(232, 205, 130, 0) 70%),
      radial-gradient(60% 88% at 90% 56%,  rgba(160, 124, 44, 0.4) 0%, rgba(160, 124, 44, 0) 66%),
      linear-gradient(to bottom,
        #fefefe 0%,
        #fdfaf1 18%,
        #f4ecd6 34%,
        #ddcda2 48%,
        #b3a06b 60%,
        #7d6f45 71%,
        #4c4229 81%,
        #262214 90%,
        #131109 96%,
        var(--c5-black) 100%);
  }

  /* ---------------- black footer (approved) ---------------- */
  .c5-footer { background: var(--c5-black); color: #f4f4f2; }
  .foot-top {
    display: flex; justify-content: space-between; align-items: flex-start;
    gap: 2rem; padding: 4vh 5vw 2vh; flex-wrap: wrap;
  }
  .foot-copy { margin: 0 0 4px; font-size: 14.5px; font-weight: 600; }
  .foot-muted { margin: 0; font-size: 13px; color: rgba(244, 244, 242, 0.42); }

  .foot-right {
    text-align: right; text-decoration: none;
    display: inline-flex; flex-direction: column; align-items: flex-end; gap: 2px;
    color: #f4f4f2;
  }
  .foot-right .small {
    font-family: "Space Grotesk", sans-serif; font-size: 14px; font-weight: 600;
    color: rgba(244, 244, 242, 0.65);
  }
  .wiggle { display: inline-block; animation: c5-wiggle 3.4s ease-in-out infinite; transform-origin: 60% 80%; }
  .w2 { animation-delay: 0.35s; }
  @keyframes c5-wiggle {
    0%, 78%, 100% { transform: rotate(0deg); }
    84%  { transform: rotate(10deg) translateY(-1px); }
    90%  { transform: rotate(-8deg); }
    95%  { transform: rotate(4deg); }
  }

  .foot-right .big {
    font-family: "Clash Display", "Space Grotesk", sans-serif; font-weight: 700;
    font-size: clamp(1.7rem, 3.4vw, 2.6rem); line-height: 1;
    display: inline-flex; align-items: center;
    transition: color 0.3s ease, text-shadow 0.3s ease;
  }
  .foot-right:hover .big {
    color: var(--c5-gold);
    text-shadow: 0 0 18px rgba(255, 217, 77, 0.35);
  }
  .chev { display: inline-block; margin-left: 0.04em; animation: c5-race 1.5s ease-in-out infinite; }
  .c2 { animation-delay: 0.12s; }
  .c3 { animation-delay: 0.24s; }
  @keyframes c5-race {
    0%, 55%, 100% { transform: translateX(0); opacity: 1; }
    25% { transform: translateX(0.28em); opacity: 0.35; }
    40% { transform: translateX(0.12em); opacity: 1; }
  }

  .foot-name {
    overflow: hidden;
    height: clamp(4.6rem, 17.5vw, 20rem);
    margin-top: 1vh;
  }
  .name-row {
    display: block; text-align: center; white-space: nowrap;
    font-family: "Clash Display", "Space Grotesk", sans-serif; font-weight: 800;
    font-size: clamp(7rem, 26vw, 30rem);
    letter-spacing: -0.02em; line-height: 0.74;
    transform: scaleX(0.85); transform-origin: center bottom; will-change: transform;
  }
  .ltr {
    --g: 0;
    display: inline-block;
    color: color-mix(in srgb, #ffffff calc((1 - var(--g)) * 100%), var(--c5-gold) calc(var(--g) * 100%));
    text-shadow: 0 0 calc(var(--g) * 42px) rgba(255, 217, 77, calc(var(--g) * 0.55));
    transition: color 0.18s linear, text-shadow 0.18s linear;
  }
  @media (hover: hover) {
    .foot-name:hover .ltr:hover { --g: 1; }
  }

  @media (max-width: 700px) {
    .foot-top { flex-direction: column; }
    .foot-right { text-align: left; align-items: flex-start; }
    .sketch { display: none; }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const section = document.querySelector<HTMLElement>("#connect");
  const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
  const EMAIL = section?.querySelector<HTMLElement>(".email-slider")?.dataset.email || "";

  /* ---------- isometric connect (headline) → mailto ---------- */
  section?.querySelector(".iso-btn")?.addEventListener("click", () => {
    // small delay so the press animation reads before the mail app steals focus
    setTimeout(() => { window.location.href = `mailto:${EMAIL}`; }, 180);
  });

  /* ---------- glassy slider → reveal + copy ---------- */
  const slider = section?.querySelector<HTMLElement>(".email-slider");
  if (slider) {
    const reveal = () => {
      if (slider.classList.contains("open")) return;
      slider.classList.add("open");
      navigator.clipboard?.writeText(EMAIL).then(() => {
        slider.classList.add("copied");
        setTimeout(() => slider.classList.remove("copied"), 2000);
      }).catch(() => {});
    };
    slider.addEventListener("click", reveal);
    slider.addEventListener("keydown", (e) => {
      if ((e as KeyboardEvent).key === "Enter" || (e as KeyboardEvent).key === " ") {
        e.preventDefault(); reveal();
      }
    });
  }

  /* ---------- HERE ›› → back to top ---------- */
  section?.querySelector("[data-totop]")?.addEventListener("click", (e) => {
    e.preventDefault();
    // @ts-ignore — Lenis set by Base.astro when motion is allowed
    const lenis = window.lenis;
    if (lenis) lenis.scrollTo(0);
    else window.scrollTo({ top: 0, behavior: reduce ? "auto" : "smooth" });
  });

  /* ---------- cursor-proximity GOLD glow on the giant letters ---------- */
  const zone = section?.querySelector<HTMLElement>("[data-glow-zone]");
  const letters = zone ? Array.from(zone.querySelectorAll<HTMLElement>(".ltr")) : [];
  if (zone && letters.length && !reduce && matchMedia("(hover: hover)").matches) {
    let raf = 0, mx = 0, my = 0;
    const paint = () => {
      raf = 0;
      for (const el of letters) {
        const r = el.getBoundingClientRect();
        const d = Math.hypot(mx - (r.left + r.width / 2), my - (r.top + r.height / 2));
        const g = Math.max(0, 1 - d / (r.width * 1.6));
        el.style.setProperty("--g", (g * g).toFixed(3));
      }
    };
    zone.addEventListener("pointermove", (e) => {
      mx = e.clientX; my = e.clientY;
      if (!raf) raf = requestAnimationFrame(paint);
    });
    zone.addEventListener("pointerleave", () => {
      letters.forEach((el) => el.style.setProperty("--g", "0"));
    });
  }

  /* ---------- reveal transition + name stretch ---------- */
  const mm = gsap.matchMedia();
  mm.add("(min-width: 1024px) and (prefers-reduced-motion: no-preference)", () => {
    const anims: gsap.core.Tween[] = [];
    anims.push(
      gsap.fromTo(".connect .c5-inner",
        { yPercent: -14 },
        { yPercent: 0, ease: "none",
          scrollTrigger: { trigger: "#connect", start: "top bottom", end: "top 15%", scrub: 0.5 } }
      )
    );
    anims.push(
      gsap.fromTo(".connect [data-stretch]",
        { scaleX: 0.85 },
        { scaleX: 1.12, ease: "none",
          scrollTrigger: { trigger: "#connect", start: "top 70%", end: "bottom bottom", scrub: 0.6 } }
      )
    );
    return () => anims.forEach((a) => a.scrollTrigger?.kill());
  });

  if (reduce) {
    const row = section?.querySelector<HTMLElement>("[data-stretch]");
    if (row) row.style.transform = "scaleX(1)";
  }
</script>
