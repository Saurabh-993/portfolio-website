<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const faces = Array.from(document.querySelectorAll<HTMLImageElement>(".pill-face img"));
  if (faces.length > 1) {
    let fi = 0;
    setInterval(() => {
      faces[fi].classList.remove("on");
      fi = (fi + 1) % faces.length;
      faces[fi].classList.add("on");
    }, 900);
  }

  const mm = gsap.matchMedia();
  mm.add("(min-width: 901px) and (prefers-reduced-motion: no-preference)", () => {
    const introEls = gsap.utils.toArray<HTMLElement>("[data-intro]");
    const introWrap = document.querySelector<HTMLElement>(".p4-intro");
    if (!introWrap || !introEls.length) return;
    const introTween = gsap.to(introEls, {
      yPercent: -12, opacity: 0, filter: "blur(9px)", ease: "none",
      scrollTrigger: { trigger: introWrap, start: "top top", end: "bottom 62%", scrub: 0.5 },
    });
    return () => { introTween.scrollTrigger?.kill(); introTween.kill(); gsap.set(introEls, { clearProps: "all" }); };
  });

  document.querySelector("[data-more]")?.addEventListener("click", () => {
    const extras = document.querySelectorAll<HTMLElement>(".p4-row[data-extra]");
    if (extras.length) {
      extras.forEach((r, k) => setTimeout(() => r.classList.add("show"), k * 90));
      const total = document.querySelectorAll(".p4-row").length;
      const pad = (n: number) => String(n).padStart(2, "0");
      const count = document.querySelector<HTMLElement>("[data-count]");
      if (count) count.textContent = `[ ${pad(total)} / ${pad(total)} ]`;
      const more = document.querySelector<HTMLElement>("[data-more]");
      if (more) more.style.display = "none";
      // ease down to the freshly revealed row
      setTimeout(() => extras[0]?.scrollIntoView({ behavior: "smooth", block: "center" }), 120);
    } else {
      document.querySelector("#projects .p4-list")?.scrollIntoView({ behavior: "smooth", block: "start" });
    }
  });
  document.querySelectorAll<HTMLAnchorElement>("[data-soon]").forEach((a) =>
    a.addEventListener("click", (e) => e.preventDefault())
  );

  /* ---------------- MODAL ---------------- */
  const DATA = JSON.parse(document.querySelector("[data-modal-json]")?.textContent || "[]");
  const TAB_TITLES: Record<string, string> = {
    genesis: "01. Genesis", faculties: "02. Faculties",
    substratum: "03. Substratum", culmination: "04. Culmination",
  };

  const modal = document.querySelector<HTMLElement>("[data-modal]");
  const shell = modal?.querySelector<HTMLElement>(".pm-shell");
  const tabsWrap = modal?.querySelector<HTMLElement>("[data-tabs]");
  const elName = modal?.querySelector<HTMLElement>("[data-m-name]");
  const elKicker = modal?.querySelector<HTMLElement>("[data-m-kicker]");
  const elTitle = modal?.querySelector<HTMLElement>("[data-m-title]");
  const elBody = modal?.querySelector<HTMLElement>("[data-m-body]");
  const elImg = modal?.querySelector<HTMLImageElement>("[data-m-img]");
  const elPh = modal?.querySelector<HTMLElement>("[data-m-ph]");
  const elRepo = modal?.querySelector<HTMLAnchorElement>("[data-m-repo]");

  let current = 0;
  let lastFocus: HTMLElement | null = null;

  const applyNiche = (rowEl: HTMLElement) => {
    const niche = getComputedStyle(rowEl).getPropertyValue("--niche").trim();
    if (shell && niche) shell.style.setProperty("--niche", niche);
  };

  const renderTab = (key: string) => {
    const p = DATA[current];
    if (!p) return;
    if (elTitle) elTitle.textContent = TAB_TITLES[key] || "";
    if (elBody) elBody.textContent = p.modal[key] || "";
    if (elImg && elPh) { elImg.hidden = true; elPh.hidden = false; }
    [elTitle, elBody].forEach((el) => {
      if (!el) return;
      el.classList.remove("pm-swap"); void el.offsetWidth; el.classList.add("pm-swap");
    });
  };

  const setActiveTab = (key: string) => {
    tabsWrap?.querySelectorAll<HTMLElement>(".pm-tab").forEach((b) =>
      b.classList.toggle("active", b.dataset.tab === key)
    );
    renderTab(key);
  };

  const open = (index: number, rowEl: HTMLElement) => {
    if (!modal) return;
    current = index;
    const p = DATA[index];
    lastFocus = document.activeElement as HTMLElement;
    applyNiche(rowEl);
    if (elName) elName.textContent = p.name;
    if (elKicker) elKicker.textContent = p.kicker;
    if (elRepo) elRepo.href = p.repo || "#";
    setActiveTab("genesis");
    modal.hidden = false;
    requestAnimationFrame(() => modal.classList.add("open"));
    document.body.style.overflow = "hidden";
    modal.querySelector<HTMLElement>(".pm-tab.active")?.focus();
  };

  const close = () => {
    if (!modal) return;
    modal.classList.remove("open");
    document.body.style.overflow = "";
    setTimeout(() => { modal.hidden = true; lastFocus?.focus(); }, 320);
  };

  document.querySelectorAll<HTMLElement>("[data-open]").forEach((row) => {
    const idx = Number(row.dataset.open);
    row.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest("a")) return;
      open(idx, row);
    });
    row.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") { e.preventDefault(); open(idx, row); }
    });
  });

  tabsWrap?.querySelectorAll<HTMLElement>(".pm-tab").forEach((b) =>
    b.addEventListener("click", () => setActiveTab(b.dataset.tab!))
  );
  modal?.querySelectorAll<HTMLElement>("[data-close]").forEach((el) =>
    el.addEventListener("click", close)
  );
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modal && !modal.hidden) close();
  });
</script>
