---
/**
 * Page4_Process.astro - "My Projects"
 *
 * MODAL POLISH (modal only):
 * 1. Corner brackets pushed OUT with a real gap from the text-card border.
 * 2. Brackets: rich solid niche color in light, glowing niche color in dark.
 * 3. X close button restyled: clean circular aesthetic button.
 * 4. Modal typography switched to Inter (neat, clean, reference-like).
 * 5. Image radial flare made more visible.
 */

const AVATARS = 7;

const SUBLINE = "Not demos. Things I built because they needed to exist.";
const SIDE_LABEL = "hover any project to look inside · 01 / 03";
// note: "resume" spelling used throughout (not "resume")

const TABS = [
  { key: "genesis",     label: "Genesis",     hint: "the origin",     dot: "#f2743a" },
  { key: "faculties",   label: "Faculties",   hint: "what it does",   dot: "#e6b422" },
  { key: "substratum",  label: "Substratum",  hint: "how it's built", dot: "#8bd450" },
  { key: "culmination", label: "Culmination", hint: "the impact",     dot: "#3fd6bd" },
];

const PROJECTS = [
  {
    id: 1,
    name: "CareerPilot AI",
    kicker: "AI Resume Coach & Interview-Prep Platform",
    about:
      "A full-stack AI platform that parses your resume, embeds it into a vector store, and lets you chat with it through RAG.",
    problem:
      "Kills blind job-hunting: ATS scoring against a job description, skill-gap detection, and a tailored learning roadmap.",
    stack: [
      { t: "React", s: "react" },
      { t: "Node", s: "nodedotjs" },
      { t: "Express", s: "express" },
      { t: "MongoDB", s: "mongodb" },
      { t: "LangChain", s: "langchain" },
      { t: "LangGraph" },
      { t: "Qdrant" },
      { t: "RAG" },
    ],
    metric: "Resume-aware RAG · ATS score · skill-gap roadmap",
    repo: "https://github.com/Saurabh-993/Career-Pilot-AI",
    preview: "/projects/p1.png",
    modal: {
      genesis:
        "Job-hunting is mostly guesswork: you fire resumes into the void and hope. CareerPilot turns that fog into a conversation, parsing your own resume into something you can actually interrogate and improve.",
      faculties:
        "Chat with your resume through RAG, score it against any job description with ATS-style grading, surface the exact skills you're missing, and get a tailored roadmap back that tells you what to learn next.",
      substratum:
        "A React front end over a Node and Express API, resume text embedded into a Qdrant vector store, and a LangChain and LangGraph pipeline orchestrating retrieval and multi-step reasoning on top of MongoDB.",
      culmination:
        "Blind applications become deliberate ones. Every resume arrives aware of the role it's targeting, gap-checked and roadmap-backed, so the effort lands where it counts.",
    },
  },
  {
    id: 2,
    name: "Finance Manager AI",
    kicker: "Conversational Market-Forecasting Engine",
    about:
      "A forecasting engine that moved from LSTM to a Transformer to beat vanishing gradients on long market sequences.",
    problem:
      "Turns 5 years of market data into a real-time, conversational tool you can actually ask questions.",
    stack: [
      { t: "Python", s: "python" },
      { t: "FastAPI", s: "fastapi" },
      { t: "TensorFlow", s: "tensorflow" },
      { t: "Transformer" },
      { t: "Embeddings" },
      { t: "React", s: "react" },
      { t: "yFinance" },
    ],
    metric: "5 yrs market data · Transformer > LSTM",
    repo: "https://github.com/Saurabh-993/Finance-Manager-AI",
    preview: "/projects/p2.png",
    modal: {
      genesis:
        "Market data is long, noisy and unforgiving. This began as an LSTM experiment and became a study in doing sequence modelling properly, where memory over long horizons is the whole game.",
      faculties:
        "Ask the market questions in plain language and get grounded, real-time answers built on five years of history, with forecasts you can probe rather than blindly trust.",
      substratum:
        "A Transformer replaced the LSTM to defeat vanishing gradients across long sequences, served through a FastAPI backend with a React client and live data pulled via yFinance.",
      culmination:
        "Half a decade of raw prices becomes a tool you can hold a conversation with. The Transformer's edge over the LSTM is the quiet proof that the architecture choice was the right one.",
    },
  },
  {
    id: 3,
    name: "ATS Analytics Dashboard",
    kicker: "Delhi Metro · Big-Data BI",
    about:
      "An interactive Power BI dashboard over 66M+ metro transactions: revenue, passenger type and station-to-station flows.",
    problem:
      "Turns a 256GB dataset into fast, accurate KPIs that decision-makers can actually act on.",
    stack: [
      { t: "Power BI" },
      { t: "PostgreSQL", s: "postgresql" },
      { t: "Python", s: "python" },
      { t: "SQL" },
      { t: "Pandas", s: "pandas" },
    ],
    metric: "66M+ rows · 256GB · sub-second KPIs",
    repo: "https://github.com/Saurabh-993/dmrc-ats-powerbi-dashboard",
    preview: "/projects/p3.png",
    modal: {
      genesis:
        "Sixty-six million metro transactions is not a spreadsheet, it's a city breathing. The task was to make that scale legible: revenue, riders and routes, without drowning the people who need to decide.",
      faculties:
        "Explore revenue, passenger type and station-to-station flows interactively, with KPIs that answer in under a second instead of making an analyst wait.",
      substratum:
        "A 256GB dataset wrangled through Python and Pandas ETL into a tuned PostgreSQL and SQL layer, surfaced as an interactive Power BI model built for speed.",
      culmination:
        "A quarter-terabyte of raw movement becomes decisions leadership can act on the same morning. Scale stopped being a wall and became a lens.",
    },
  },
  {
    id: 4,
    name: "TaskFlow Pro",
    kicker: "Project Management Platform",
    extra: true,
    about:
      "A modern project-management platform — Kanban, Scrum and timeline boards, tasks, roles and analytics, in the spirit of Jira, Trello and Asana.",
    problem:
      "Small teams run projects across Excel, WhatsApp and scattered notes — TaskFlow pulls collaboration, tracking, deadlines and analytics into one home.",
    stack: [
      { t: "React", s: "react" },
      { t: "Vite", s: "vite" },
      { t: "Tailwind", s: "tailwindcss" },
      { t: "GSAP", s: "gsap" },
      { t: "Node", s: "nodedotjs" },
      { t: "Express", s: "express" },
      { t: "MongoDB", s: "mongodb" },
      { t: "Docker", s: "docker" },
    ],
    metric: "MERN · Kanban/Scrum/Timeline · JWT auth · Docker CI/CD",
    repo: "https://github.com/Saurabh-993/Task-Flow",
    preview: "/projects/p4.png",
    modal: {
      genesis:
        "Small teams rarely start with a tool — they run projects across spreadsheets, WhatsApp threads and scattered notes until nothing lines up. TaskFlow Pro began as the answer to that mess: one place where work, people and deadlines actually meet.",
      faculties:
        "Organise work on Kanban, Scrum or timeline boards, with a full task system — labels, priority, due dates, assignees, attachments and comments. Spin up workspaces, invite members with roles and permissions, and read the room through a dashboard of productivity graphs, pending and completed tasks, and weekly analytics.",
      substratum:
        "A MERN build: React + Vite + Tailwind + Framer Motion + React Query on the front, a Node/Express API over MongoDB with JWT, Bcrypt and Multer, shipped through Docker, Nginx and GitHub Actions. Data flows Users → Workspaces → Projects → Boards → Tasks → Comments → activity logs.",
      culmination:
        "Collaboration, tracking, deadlines and analytics collapse into a single product a small team can actually run on — and it doubled as a deep run through MERN, auth and authorization, CRUD, charts, file upload and Docker.",
    },
  },
];

const TOTAL = PROJECTS.length;
const FEATURED = PROJECTS.filter((p) => !p.extra).length;
---

<section class="p4 section" id="projects">
  <div class="p4-intro">
    <div class="p4-intro-inner" data-intro>
      <div class="p4-pill">
        <span class="pill-face" data-face>
          {Array.from({ length: AVATARS }).map((_, i) => (
            <img
              src={`/avatars/a${i + 1}.png`}
              alt=""
              class={i === 0 ? "on" : ""}
              data-fi={i}
              loading="lazy"
            />
          ))}
        </span>
        <span class="pill-txt">What I built</span>
      </div>

      <h2 class="p4-head">My Projects</h2>
      <p class="p4-sub">{SUBLINE}</p>
    </div>

    <p class="p4-micro" data-intro aria-label={SIDE_LABEL}>
      {SIDE_LABEL.split("").map((ch, i) => (
        <span class="ch" style={`--i:${i}`}>{ch === " " ? "\u00A0" : ch}</span>
      ))}
    </p>
  </div>

  <div class="p4-list" data-list>
    {PROJECTS.map((p, i) => (
      <article class={`p4-row${p.extra ? " is-extra" : ""}`} data-row={i} data-open={i} data-extra={p.extra}
        role="button" tabindex="0" aria-label={`Open ${p.name} details`}>
        <span class="row-glow" aria-hidden="true"></span>

        <div class="row-inner">
          <div class="row-lead">
            <span class="row-idx">0{i + 1}</span>

            <div class="row-head">
              <h3 class="row-name">{p.name}</h3>
              <span class="row-kicker">{p.kicker}</span>
            </div>
          </div>

          <p class="row-about">{p.about}</p>
          <p class="row-problem"><span>Solves ·</span> {p.problem}</p>

          <div class="row-chips">
            {p.stack.map((c) => (
              <span class="chip">
                {c.s && (
                  <img
                    src={`https://cdn.simpleicons.org/${c.s}`}
                    alt=""
                    width="14"
                    height="14"
                    loading="lazy"
                    onerror="this.remove()"
                  />
                )}
                {c.t}
              </span>
            ))}
          </div>

          <div class="row-foot">
            <span class="row-metric">{p.metric}</span>

            <div class="row-links">
              <a class="row-link soon" href="#" data-soon>
                Live<span>soon</span>
              </a>
              <a class="row-link" href={p.repo} target="_blank" rel="noopener noreferrer">
                Code<span>↗</span>
              </a>
            </div>
          </div>
        </div>

        <div class="row-preview">
          <img src={p.preview} alt={`${p.name} preview`} loading="lazy" />
        </div>
      </article>
    ))}
  </div>

  <div class="p4-foot">
    <span class="foot-count" data-count>
      [ {String(FEATURED).padStart(2, "0")} / {String(TOTAL).padStart(2, "0")} ]
    </span>
    <span class="foot-label">selected work</span>
    <button class="foot-more" type="button" data-more>
      more projects <span>↓</span>
    </button>
  </div>

  <!-- ============ PROJECT MODAL ============ -->
  <div class="pm" data-modal hidden>
    <div class="pm-scrim" data-close></div>

    <div class="pm-shell" role="dialog" aria-modal="true" aria-label="Project details">
      <aside class="pm-side">
        <div class="pm-brand">
          <span class="pm-brand-name" data-m-name>Project</span>
          <button class="pm-x" type="button" data-close aria-label="Close">
            <span class="pm-x-glyph"></span>
          </button>
        </div>

        <nav class="pm-nav" data-tabs>
          {TABS.map((t, i) => (
            <button class={`pm-tab${i === 0 ? " active" : ""}`} type="button" data-tab={t.key}
              style={`--dot:${t.dot}`}>
              <span class="pm-dot"></span>
              <span class="pm-tab-txt">
                <span class="pm-tab-label">{t.label}</span>
                <span class="pm-tab-hint">{t.hint}</span>
              </span>
            </button>
          ))}
        </nav>

        <p class="pm-kicker" data-m-kicker></p>
      </aside>

      <div class="pm-main">
        <div class="pm-card">
          <span class="pm-corner tl"></span>
          <span class="pm-corner tr"></span>
          <span class="pm-corner bl"></span>
          <span class="pm-corner br"></span>

          <h3 class="pm-title" data-m-title>01. Genesis</h3>
          <p class="pm-body" data-m-body></p>
        </div>

        <div class="pm-figure">
          <div class="pm-figure-glow" aria-hidden="true"></div>
          <div class="pm-figure-inner">
            <img data-m-img alt="" hidden />
            <span class="pm-figure-ph" data-m-ph>preview coming soon</span>
          </div>
        </div>

        <a class="pm-repo" data-m-repo href="#" target="_blank" rel="noopener noreferrer" aria-label="View source on GitHub">
          <svg class="pm-repo-i" viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path fill="currentColor" d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-1.95c-3.2.7-3.88-1.37-3.88-1.37-.53-1.34-1.29-1.7-1.29-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.78 1.2 1.78 1.2 1.04 1.79 2.73 1.27 3.4.97.1-.76.41-1.27.74-1.56-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.24 2.76.12 3.05.74.81 1.18 1.83 1.18 3.09 0 4.42-2.69 5.39-5.25 5.68.42.36.79 1.06.79 2.14v3.17c0 .31.2.67.8.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z"/></svg>
          <span>View source</span>
        </a>
      </div>
    </div>
  </div>
</section>

<script type="application/json" data-modal-json set:html={JSON.stringify(
  PROJECTS.map((p, i) => ({ i, name: p.name, kicker: p.kicker, preview: p.preview, repo: p.repo, modal: p.modal }))
)}></script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

  .p4 {
    --p4-bg: #f3f4f7;
    --p4-ink: #14161a;
    --p4-soft: #6a6f78;
    --p4-ghost: rgba(10, 12, 16, 0.2);
    --p4-rule: rgba(10, 12, 16, 0.12);
    --p4-chip: rgba(10, 12, 16, 0.045);
    --p4-chip-bd: rgba(10, 12, 16, 0.12);
    --p4-pill: #d9761a;

    --pm-scrim: rgba(20, 18, 24, 0.42);
    --pm-shell: #eef0f3;
    --pm-box: #ffffff;
    --pm-border: rgba(10, 12, 16, 0.12);
    --pm-card: #f6f7f9;
    --pm-fig-bg: #eceef1;
    --pm-fig-ink: #9aa0aa;
    --pm-ink: #14161a;
    --pm-soft: #6a6f78;
    --pm-hover: rgba(10, 12, 16, 0.05);
    --pm-bracket: rgba(10, 12, 16, 0.42);

    position: relative;
    min-height: 100dvh;
    background: var(--p4-bg);
    color: var(--p4-ink);
    overflow-x: clip;
    display: flex;
    flex-direction: column;
  }

  :global(html[data-theme='dark']) .p4 {
    --p4-bg: #08080c;
    --p4-ink: #eef1f6;
    --p4-soft: rgba(238, 241, 246, 0.62);
    --p4-ghost: rgba(255, 255, 255, 0.16);
    --p4-rule: rgba(255, 255, 255, 0.1);
    --p4-chip: rgba(255, 255, 255, 0.05);
    --p4-chip-bd: rgba(255, 255, 255, 0.12);
    --p4-pill: #178f7c;

    --pm-scrim: rgba(0, 0, 0, 0.72);
    --pm-shell: #060608;
    --pm-box: #0d0e11;
    --pm-border: rgba(255, 255, 255, 0.09);
    --pm-card: #15171c;
    --pm-fig-bg: #050506;
    --pm-fig-ink: rgba(238, 241, 246, 0.4);
    --pm-ink: #f1f4f8;
    --pm-soft: rgba(238, 241, 246, 0.6);
    --pm-hover: rgba(255, 255, 255, 0.05);
    --pm-bracket: rgba(255, 255, 255, 0.34);

    background:
      radial-gradient(120% 80% at 80% -10%, rgba(63, 214, 189, 0.12) 0%, transparent 55%),
      linear-gradient(180deg, #0a0f12 0%, #080c0e 100%);
  }

  /* ===== niche palettes (unchanged) ===== */
  .p4-row:nth-child(1) {
    --row-fill: #f2743a; --row-core: #ffb583;
    --row-accent: #5a1c00; --row-accent-ink: #5a1c00; --row-accent-soft: rgba(90, 28, 0, 0.4);
    --row-glow-strong: rgba(242, 116, 58, 0.5); --row-glow-mid: rgba(242, 116, 58, 0.24); --row-glow-soft: rgba(242, 116, 58, 0.09);
    --row-text: #2e0f02; --row-text-soft: rgba(46, 15, 2, 0.72);
    --niche: #d9761a;
  }
  .p4-row:nth-child(2) {
    --row-fill: #ffc93c; --row-core: #ffe88c;
    --row-accent: #6b5100; --row-accent-ink: #6b5100; --row-accent-soft: rgba(107, 81, 0, 0.42);
    --row-glow-strong: rgba(255, 196, 54, 0.5); --row-glow-mid: rgba(255, 196, 54, 0.24); --row-glow-soft: rgba(255, 196, 54, 0.09);
    --row-text: #2a2100; --row-text-soft: rgba(42, 33, 0, 0.72);
    --niche: #c99500;
  }
  .p4-row:nth-child(3) {
    --row-fill: #ff6f8b; --row-core: #ffb1c0;
    --row-accent: #7a1030; --row-accent-ink: #7a1030; --row-accent-soft: rgba(122, 16, 48, 0.4);
    --row-glow-strong: rgba(255, 111, 139, 0.5); --row-glow-mid: rgba(255, 111, 139, 0.24); --row-glow-soft: rgba(255, 111, 139, 0.09);
    --row-text: #350913; --row-text-soft: rgba(53, 9, 19, 0.72);
    --niche: #e0416a;
  }
  :global(html[data-theme='dark']) .p4-row:nth-child(1) {
    --row-fill: #16d6b0; --row-core: #63f2d6;
    --row-accent: #4ff0d0; --row-accent-ink: #05463a; --row-accent-soft: rgba(4, 58, 48, 0.45);
    --row-glow-strong: rgba(30, 224, 190, 0.62); --row-glow-mid: rgba(30, 224, 190, 0.34); --row-glow-soft: rgba(30, 224, 190, 0.13);
    --row-text: #032620; --row-text-soft: rgba(3, 38, 32, 0.74);
    --niche: #16d6b0;
  }
  :global(html[data-theme='dark']) .p4-row:nth-child(2) {
    --row-fill: #59d94a; --row-core: #94f088;
    --row-accent: #93f087; --row-accent-ink: #0b3d09; --row-accent-soft: rgba(11, 61, 9, 0.45);
    --row-glow-strong: rgba(96, 224, 74, 0.6); --row-glow-mid: rgba(96, 224, 74, 0.32); --row-glow-soft: rgba(96, 224, 74, 0.13);
    --row-text: #072b05; --row-text-soft: rgba(7, 43, 5, 0.74);
    --niche: #59d94a;
  }
  :global(html[data-theme='dark']) .p4-row:nth-child(3) {
    --row-fill: #ff5c9d; --row-core: #ff9ec4;
    --row-accent: #ff9ec4; --row-accent-ink: #5a0f34; --row-accent-soft: rgba(90, 15, 52, 0.45);
    --row-glow-strong: rgba(255, 92, 157, 0.6); --row-glow-mid: rgba(255, 92, 157, 0.32); --row-glow-soft: rgba(255, 92, 157, 0.13);
    --row-text: #35061f; --row-text-soft: rgba(53, 6, 31, 0.74);
    --niche: #ff5c9d;
  }
  /* project 4 (TaskFlow Pro) — project-management BLUE → INDIGO niche */
  .p4-row:nth-child(4) {
    --row-fill: #3f6bff; --row-core: #a9c0ff;
    --row-accent: #0a1a5c; --row-accent-ink: #0a1a5c; --row-accent-soft: rgba(10, 26, 92, 0.4);
    --row-glow-strong: rgba(63, 107, 255, 0.5); --row-glow-mid: rgba(63, 107, 255, 0.24); --row-glow-soft: rgba(63, 107, 255, 0.09);
    --row-text: #08113f; --row-text-soft: rgba(8, 17, 63, 0.72);
    --niche: #2f5fe0;
  }
  :global(html[data-theme='dark']) .p4-row:nth-child(4) {
    --row-fill: #5b8cff; --row-core: #a9c4ff;
    --row-accent: #a9c4ff; --row-accent-ink: #0a1a4a; --row-accent-soft: rgba(10, 26, 74, 0.45);
    --row-glow-strong: rgba(91, 140, 255, 0.6); --row-glow-mid: rgba(91, 140, 255, 0.32); --row-glow-soft: rgba(91, 140, 255, 0.13);
    --row-text: #06123a; --row-text-soft: rgba(6, 18, 58, 0.74);
    --niche: #5b8cff;
  }
  /* extra projects stay hidden until "more projects" reveals them */
  .p4-row.is-extra { display: none; }
  .p4-row.is-extra.show { display: flex; }

  /* ---------- intro ---------- */
  .p4-intro { position: sticky; top: 0; min-height: 100dvh; display: grid; align-items: center; z-index: 0; }
  .p4-intro-inner { position: relative; padding: 0 clamp(24px, 7vw, 120px); display: flex; flex-direction: column; gap: 16px; will-change: transform, opacity, filter; }
  .p4-pill { display: inline-flex; align-items: center; gap: 12px; align-self: flex-start; padding: 8px 20px 8px 8px; border-radius: 999px; background: var(--p4-pill); box-shadow: 0 10px 30px color-mix(in srgb, var(--p4-pill) 45%, transparent); }
  .pill-face { position: relative; width: 40px; height: 40px; border-radius: 50%; overflow: hidden; flex: none; background: #111; box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.3); }
  .pill-face img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity 0.35s ease; image-rendering: pixelated; }
  .pill-face img.on { opacity: 1; }
  .pill-txt { font-family: "JetBrains Mono", monospace; font-size: 13.5px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: #fff; }
  .p4-head { margin: 6px 0 0; font-family: "Clash Display", "Space Grotesk", sans-serif; font-weight: 700; font-size: clamp(3rem, 11vw, 9rem); line-height: 0.92; letter-spacing: -0.03em; color: var(--p4-ink); text-wrap: balance; }
  .p4-sub { margin: 4px 0 0; max-width: 22ch; font-family: "Clash Display", "Space Grotesk", sans-serif; font-weight: 500; font-size: clamp(1.35rem, 3.2vw, 2.5rem); line-height: 1.1; letter-spacing: -0.01em; color: var(--p4-ink); text-wrap: balance; }
  :global(html[data-theme='dark']) .p4-sub { color: #f2f6fc; text-shadow: 0 0 10px rgba(255, 255, 255, 0.45), 0 0 28px rgba(170, 200, 255, 0.35); }
  .p4-micro { position: absolute; right: clamp(18px, 4vw, 74px); top: 50%; transform: translateY(-50%); margin: 0; writing-mode: vertical-rl; text-orientation: mixed; white-space: nowrap; line-height: 1; font-family: "JetBrains Mono", monospace; font-size: 13px; font-weight: 700; letter-spacing: 0.3em; text-transform: uppercase; color: var(--p4-soft); will-change: opacity, transform; }
