---
/**
 * Page3_Story.astro — "Experience & Journey"
 * Atlassian-style pinned CAMERA FLY-THROUGH (2D DOM/SVG + GSAP — no WebGL).
 *
 *   - LEFT caption is the HERO (era + big title + stat + narrative).
 *   - In-world "frame" = secondary playful polaroid (meme + handwritten line
 *     + skill ribbon), ringed by 4–5 hand-drawn SKETCH doodles that draw
 *     themselves in when the card is focused (relevant to each milestone).
 *   - Page 2 → Page 3 aurora seam: p2__seam (bottom) + p3__seam (top) meet at the junction.
 *   - Bottom bar is a DRAGGABLE scrubber + a "skip" button.
 *   - Finale: frosted glass veil behind the "now" caption.
 *   - Dark mode: layered gradient/vignette (not flat black).
 *   - Memes live in /public/memes as m1..m6.gif.
 *   - Desktop + motion only; mobile / reduced-motion → vertical timeline.
 */
const FRAMES = [
  { id: 1, x: 560,  y: 1500, era: "2021 · the spark",        title: "Where it caught",       stat: "89%",  statlabel: "Class XII · CBSE",     body: "KV Vigyan Vihar, Delhi. Solid marks, endless questions, and the first real itch to build things instead of just using them.",                          meme: "/memes/m1.gif", memeCap: "let's get started.",        tag: "curiosity",      sketches: ["lightbulb","spark","arrow","exclaim","star"] },
  { id: 2, x: 1560, y: 980,  era: "2022–2026 · college",     title: "B.Tech IT — AI/ML",     stat: "7.55", statlabel: "CGPA · MSIT Delhi",    body: "Maharaja Surajmal Institute of Technology, AI/ML specialisation — where “can I build that?” turned into a weekly reflex.",                           meme: "/memes/m2.gif", memeCap: "me, learning to code",      tag: "Python · C++",   sketches: ["code","coffee","star","squiggle","spark"] },
  { id: 3, x: 2500, y: 1640, era: "the creative detour",     title: "Design & a channel",    stat: "~520", statlabel: "views · 2 videos",     body: "Ran a small YouTube channel and made design assets for others. Proof I care how things look — not only how they run.",                               meme: "/memes/m3.gif", memeCap: "wait, people watched it?!", tag: "design + video", sketches: ["play","heart","eye","underline","spark"] },
  { id: 4, x: 3450, y: 1000, era: "2024 · first internship", title: "Software Intern — CRIS", stat: "UTS",  statlabel: "Railway platform",     body: "Shipped responsive UI, flows and dashboards for the UTS platform in Flutter, Dart & Go Router — plus Excel/PDF export on Node.js + MySQL, Agile throughout.", meme: "/memes/m4.gif", memeCap: "first offer letter hits",   tag: "Flutter · Go",   sketches: ["rocket","check","arrow","star","spark"] },
  { id: 5, x: 4400, y: 1620, era: "2025 · data at scale",    title: "Data Analyst — DMRC",   stat: "66M+", statlabel: "transactions · 256GB", body: "Turned 66M+ metro transactions into a Power BI dashboard, and built Python/Pandas ETL with tuned SQL. Big data → real decisions.",                    meme: "/memes/m5.gif", memeCap: "66M rows, no problem",      tag: "Power BI · SQL", sketches: ["bars","uparrow","database","spark","star"] },
  { id: 6, x: 5350, y: 980,  era: "always leveling up",      title: "Certified & curious",   stat: "4+",   statlabel: "certifications",       body: "AWS Cloud Practitioner, IBM Data Fundamentals, Google Analytics, IT Audit — plus deep dives into RAG, agents and AI systems.",                        meme: "/memes/m6.gif", memeCap: "cert season chaos",        tag: "AWS · IBM",      sketches: ["trophy","check","plus","star","spark"] },
];
const END = { x: 6050, y: 1480, title: "Currently building in AI — open to work", body: "Still learning, still shipping. Open to roles and collaborations where I can build things that feel alive." };

const SKILLS = [
  { x: 1040, y: 1210, r: 0.10, t: "Problem-solver" },
  { x: 2260, y: 820,  r: 0.20, t: "Curious by default" },
  { x: 2000, y: 1220, r: 0.30, t: "Fast learner" },
  { x: 1260, y: 1760, r: 0.16, t: "Ownership" },
  { x: 2980, y: 1280, r: 0.42, t: "Ships end-to-end" },
  { x: 3720, y: 1820, r: 0.52, t: "Adaptable" },
  { x: 3900, y: 1210, r: 0.60, t: "Clear communicator" },
  { x: 4560, y: 780,  r: 0.70, t: "Calm under pressure" },
  { x: 4820, y: 1240, r: 0.78, t: "Design sense" },
  { x: 5650, y: 1280, r: 0.88, t: "Team player" },
];

const LINK = "M 560 1500 C 900 1180 1180 1000 1560 980 S 2200 1520 2500 1640 S 3160 1050 3450 1000 S 4110 1470 4400 1620 S 5060 1050 5350 980 S 5820 1330 6050 1480";

// hand-drawn sketch library (stroke-only single-path glyphs, pathLength=100)
const SKETCH: Record<string, string> = {
  lightbulb: "M50 12 C33 12 23 25 23 39 C23 51 33 57 35 66 L65 66 C67 57 77 51 77 39 C77 25 67 12 50 12 Z M40 74 L60 74 M43 82 L57 82",
  spark:     "M50 14 L57 43 L86 50 L57 57 L50 86 L43 57 L14 50 L43 43 Z",
  arrow:     "M14 68 C40 40 62 40 84 54 M84 54 L71 43 M84 54 L67 63",
  exclaim:   "M50 16 L50 58 M50 72 L50 80",
  star:      "M50 14 L61 40 L89 42 L67 61 L74 88 L50 72 L26 88 L33 61 L11 42 L39 40 Z",
  code:      "M38 30 L18 50 L38 70 M62 30 L82 50 L62 70 M57 24 L43 76",
  coffee:    "M28 42 L28 66 C28 76 72 76 72 66 L72 42 Z M72 48 C85 46 86 62 72 60 M40 22 C36 28 44 32 40 38 M54 22 C50 28 58 32 54 38",
  squiggle:  "M14 58 C26 44 34 74 46 58 C58 42 66 72 78 58 C83 51 88 57 90 55",
  play:      "M37 28 L74 50 L37 72 Z",
  heart:     "M50 78 C12 53 24 20 50 38 C76 20 88 53 50 78 Z",
  eye:       "M12 50 C32 27 68 27 88 50 C68 73 32 73 12 50 Z M39 50 A11 11 0 1 0 61 50 A11 11 0 1 0 39 50 Z",
  underline: "M16 56 C40 70 60 70 84 54",
  rocket:    "M50 14 C63 24 67 43 60 60 L40 60 C33 43 37 24 50 14 Z M40 60 L30 76 L42 68 M60 60 L70 76 L58 68 M43 40 A7 7 0 1 0 57 40 A7 7 0 1 0 43 40",
  check:     "M20 52 L42 74 L82 28",
  bars:      "M16 80 L86 80 M26 80 L26 56 M44 80 L44 40 M62 80 L62 50 M80 80 L80 26",
  uparrow:   "M50 82 L50 22 M31 43 L50 20 L69 43",
  database:  "M28 30 C28 22 72 22 72 30 L72 70 C72 78 28 78 28 70 Z M28 30 C28 38 72 38 72 30 M28 50 C28 58 72 58 72 50",
  trophy:    "M33 24 L67 24 L65 45 C65 57 35 57 35 45 Z M33 30 C21 30 22 45 35 43 M67 30 C79 30 78 45 65 43 M50 57 L50 68 M38 78 L62 78 L58 68 L42 68 Z",
  plus:      "M50 26 L50 74 M26 50 L74 50",
};
// 5 anchor positions ringing the card (px, relative to frame origin)
const POS = [
  { x: -80, y: -44, s: 66, r: -14, d: 0.00 },
  { x: 286, y: -36, s: 60, r: 12,  d: 0.08 },
  { x: 320, y: 150, s: 58, r: -8,  d: 0.16 },
  { x: -72, y: 236, s: 62, r: 10,  d: 0.24 },
  { x: 252, y: 292, s: 56, r: 16,  d: 0.32 },
];
---

<section class="p3 section" id="story">
  <!-- page2 → page3 boundary: aurora upper half (mirrors p2__seam below) -->
  <div class="p3__seam" aria-hidden="true"></div>

  <div class="p3-stage">
    <div class="p3-world" data-world>
      <div class="p3-grid" aria-hidden="true"></div>

      <svg class="p3-links" viewBox="0 0 6400 2600" aria-hidden="true">
        <path class="link-track" d={LINK} />
        <path class="link-live" data-link d={LINK} />
      </svg>

      {SKILLS.map((s) => (
        <span class="p3-skill" data-reveal={s.r} style={`left:${s.x}px; top:${s.y}px;`}>{s.t}</span>
      ))}

      {FRAMES.map((f, i) => (
        <article class="p3-frame" data-frame={i} style={`left:${f.x}px; top:${f.y}px;`}>
          {f.sketches.map((k, j) => (
            <span class="pf-sketch" style={`left:${POS[j].x}px; top:${POS[j].y}px; width:${POS[j].s}px; height:${POS[j].s}px; --r:${POS[j].r}deg; --d:${POS[j].d}s;`}>
              <svg viewBox="0 0 100 100" aria-hidden="true"><path pathLength="100" d={SKETCH[k]} /></svg>
            </span>
          ))}

          <div class="pf-card">
            <div class="pf-media">
              <img src={f.meme} alt="" loading="lazy" onerror="this.remove()" />
              <span class="pf-media-ph">reaction loading…</span>
            </div>
            <div class="pf-foot">
              <p class="pf-cap">{f.memeCap}</p>
              <span class="pf-tag">{f.tag}</span>
            </div>
          </div>

          <span class="pf-node"></span>
        </article>
      ))}

      <div class="p3-end" style={`left:${END.x}px; top:${END.y}px;`}>
        <span class="pe-ping"></span><span class="pe-node"></span>
        <span class="pe-label">open to work</span>
      </div>
    </div>
  </div>

  <!-- frosted veil for the finale (behind the "now" caption) -->
  <div class="p3-veil" data-veil aria-hidden="true"></div>

  <!-- fixed captions (HERO — one visible at a time) -->
  <div class="p3-caps" data-caps>
    {FRAMES.map((f, i) => (
      <div class={`p3-cap${i === 0 ? " active" : ""}`} data-cap={i}>
        <p class="pc-era"><span class="pc-idx">0{i + 1}</span>{f.era}</p>
        <h2 class="pc-title">{f.title}</h2>
        <div class="pc-stat"><span class="pc-statnum">{f.stat}</span><span class="pc-statlab">{f.statlabel}</span></div>
        <p class="pc-body">{f.body}</p>
      </div>
    ))}
    <div class="p3-cap p3-cap--end" data-cap="end">
      <p class="pc-era"><span class="pc-idx">✦</span>2026 · now</p>
      <h2 class="pc-title">{END.title}</h2>
      <p class="pc-body">{END.body}</p>
      <a class="pc-cta" href="#connect" data-p3-connect>Let's talk ↗</a>
    </div>
  </div>

  <!-- HUD: draggable scrubber + skip -->
  <div class="p3-hud">
    <div class="p3-bar" data-bar role="slider" tabindex="0" aria-label="Scrub the journey" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
      <span class="p3-fill" data-progress></span>
      <span class="p3-knob" data-knob></span>
    </div>
    <button class="p3-skip" type="button" data-skip>skip →</button>
  </div>

  <!-- MOBILE / reduced-motion fallback: clean vertical timeline -->
  <div class="p3-fallback">
    <h2 class="pf-heading">Experience &amp; Journey</h2>
    <ol>
      {FRAMES.map((f) => (
        <li>
          <p class="fb-era">{f.era}</p>
          <h3>{f.title}</h3>
          <p class="fb-meta">{f.stat} · {f.statlabel}</p>
          <p class="fb-body">{f.body}</p>
        </li>
      ))}
      <li class="fb-now">
        <h3>{END.title}</h3>
        <p class="fb-body">{END.body}</p>
        <a href="#connect">Let's talk ↗</a>
      </li>
    </ol>
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Caveat:wght@600;700&display=swap');

  .p3 {
    --p3-ink: #14161a; --p3-soft: #5f646d;
    --p3-grid: rgba(0,0,0,0.045);
    --p3-line: rgba(30,120,255,0.26); --p3-live: #2f7bff; --p3-accent: #2f7bff;
    --pf-bg: #ffffff; --pf-border: rgba(0,0,0,0.10);
    --p3-doodle: rgba(255,150,40,0.9);
    position: relative; height: 100dvh; overflow: hidden; color: var(--p3-ink);
    background:
      radial-gradient(130% 90% at 18% 0%, #ffffff 0%, #f2f4f8 52%, #e8ebf1 100%);
  }
  :global(html[data-theme='dark']) .p3 {
    --p3-ink: #eef1f6; --p3-soft: rgba(238,241,246,0.62);
    --p3-grid: rgba(120,170,255,0.06);
    --p3-line: rgba(90,170,255,0.30); --p3-live: #5aa2ff; --p3-accent: #6fb0ff;
    --pf-bg: #161a22; --pf-border: rgba(255,255,255,0.10);
    --p3-doodle: rgba(120,190,255,0.92);
    background:
      radial-gradient(120% 70% at 78% -10%, rgba(60,120,230,0.16) 0%, transparent 55%),
      radial-gradient(100% 80% at 15% 4%, rgba(40,90,180,0.14) 0%, transparent 50%),
      linear-gradient(180deg, #0f131b 0%, #0b0e15 46%, #080a10 100%);
  }

  /* ================= boundary gradient band (top of page 3 ← page 2) ================= */
  .p3__seam {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: clamp(160px, 26vh, 300px);
    pointer-events: none;
    z-index: 2;
    /* exact mirror of p2__seam — identical pools/colours peaking at the
       junction (top edge); base starts on the SAME junction tone (#fbfcfe) */
    background:
      radial-gradient(72% 125% at 16% -2%, rgba(88, 216, 172, 0.82) 0%, transparent 56%),
      radial-gradient(88% 135% at 50% -10%, rgba(52, 200, 220, 0.90) 0%, transparent 58%),
      radial-gradient(76% 125% at 84% -2%, rgba(70, 120, 226, 0.84) 0%, transparent 56%),
      radial-gradient(60% 115% at 34% -20%, rgba(140, 108, 234, 0.52) 0%, transparent 54%),
      linear-gradient(to bottom, #fbfcfe 0%, #ffffff 100%);
    -webkit-mask-image: linear-gradient(to bottom, #000 0%, #000 58%, transparent 100%);
    mask-image: linear-gradient(to bottom, #000 0%, #000 58%, transparent 100%);
  }
  :global(html[data-theme='dark']) .p3__seam {
    background:
      radial-gradient(72% 125% at 16% -2%, rgba(58, 216, 152, 0.66) 0%, transparent 58%),
      radial-gradient(88% 135% at 50% -10%, rgba(32, 190, 206, 0.70) 0%, transparent 60%),
      radial-gradient(76% 125% at 84% -2%, rgba(48, 98, 210, 0.74) 0%, transparent 58%),
      radial-gradient(60% 115% at 34% -20%, rgba(116, 84, 220, 0.48) 0%, transparent 56%),
      linear-gradient(to bottom, #0c0f17 0%, #0f131b 100%);
    -webkit-mask-image: linear-gradient(to bottom, #000 0%, #000 62%, transparent 100%);
    mask-image: linear-gradient(to bottom, #000 0%, #000 62%, transparent 100%);
  }

  .p3-stage { position: absolute; inset: 0; overflow: hidden; z-index: 1; }

  .p3-world { position: absolute; top: 0; left: 0; width: 6400px; height: 2600px; transform-origin: 0 0; will-change: transform; }
  .p3-grid { position: absolute; inset: 0;
    background-image:
      linear-gradient(to right, var(--p3-grid) 1px, transparent 1px),
      linear-gradient(to bottom, var(--p3-grid) 1px, transparent 1px);
    background-size: 88px 88px;
    -webkit-mask-image: radial-gradient(120% 120% at 50% 40%, #000 55%, transparent 100%);
            mask-image: radial-gradient(120% 120% at 50% 40%, #000 55%, transparent 100%); }

  .p3-links { position: absolute; top: 0; left: 0; width: 6400px; height: 2600px; overflow: visible; fill: none; }
  .link-track { stroke: var(--p3-line); stroke-width: 4; stroke-linecap: round; stroke-dasharray: 2 16; }
  .link-live  { stroke: var(--p3-live); stroke-width: 5; stroke-linecap: round; filter: drop-shadow(0 0 8px var(--p3-live)); }

  /* ============ FRAME = secondary playful polaroid ============ */
  .p3-frame { position: absolute; width: 320px; transform: translate(-50%, -50%); }
  .p3-frame:nth-child(odd)  .pf-card { transform: rotate(-2.4deg); }
  .p3-frame:nth-child(even) .pf-card { transform: rotate(2.1deg); }

  .pf-card { position: relative; z-index: 2; padding: 12px 12px 10px; border-radius: 14px;
    background: var(--pf-bg); border: 1px solid var(--pf-border);
    box-shadow: 0 22px 55px rgba(0,0,0,0.22), 0 2px 0 rgba(0,0,0,0.04);
    transition: transform 0.4s cubic-bezier(0.2,0.9,0.3,1.2); }

  .pf-media { position: relative; aspect-ratio: 4/3; border-radius: 9px; overflow: hidden;
    background:
      repeating-linear-gradient(45deg, color-mix(in srgb, var(--p3-accent) 12%, transparent) 0 10px, transparent 10px 20px),
      color-mix(in srgb, var(--pf-bg) 60%, #808a9c);
    display: grid; place-items: center; }
  .pf-media img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; }
  .pf-media-ph { font-family: "JetBrains Mono", monospace; font-size: 11px; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--p3-soft); opacity: 0.8; }

  .pf-foot { display: flex; align-items: center; justify-content: space-between; gap: 8px; padding: 9px 3px 2px; }
  .pf-cap { margin: 0; font-family: "Caveat", cursive; font-weight: 700; font-size: 22px; line-height: 1; color: var(--p3-ink); }
  /* dark: silver glow on the handwritten line, matching Page 2's headings */
  :global(html[data-theme='dark']) .pf-cap {
    color: #f2f6fc;
    text-shadow: 0 0 10px rgba(255,255,255,0.45), 0 0 28px rgba(170,200,255,0.35); }
  .pf-tag { flex: none; font-family: "JetBrains Mono", monospace; font-size: 10px; letter-spacing: 0.06em;
    padding: 4px 8px; border-radius: 999px; white-space: nowrap;
    color: var(--p3-accent); background: color-mix(in srgb, var(--p3-accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--p3-accent) 26%, transparent); }

  /* ---- sketch doodles ringing the card ---- */
  .pf-sketch { position: absolute; z-index: 1; pointer-events: none; opacity: 0;
    transform: rotate(var(--r)) scale(0.1); }
  .pf-sketch svg { display: block; width: 100%; height: 100%; overflow: visible; }
  .pf-sketch path { fill: none; stroke: var(--p3-doodle); stroke-width: 3; stroke-linecap: round; stroke-linejoin: round;
    stroke-dasharray: 100; stroke-dashoffset: 100; transition: stroke-dashoffset 0.7s ease var(--d);
    filter: drop-shadow(0 1px 4px rgba(0,0,0,0.12)); }
  /* dark: a soft SILVER glow on the doodles — deliberately a touch lower
     than the caption's glow under the card */
  :global(html[data-theme='dark']) .pf-sketch path {
    filter: drop-shadow(0 0 5px rgba(214,226,248,0.30)) drop-shadow(0 0 1px rgba(255,255,255,0.25)); }

  /* on focus the doodles POP outward like a happy little burst, then settle */
  .p3-frame.active .pf-sketch { animation: skPop 0.62s cubic-bezier(0.18,1.5,0.3,1) var(--d) both; }
  .p3-frame.active .pf-sketch path { stroke-dashoffset: 0; }
  .p3-frame.active .pf-sketch svg { animation: skFloat 4.6s ease-in-out infinite; animation-delay: calc(var(--d) + 0.6s); }
  @keyframes skPop {
    0%   { opacity: 0;    transform: rotate(var(--r)) scale(0.1); }
    55%  { opacity: 1;    transform: rotate(var(--r)) scale(1.22); }
    75%  {                transform: rotate(var(--r)) scale(0.94); }
    100% { opacity: 0.94; transform: rotate(var(--r)) scale(1); }
  }
  @keyframes skFloat { 0%,100% { transform: translateY(0) rotate(0deg); } 50% { transform: translateY(-5px) rotate(1.5deg); } }

  .pf-node { position: absolute; left: 50%; bottom: -30px; transform: translateX(-50%);
    width: 15px; height: 15px; border-radius: 50%; background: var(--p3-live);
    box-shadow: 0 0 0 6px color-mix(in srgb, var(--p3-live) 18%, transparent), 0 0 18px var(--p3-live); }

  /* soft-skill nodes along the line */
  .p3-skill { position: absolute; transform: translate(-50%, -50%) scale(0.6); opacity: 0;
    padding: 9px 16px; border-radius: 999px; white-space: nowrap;
    font-family: "Space Grotesk", sans-serif; font-weight: 600; font-size: 15px; color: var(--p3-ink);
    background: color-mix(in srgb, var(--pf-bg) 84%, transparent);
    border: 1px solid var(--pf-border); box-shadow: 0 8px 24px rgba(0,0,0,0.16);
    -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);
    transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.2,0.9,0.3,1.3); }
  .p3-skill::before { content: "✦"; color: var(--p3-accent); margin-right: 7px; }
  .p3-skill.in { opacity: 1; transform: translate(-50%, -50%) scale(1); }

  /* end node */
  .p3-end { position: absolute; transform: translate(-50%, -50%); display: grid; place-items: center; }
  .pe-node { grid-area: 1/1; width: 26px; height: 26px; border-radius: 50%; background: var(--p3-live); box-shadow: 0 0 22px var(--p3-live); }
  .pe-ping { grid-area: 1/1; width: 26px; height: 26px; border-radius: 50%; border: 2px solid var(--p3-live); animation: pe-ping 2s ease-out infinite; }
  @keyframes pe-ping { 0% { transform: scale(1); opacity: 0.9; } 100% { transform: scale(4.2); opacity: 0; } }
  .pe-label { position: absolute; top: 34px; white-space: nowrap; font-family: "JetBrains Mono", monospace; font-size: 13px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--p3-live); }

  /* frosted veil during finale */
  .p3-veil { position: absolute; inset: 0; z-index: 3; opacity: 0; pointer-events: none;
    background: color-mix(in srgb, var(--pf-bg) 34%, transparent);
    -webkit-backdrop-filter: blur(9px) saturate(1.05); backdrop-filter: blur(9px) saturate(1.05); }

  /* captions (fixed, left) — the HERO */
  .p3-caps { position: absolute; left: clamp(24px, 6vw, 96px); top: 0; bottom: 0; width: min(440px, 42vw); display: grid; align-content: center; pointer-events: none; z-index: 4; }
  .p3-cap { grid-area: 1/1; opacity: 0; transform: translateY(14px); transition: opacity 0.5s ease, transform 0.5s ease; pointer-events: none; }
  .p3-cap.active { opacity: 1; transform: translateY(0); pointer-events: auto; }
  .pc-era { display: flex; align-items: center; gap: 12px; margin: 0 0 12px; font-family: "JetBrains Mono", monospace; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--p3-accent); }
  .pc-idx { font-size: 12px; font-weight: 700; padding: 4px 8px; border-radius: 6px; color: var(--pf-bg); background: var(--p3-accent); letter-spacing: 0.08em; }
  .pc-title { margin: 0 0 14px; font-family: "Clash Display","Space Grotesk",sans-serif; font-weight: 700; font-size: clamp(1.8rem, 3.1vw, 2.8rem); line-height: 1.06; letter-spacing: -0.02em; color: var(--p3-ink); }
  .pc-stat { display: flex; align-items: baseline; gap: 10px; margin: 0 0 16px; }
  .pc-statnum { font-family: "Clash Display","Space Grotesk",sans-serif; font-weight: 700; font-size: clamp(1.6rem, 2.6vw, 2.2rem); color: var(--p3-live); line-height: 1;
    text-shadow: 0 0 22px color-mix(in srgb, var(--p3-live) 45%, transparent); }
  .pc-statlab { font-family: "JetBrains Mono", monospace; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--p3-soft); }
  .pc-body { margin: 0; font-size: clamp(14px, 1.25vw, 16px); line-height: 1.62; color: var(--p3-soft); max-width: 42ch; }
  .pc-cta { display: inline-block; margin-top: 18px; font-family: "Space Grotesk",sans-serif; font-weight: 700; color: var(--p3-live); text-decoration: none; pointer-events: auto; }
  .p3-cap--end .pc-title { max-width: 15ch; }

  /* HUD */
  .p3-hud { position: absolute; left: 0; right: 0; bottom: 26px; display: flex; align-items: center; gap: 18px; padding: 0 clamp(24px, 6vw, 96px); z-index: 6; }
  .p3-bar { position: relative; flex: 1; height: 22px; display: flex; align-items: center; cursor: grab; touch-action: none; }
  .p3-bar::before { content: ""; position: absolute; left: 0; right: 0; top: 50%; transform: translateY(-50%);
    height: 4px; border-radius: 4px; background: color-mix(in srgb, var(--p3-ink) 14%, transparent); }
  .p3-bar:active { cursor: grabbing; }
  .p3-fill { position: absolute; left: 0; top: 50%; transform: translateY(-50%); height: 4px; width: 0%; border-radius: 4px;
    background: var(--p3-live); box-shadow: 0 0 12px var(--p3-live); pointer-events: none; }
  .p3-knob { position: absolute; top: 50%; left: 0; width: 15px; height: 15px; border-radius: 50%;
    transform: translate(-50%, -50%); background: var(--pf-bg); border: 3px solid var(--p3-live);
    box-shadow: 0 0 14px var(--p3-live); pointer-events: none; transition: transform 0.15s ease; }
  .p3-bar:hover .p3-knob { transform: translate(-50%, -50%) scale(1.18); }
  .p3-skip { flex: none; padding: 9px 18px; border-radius: 999px; border: 1px solid var(--pf-border);
    background: color-mix(in srgb, var(--pf-bg) 70%, transparent); -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px);
    font-family: "Space Grotesk",sans-serif; font-weight: 600; font-size: 14px; color: var(--p3-ink); cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.3s ease; }
  .p3-skip:hover { transform: translateX(3px); box-shadow: 0 0 20px var(--p3-line); }

  .p3-fallback { display: none; }

  @media (max-width: 1023px), (prefers-reduced-motion: reduce) {
    .p3 { height: auto; min-height: 100dvh; }
    .p3-stage, .p3-caps, .p3-hud, .p3-veil { display: none; }
    .p3-fallback { display: block; max-width: 820px; margin: 0 auto; padding: 12vh 6vw; }
    .pf-heading { font-family: "Clash Display","Space Grotesk",sans-serif; font-size: clamp(1.8rem,7vw,2.6rem); margin: 0 0 6vh; }
    .p3-fallback ol { list-style: none; margin: 0; padding: 0; display: grid; gap: 3rem; position: relative; }
    .p3-fallback li { border-left: 2px solid var(--p3-line); padding-left: 22px; position: relative; }
    .p3-fallback li::before { content: ""; position: absolute; left: -7px; top: 4px; width: 12px; height: 12px; border-radius: 50%; background: var(--p3-live); box-shadow: 0 0 12px var(--p3-live); }
    .fb-era { margin: 0 0 6px; font-family: "JetBrains Mono", monospace; font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--p3-accent); }
    .p3-fallback h3 { margin: 0 0 6px; font-family: "Clash Display","Space Grotesk",sans-serif; font-size: 1.3rem; }
    .fb-meta { margin: 0 0 8px; font-family: "JetBrains Mono", monospace; font-size: 12.5px; color: var(--p3-soft); }
    .fb-body { margin: 0; color: var(--p3-soft); line-height: 1.6; }
    .fb-now a, .p3-fallback a { color: var(--p3-live); font-weight: 700; text-decoration: none; }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const FRAMES = [
    { x: 560,  y: 1500 }, { x: 1560, y: 980 }, { x: 2500, y: 1640 },
    { x: 3450, y: 1000 }, { x: 4400, y: 1620 }, { x: 5350, y: 980 },
  ];
  const END = { x: 6050, y: 1480 };
  const VEIL_START = 0.86;

  const mm = gsap.matchMedia();
  mm.add("(min-width: 1024px) and (prefers-reduced-motion: no-preference)", () => {
    const stage = document.querySelector<HTMLElement>(".p3 .p3-stage");
    const world = document.querySelector<HTMLElement>("[data-world]");
    const link  = document.querySelector<SVGPathElement>("[data-link]");
    const bar   = document.querySelector<HTMLElement>("[data-progress]");
    const knob  = document.querySelector<HTMLElement>("[data-knob]");
    const barWrap = document.querySelector<HTMLElement>("[data-bar]");
    const veil  = document.querySelector<HTMLElement>("[data-veil]");
    const caps  = Array.from(document.querySelectorAll<HTMLElement>(".p3-cap"));
    const frames = Array.from(document.querySelectorAll<HTMLElement>(".p3-frame"));
    const skills = Array.from(document.querySelectorAll<HTMLElement>(".p3-skill"));
    if (!stage || !world || !link) return;

    const len = link.getTotalLength();
    link.style.strokeDasharray = `${len}`;
    link.style.strokeDashoffset = `${len}`;

    const cam = { x: FRAMES[0].x, y: FRAMES[0].y, s: 0.62 };
    const apply = () => {
      const vw = stage.clientWidth, vh = stage.clientHeight;
      world.style.transform = `translate(${vw * 0.64 - cam.x * cam.s}px, ${vh / 2 - cam.y * cam.s}px) scale(${cam.s})`;
    };
    apply();
    window.addEventListener("resize", apply);

    // reveal one caption AND light up that frame's sketch doodles
    const showFrame = (key: number | "end") => {
      caps.forEach((c) => c.classList.toggle("active", c.dataset.cap === String(key)));
      frames.forEach((fr) => fr.classList.toggle("active", fr.dataset.frame === String(key)));
    };

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: ".p3", start: "top top", end: "+=700%", pin: true, scrub: 0.7, anticipatePin: 1,
        onUpdate: (self) => {
          const p = self.progress;
          if (bar)  bar.style.width = `${(p * 100).toFixed(2)}%`;
          if (knob) knob.style.left = `${(p * 100).toFixed(2)}%`;
          if (barWrap) barWrap.setAttribute("aria-valuenow", (p * 100).toFixed(0));
          link.style.strokeDashoffset = `${len * (1 - Math.min(p * 1.05, 1))}`;
          skills.forEach((s) => s.classList.toggle("in", p >= parseFloat(s.dataset.reveal || "1")));
          if (veil) veil.style.opacity = `${Math.min(Math.max((p - VEIL_START) / (1 - VEIL_START), 0), 1) * 0.92}`;
        },
      },
    });

    // opening — zoom INTO frame 1
    tl.to(cam, { s: 1.05, duration: 1, ease: "power2.inOut", onUpdate: apply, onStart: () => showFrame(0) });
    // travel + settle at each subsequent frame
    FRAMES.slice(1).forEach((f, idx) => {
      const i = idx + 1;
      tl.to(cam, { x: f.x, y: f.y, s: 0.85, duration: 1.2, ease: "power1.inOut", onUpdate: apply, onStart: () => showFrame(i) });
      tl.to(cam, { s: 1.05, duration: 0.6, ease: "power2.out", onUpdate: apply });
    });
    // finale — zoom OUT to reveal the whole path + open node
    tl.to(cam, { x: (FRAMES[0].x + END.x) / 2, y: 1360, s: 0.3, duration: 1.6, ease: "power2.inOut", onUpdate: apply, onStart: () => showFrame("end") });

    const st = tl.scrollTrigger!;
    // @ts-ignore
    const lenis = window.lenis;

    document.querySelector("[data-skip]")?.addEventListener("click", () => {
      const target = st.end - 2;
      if (lenis) lenis.scrollTo(target); else window.scrollTo({ top: target, behavior: "smooth" });
    });

    // Draggable scrubber
    if (barWrap) {
      let dragging = false;
      const scrubTo = (clientX: number) => {
        const r = barWrap.getBoundingClientRect();
        const ratio = Math.min(Math.max((clientX - r.left) / r.width, 0), 1);
        const target = st.start + ratio * (st.end - st.start);
        if (lenis) lenis.scrollTo(target, { immediate: false, duration: 0.25 });
        else window.scrollTo({ top: target });
      };
      barWrap.addEventListener("pointerdown", (e) => { dragging = true; barWrap.setPointerCapture(e.pointerId); scrubTo(e.clientX); });
      barWrap.addEventListener("pointermove", (e) => { if (dragging) scrubTo(e.clientX); });
      const stop = () => { dragging = false; };
      barWrap.addEventListener("pointerup", stop);
      barWrap.addEventListener("pointercancel", stop);
      barWrap.addEventListener("keydown", (e) => {
        if (e.key !== "ArrowLeft" && e.key !== "ArrowRight") return;
        e.preventDefault();
        const step = (st.end - st.start) * 0.04 * (e.key === "ArrowRight" ? 1 : -1);
        const target = Math.min(Math.max(window.scrollY + step, st.start), st.end);
        if (lenis) lenis.scrollTo(target); else window.scrollTo({ top: target });
      });
    }

    return () => { window.removeEventListener("resize", apply); st.kill(); };
  });
</script>
