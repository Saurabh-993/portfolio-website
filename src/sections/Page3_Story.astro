---
/**
 * Page3_Story.astro — "Experience & Journey"
 * Atlassian-style pinned CAMERA FLY-THROUGH (2D DOM/SVG + GSAP — no WebGL).
 * A large "journey map" world is panned/zoomed by scroll: zoom into frame 1,
 * travel the connector line settling at each milestone, then zoom out to the
 * open "still learning / open to work" node. Progress bar + Skip, both themes.
 * Desktop+motion only; mobile / reduced-motion falls back to a vertical timeline.
 *
 * Copy is resume-accurate. Memes: drop a gif/mp4 path into `meme` per frame
 * (null = styled placeholder). Coordinates live in a 6400×2600 world.
 */
const FRAMES = [
  { id: 1, x: 560,  y: 1500, era: "2021 · the spark",        title: "Where it caught",           meta: "Class XII (CBSE) · 89%",              body: "KV Vigyan Vihar, Delhi. Solid marks, endless questions, and the first real itch to build things instead of just use them.", meme: null },
  { id: 2, x: 1560, y: 980,  era: "2022–2026 · college",     title: "B.Tech IT — AI/ML",         meta: "MSIT, Delhi · CGPA 7.55/10",          body: "Maharaja Surajmal Institute of Technology, AI/ML specialisation — where “can I build that?” turned into a weekly reflex.", meme: null },
  { id: 3, x: 2500, y: 1640, era: "the creative detour",     title: "Design & a channel",        meta: "2 videos · ~520 views · brand assets", body: "Ran a small YouTube channel and made design assets for others. Proof I care how things look — not only how they run.", meme: null },
  { id: 4, x: 3450, y: 1000, era: "2024 · first internship", title: "Software Intern — CRIS",     meta: "Centre for Railway Information Systems", body: "Shipped responsive UI, flows and dashboards for the UTS platform in Flutter, Dart & Go Router — plus Excel/PDF export on Node.js + MySQL, Agile throughout.", meme: null },
  { id: 5, x: 4400, y: 1620, era: "2025 · data at scale",    title: "Data Analyst — DMRC",       meta: "Delhi Metro · 66M+ transactions",     body: "Turned 66M+ metro transactions (256GB) into a Power BI dashboard, and built Python/Pandas ETL with tuned SQL. Big data → real decisions.", meme: null },
  { id: 6, x: 5350, y: 980,  era: "always leveling up",      title: "Certified & curious",       meta: "AWS · IBM · Google · IT Audit",       body: "AWS Cloud Practitioner, IBM Data Fundamentals, Google Analytics, IT Audit — plus deep dives into RAG, agents and AI systems.", meme: null },
];
const END = { x: 6050, y: 1480, title: "Currently building in AI — open to work", body: "Still learning, still shipping. Open to roles and collaborations where I can build things that feel alive." };

const SKILLS = [
  { x: 1040, y: 1210, r: 0.10, t: "Problem-solver" },
  { x: 2260, y: 820,  r: 0.20, t: "Curious by default" },
  { x: 2000, y: 1220, r: 0.30, t: "Fast learner" },
  { x: 1260, y: 1760, r: 0.16, t: "Ownership" },
  { x: 2980, y: 1280, r: 0.42, t: "Ships end-to-end" },
  { x: 3720, y: 1820, r: 0.52, t: "Adaptable" },
  { x: 3900, y: 1210, r: 0.60, t: "Clear communicator" },
  { x: 4560, y: 780,  r: 0.70, t: "Calm under pressure" },
  { x: 4820, y: 1240, r: 0.78, t: "Design sense" },
  { x: 5650, y: 1280, r: 0.88, t: "Team player" },
];

const LINK = "M 560 1500 C 900 1180 1180 1000 1560 980 S 2200 1520 2500 1640 S 3160 1050 3450 1000 S 4110 1470 4400 1620 S 5060 1050 5350 980 S 5820 1330 6050 1480";
---

<section class="p3 section" id="story">
  <div class="p3-stage">
    <div class="p3-world" data-world>
      <div class="p3-grid" aria-hidden="true"></div>

      <svg class="p3-links" viewBox="0 0 6400 2600" aria-hidden="true">
        <path class="link-track" d={LINK} />
        <path class="link-live" data-link d={LINK} />
      </svg>

      {SKILLS.map((s) => (
        <span class="p3-skill" data-reveal={s.r} style={`left:${s.x}px; top:${s.y}px;`}>{s.t}</span>
      ))}

      {FRAMES.map((f, i) => (
        <article class="p3-frame" data-frame={i} style={`left:${f.x}px; top:${f.y}px;`}>
          <div class="pf-win">
            <div class="pf-bar">
              <span class="pf-dot"></span><span class="pf-dot"></span><span class="pf-dot"></span>
              <span class="pf-title">{f.era}</span>
            </div>
            <div class="pf-body">
              <div class="pf-media">
                {f.meme
                  ? <img src={f.meme} alt="" loading="lazy" onerror="this.style.display='none'; this.parentElement.classList.add('empty')" />
                  : null}
                <span class="pf-media-tag">meme incoming ✦</span>
              </div>
            </div>
          </div>
          <span class="pf-node"></span>
        </article>
      ))}

      <div class="p3-end" style={`left:${END.x}px; top:${END.y}px;`}>
        <span class="pe-ping"></span><span class="pe-node"></span>
        <span class="pe-label">open to work</span>
      </div>
    </div>
  </div>

  <!-- fixed captions (one visible at a time) -->
  <div class="p3-caps" data-caps>
    {FRAMES.map((f, i) => (
      <div class={`p3-cap${i === 0 ? " active" : ""}`} data-cap={i}>
        <p class="pc-era">{f.era}</p>
        <h2 class="pc-title">{f.title}</h2>
        <p class="pc-meta">{f.meta}</p>
        <p class="pc-body">{f.body}</p>
      </div>
    ))}
    <div class="p3-cap p3-cap--end" data-cap="end">
      <p class="pc-era">2026 · now</p>
      <h2 class="pc-title">{END.title}</h2>
      <p class="pc-body">{END.body}</p>
      <a class="pc-cta" href="#connect" data-p3-connect>Let's talk ↗</a>
    </div>
  </div>

  <!-- HUD: progress + skip -->
  <div class="p3-hud" aria-hidden="false">
    <div class="p3-bar"><span data-progress></span></div>
    <button class="p3-skip" type="button" data-skip>Skip to now →</button>
  </div>

  <!-- MOBILE / reduced-motion fallback: clean vertical timeline -->
  <div class="p3-fallback">
    <h2 class="pf-heading">Experience &amp; Journey</h2>
    <ol>
      {FRAMES.map((f) => (
        <li>
          <p class="fb-era">{f.era}</p>
          <h3>{f.title}</h3>
          <p class="fb-meta">{f.meta}</p>
          <p class="fb-body">{f.body}</p>
        </li>
      ))}
      <li class="fb-now">
        <h3>{END.title}</h3>
        <p class="fb-body">{END.body}</p>
        <a href="#connect">Let's talk ↗</a>
      </li>
    </ol>
  </div>
</section>

<style>
  .p3 {
    --p3-bg: #f4f5f7; --p3-grid: rgba(0,0,0,0.05); --p3-ink: #14161a; --p3-soft: #6a6f78;
    --p3-line: rgba(30,120,255,0.28); --p3-live: #2f7bff; --p3-accent: #2f7bff;
    --pf-bg: #ffffff; --pf-bar: linear-gradient(#f6f7f9,#eceef2); --pf-border: rgba(0,0,0,0.12);
    position: relative; height: 100dvh; overflow: hidden; background: var(--p3-bg); color: var(--p3-ink);
  }
  :global(html[data-theme='dark']) .p3 {
    --p3-bg: #08090c; --p3-grid: rgba(255,255,255,0.06); --p3-ink: #eef1f6; --p3-soft: rgba(238,241,246,0.6);
    --p3-line: rgba(90,170,255,0.30); --p3-live: #5aa2ff; --p3-accent: #5aa2ff;
    --pf-bg: #12141a; --pf-bar: linear-gradient(#20242c,#171a20); --pf-border: rgba(255,255,255,0.12);
  }

  .p3-stage { position: absolute; inset: 0; overflow: hidden; }

  /* the big pannable/zoomable world */
  .p3-world { position: absolute; top: 0; left: 0; width: 6400px; height: 2600px; transform-origin: 0 0; will-change: transform; }
  .p3-grid { position: absolute; inset: 0;
    background-image:
      linear-gradient(to right, var(--p3-grid) 1px, transparent 1px),
      linear-gradient(to bottom, var(--p3-grid) 1px, transparent 1px);
    background-size: 80px 80px; }

  .p3-links { position: absolute; top: 0; left: 0; width: 6400px; height: 2600px; overflow: visible; fill: none; }
  .link-track { stroke: var(--p3-line); stroke-width: 4; stroke-linecap: round; }
  .link-live  { stroke: var(--p3-live); stroke-width: 5; stroke-linecap: round; filter: drop-shadow(0 0 8px var(--p3-live)); }

  /* frames (mac windows) */
  .p3-frame { position: absolute; width: 520px; transform: translate(-50%, -50%); }
  .pf-win { border-radius: 14px; overflow: hidden; background: var(--pf-bg);
    border: 1px solid var(--pf-border); box-shadow: 0 30px 80px rgba(0,0,0,0.28); }
  .pf-bar { height: 38px; display: flex; align-items: center; gap: 8px; padding: 0 14px; background: var(--pf-bar); border-bottom: 1px solid var(--pf-border); }
  .pf-dot { width: 11px; height: 11px; border-radius: 50%; background: #cfd3da; }
  .pf-dot:nth-child(1){ background:#ff5f56; } .pf-dot:nth-child(2){ background:#ffbd2e; } .pf-dot:nth-child(3){ background:#27c93f; }
  .pf-title { margin-left: 8px; font-family: "JetBrains Mono", monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--p3-soft); }
  .pf-body { padding: 16px; }
  .pf-media { position: relative; aspect-ratio: 16/10; border-radius: 10px; overflow: hidden;
    background: repeating-linear-gradient(45deg, rgba(47,123,255,0.10) 0 12px, rgba(47,123,255,0.04) 12px 24px);
    display: grid; place-items: center; }
  .pf-media img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .pf-media-tag { font-family: "JetBrains Mono", monospace; font-size: 12px; letter-spacing: 0.1em; color: var(--p3-soft); }
  .pf-media img + .pf-media-tag { display: none; }
  .pf-node { position: absolute; left: 50%; bottom: -26px; transform: translateX(-50%); width: 16px; height: 16px; border-radius: 50%; background: var(--p3-live); box-shadow: 0 0 0 6px rgba(47,123,255,0.18), 0 0 18px var(--p3-live); }

  /* soft-skill nodes along the line */
  .p3-skill { position: absolute; transform: translate(-50%, -50%) scale(0.6); opacity: 0;
    padding: 9px 16px; border-radius: 999px; white-space: nowrap;
    font-family: "Space Grotesk", sans-serif; font-weight: 600; font-size: 15px; color: var(--p3-ink);
    background: color-mix(in srgb, var(--pf-bg) 82%, transparent);
    border: 1px solid var(--pf-border); box-shadow: 0 8px 24px rgba(0,0,0,0.18);
    -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);
    transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.2,0.9,0.3,1.3); }
  .p3-skill::before { content: "✦"; color: var(--p3-accent); margin-right: 7px; }
  .p3-skill.in { opacity: 1; transform: translate(-50%, -50%) scale(1); }

  /* end node */
  .p3-end { position: absolute; transform: translate(-50%, -50%); display: grid; place-items: center; }
  .pe-node { grid-area: 1/1; width: 26px; height: 26px; border-radius: 50%; background: var(--p3-live); box-shadow: 0 0 22px var(--p3-live); }
  .pe-ping { grid-area: 1/1; width: 26px; height: 26px; border-radius: 50%; border: 2px solid var(--p3-live); animation: pe-ping 2s ease-out infinite; }
  @keyframes pe-ping { 0% { transform: scale(1); opacity: 0.9; } 100% { transform: scale(4.2); opacity: 0; } }
  .pe-label { position: absolute; top: 34px; white-space: nowrap; font-family: "JetBrains Mono", monospace; font-size: 13px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--p3-live); }

  /* captions (fixed, left) */
  .p3-caps { position: absolute; left: clamp(24px, 6vw, 96px); top: 0; bottom: 0; width: min(420px, 40vw); display: grid; align-content: center; pointer-events: none; z-index: 4; }
  .p3-cap { grid-area: 1/1; opacity: 0; transform: translateY(14px); transition: opacity 0.5s ease, transform 0.5s ease; pointer-events: none; }
  .p3-cap.active { opacity: 1; transform: translateY(0); pointer-events: auto; }
  .pc-era { margin: 0 0 10px; font-family: "JetBrains Mono", monospace; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--p3-accent); }
  .pc-title { margin: 0 0 10px; font-family: "Clash Display","Space Grotesk",sans-serif; font-weight: 700; font-size: clamp(1.7rem, 3vw, 2.7rem); line-height: 1.08; letter-spacing: -0.02em; color: var(--p3-ink); }
  .pc-meta { margin: 0 0 14px; font-family: "JetBrains Mono", monospace; font-size: 13px; color: var(--p3-soft); }
  .pc-body { margin: 0; font-size: clamp(14px, 1.3vw, 16px); line-height: 1.6; color: var(--p3-soft); max-width: 42ch; }
  .pc-cta { display: inline-block; margin-top: 18px; font-family: "Space Grotesk",sans-serif; font-weight: 700; color: var(--p3-live); text-decoration: none; pointer-events: auto; }

  /* HUD */
  .p3-hud { position: absolute; left: 0; right: 0; bottom: 26px; display: flex; align-items: center; gap: 18px; padding: 0 clamp(24px, 6vw, 96px); z-index: 5; }
  .p3-bar { flex: 1; height: 4px; border-radius: 4px; background: color-mix(in srgb, var(--p3-ink) 14%, transparent); overflow: hidden; }
  .p3-bar span { display: block; height: 100%; width: 0%; background: var(--p3-live); box-shadow: 0 0 12px var(--p3-live); }
  .p3-skip { flex: none; padding: 9px 18px; border-radius: 999px; border: 1px solid var(--pf-border);
    background: color-mix(in srgb, var(--pf-bg) 70%, transparent); -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px);
    font-family: "Space Grotesk",sans-serif; font-weight: 600; font-size: 14px; color: var(--p3-ink); cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.3s ease; }
  .p3-skip:hover { transform: translateX(3px); box-shadow: 0 0 20px var(--p3-line); }

  /* fallback hidden on desktop-with-motion */
  .p3-fallback { display: none; }

  @media (max-width: 1023px), (prefers-reduced-motion: reduce) {
    .p3 { height: auto; min-height: 100dvh; }
    .p3-stage, .p3-caps, .p3-hud { display: none; }
    .p3-fallback { display: block; max-width: 820px; margin: 0 auto; padding: 12vh 6vw; }
    .pf-heading { font-family: "Clash Display","Space Grotesk",sans-serif; font-size: clamp(1.8rem,7vw,2.6rem); margin: 0 0 6vh; }
    .p3-fallback ol { list-style: none; margin: 0; padding: 0; display: grid; gap: 3rem; position: relative; }
    .p3-fallback li { border-left: 2px solid var(--p3-line); padding-left: 22px; position: relative; }
    .p3-fallback li::before { content: ""; position: absolute; left: -7px; top: 4px; width: 12px; height: 12px; border-radius: 50%; background: var(--p3-live); box-shadow: 0 0 12px var(--p3-live); }
    .fb-era { margin: 0 0 6px; font-family: "JetBrains Mono", monospace; font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--p3-accent); }
    .p3-fallback h3 { margin: 0 0 6px; font-family: "Clash Display","Space Grotesk",sans-serif; font-size: 1.3rem; }
    .fb-meta { margin: 0 0 8px; font-family: "JetBrains Mono", monospace; font-size: 12.5px; color: var(--p3-soft); }
    .fb-body { margin: 0; color: var(--p3-soft); line-height: 1.6; }
    .fb-now a, .p3-fallback a { color: var(--p3-live); font-weight: 700; text-decoration: none; }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const FRAMES = [
    { x: 560,  y: 1500 }, { x: 1560, y: 980 }, { x: 2500, y: 1640 },
    { x: 3450, y: 1000 }, { x: 4400, y: 1620 }, { x: 5350, y: 980 },
  ];
  const END = { x: 6050, y: 1480 };

  const mm = gsap.matchMedia();
  mm.add("(min-width: 1024px) and (prefers-reduced-motion: no-preference)", () => {
    const stage = document.querySelector<HTMLElement>(".p3 .p3-stage");
    const world = document.querySelector<HTMLElement>("[data-world]");
    const link  = document.querySelector<SVGPathElement>("[data-link]");
    const bar   = document.querySelector<HTMLElement>("[data-progress]");
    const caps  = Array.from(document.querySelectorAll<HTMLElement>(".p3-cap"));
    const skills = Array.from(document.querySelectorAll<HTMLElement>(".p3-skill"));
    if (!stage || !world || !link) return;

    const len = link.getTotalLength();
    link.style.strokeDasharray = `${len}`;
    link.style.strokeDashoffset = `${len}`;

    const cam = { x: FRAMES[0].x, y: FRAMES[0].y, s: 0.62 };
    const apply = () => {
      const vw = stage.clientWidth, vh = stage.clientHeight;
      // focus point sits at ~62% width so the left captions never overlap the frame
      world.style.transform = `translate(${vw * 0.62 - cam.x * cam.s}px, ${vh / 2 - cam.y * cam.s}px) scale(${cam.s})`;
    };
    apply();
    window.addEventListener("resize", apply);

    const showCap = (key: number | "end") => {
      caps.forEach((c) => c.classList.toggle("active", c.dataset.cap === String(key)));
    };

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: ".p3", start: "top top", end: "+=700%", pin: true, scrub: 0.7, anticipatePin: 1,
        onUpdate: (self) => {
          if (bar) bar.style.width = `${(self.progress * 100).toFixed(2)}%`;
          link.style.strokeDashoffset = `${len * (1 - Math.min(self.progress * 1.05, 1))}`;
          const p = self.progress;
          skills.forEach((s) => s.classList.toggle("in", p >= parseFloat(s.dataset.reveal || "1")));
        },
      },
    });

    // opening — zoom INTO frame 1
    tl.to(cam, { s: 1.2, duration: 1, ease: "power2.inOut", onUpdate: apply, onStart: () => showCap(0) });
    // travel + settle at each subsequent frame
    FRAMES.slice(1).forEach((f, idx) => {
      const i = idx + 1;
      tl.to(cam, { x: f.x, y: f.y, s: 0.92, duration: 1.2, ease: "power1.inOut", onUpdate: apply, onStart: () => showCap(i) });
      tl.to(cam, { s: 1.2, duration: 0.6, ease: "power2.out", onUpdate: apply });
    });
    // finale — zoom OUT to reveal the whole path + open node
    tl.to(cam, { x: (FRAMES[0].x + END.x) / 2, y: 1360, s: 0.3, duration: 1.6, ease: "power2.inOut", onUpdate: apply, onStart: () => showCap("end") });

    // Skip → jump to the end (open-to-work)
    const st = tl.scrollTrigger!;
    document.querySelector("[data-skip]")?.addEventListener("click", () => {
      // @ts-ignore
      const lenis = window.lenis;
      const target = st.end - 2;
      if (lenis) lenis.scrollTo(target); else window.scrollTo({ top: target, behavior: "smooth" });
    });

    return () => { window.removeEventListener("resize", apply); st.kill(); };
  });
</script>
