---
// Page2_Work.astro — clean professional About/Skills bento section.
import ParticleMorph from "../components/ui/ParticleMorph.astro";

const tech = [
  { label: "JavaScript", slug: "javascript" },
  { label: "TypeScript", slug: "typescript" },
  { label: "Python",     slug: "python" },
  { label: "Node.js",    slug: "nodedotjs" },
  { label: "Express",    slug: "express" },
  { label: "FastAPI",    slug: "fastapi" },
  { label: "REST APIs" },
  { label: "MongoDB",    slug: "mongodb" },
  { label: "PostgreSQL", slug: "postgresql" },
  { label: "MySQL",      slug: "mysql" },
  { label: "React",      slug: "react" },
  { label: "LangChain",  slug: "langchain" },
  { label: "LangGraph" },
  { label: "n8n",        slug: "n8n" },
  { label: "Git",        slug: "git" },
  { label: "GitHub",     slug: "github" },
];
const loop = [...tech, ...tech];
---

<section class="p2" id="work">
  <!-- Ambient background glow that triggers on hover -->
  <div class="p2__glow" aria-hidden="true"></div>

  <div class="p2__inner">
   <div class="mac-window">
    <div class="mac-header">
      <div class="mac-buttons">
        <span class="mac-btn close"></span>
        <span class="mac-btn minimize"></span>
        <span class="mac-btn maximize"></span>
      </div>
      <div class="mac-action">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 1V11M1 6H11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </div>
    </div>
    <div class="mac-body">
      <div class="bento">

        <article class="card about">
          <div class="label"><span class="dot"></span>ABOUT</div>
          <div class="about__head">
            <div class="avatar">S</div>
            <h2>Hi, I'm Saurabh.</h2>
          </div>
          <p class="bio">I build at the intersection of engineering and design — interfaces that feel
            alive, systems that stay simple underneath, and the kind of polish people only notice when
            it's missing.</p>
          <dl class="facts">
            <div><dt>Currently</dt><dd>creative frontend &amp; real-time graphics</dd></div>
            <div><dt>Focus</dt><dd>engineering &times; design, built end to end</dd></div>
            <div><dt>Edge</dt><dd>AI-augmented — I can learn, build &amp; research almost anything</dd></div>
          </dl>
        </article>

        <article class="card tech">
          <div class="label"><span class="dot"></span>STACK</div>
          <h2>Tech I build with</h2>
          <p class="bio">The stack I've gone deep on — what I reach for when an idea has to become real
            software, from interface to API to database. And with AI in the loop, I can pick up whatever
            a problem demands and ship it.</p>
          <div class="marquee">
            <div class="marquee__track">
              {loop.map((t) => (
                <span class="chip">
                  {t.slug && <img src={`https://cdn.simpleicons.org/${t.slug}`} alt="" width="18" height="18" loading="lazy" />}
                  {t.label}
                </span>
              ))}
            </div>
          </div>
        </article>

        <article class="card play">
          <div class="label"><span class="dot dot--blue"></span>PLAYGROUND</div>
          <div class="play__panel">
            <ParticleMorph />
          </div>
        </article>

      </div>
    </div>
   </div>
  </div>
</section>

<style>
  :root, html[data-theme='light'] {
    --p2-bg: #f7f6f3; /* Professional warm white background matching Image 1 */
    --mac-bg: #ffffff;
    --mac-header-bg: linear-gradient(to bottom, #f5f5f7, #e8e8ed);
    --mac-border: rgba(0, 0, 0, 0.12);
    --mac-shadow: 0 20px 60px rgba(0,0,0,0.08), 0 0 0 1px rgba(0,0,0,0.03);
    --mac-icon: #86868b;
  }

  :global(html[data-theme='dark']) {
    --p2-bg: #0a0a0a; /* Exact deep dark background matching Image 2 */
    --mac-bg: #111111;
    --mac-header-bg: linear-gradient(to bottom, #323232, #1e1e1e);
    --mac-border: rgba(255, 255, 255, 0.12);
    --mac-shadow: 0 30px 80px rgba(0,0,0,0.6), inset 0 1px 1px rgba(255,255,255,0.15);
    --mac-icon: #7d7d7d;
  }

  .p2 { 
    background: var(--p2-bg); 
    color: var(--text); 
    position: relative;
    height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: background-color 0.3s ease;
  }

  /* ---- ambient hover glow (positioned behind content) ---- */
  .p2__glow {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    transition: opacity 0.8s ease, transform 0.8s ease;
    transform: scale(0.95);
  }
  
  .p2__glow::before {
    content: "";
    position: absolute;
    left: 0%; right: 0%; top: -10%; height: 80%;
    /* Day mode: soft warm glow */
    background: radial-gradient(ellipse at center, rgba(251, 146, 60, 0.15), rgba(254, 215, 170, 0.05), transparent 60%);
    filter: blur(80px);
    animation: p2aurora 8s ease-in-out infinite alternate;
  }
  
  /* dark mode: teal -> blue ambient glow exactly like Image 3 */
  :global(html[data-theme='dark']) .p2__glow::before {
    background: radial-gradient(ellipse at center, rgba(6, 182, 212, 0.15), rgba(59, 130, 246, 0.2), transparent 70%);
    filter: blur(100px);
  }
  
  @keyframes p2aurora { 
    0% { transform: scale(1) translate(0, 0); }
    100% { transform: scale(1.05) translate(2%, 2%); } 
  }

  /* Trigger the beautiful background glow when hovering over the section */
  .p2:hover .p2__glow {
    opacity: 1;
    transform: scale(1);
  }

  .p2__inner {
    position: relative;
    z-index: 1;
    max-width: 1500px; 
    margin: 0 auto; 
    padding: 7vh 5vw 8vh; 
    width: 100%; 
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mac-window {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    background: var(--mac-bg);
    border: 1px solid var(--mac-border);
    border-radius: 12px;
    box-shadow: var(--mac-shadow);
    overflow: hidden;
    transition: all 0.4s ease;
  }

  /* subtle inner-glow when hovering the mac window itself */
  .mac-window:hover {
    border-color: var(--accent-glow);
    box-shadow: var(--mac-shadow), inset 0 0 100px var(--accent-soft);
  }

  .mac-header {
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 16px;
    background: var(--mac-header-bg);
    border-bottom: 1px solid var(--mac-border);
    flex-shrink: 0;
  }

  .mac-buttons { display: flex; gap: 8px; }
  .mac-btn { width: 12px; height: 12px; border-radius: 50%; }
  .mac-btn.close { background: #ff5f56; }
  .mac-btn.minimize { background: #ffbd2e; }
  .mac-btn.maximize { background: #27c93f; }

  .mac-action { color: var(--mac-icon); display: flex; align-items: center; justify-content: center; }
  .mac-body { flex: 1; padding: 24px; overflow: hidden; display: flex; }

  .bento {
    flex: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    grid-template-rows: minmax(0, 1fr) minmax(0, 1fr);
    gap: 24px;
    align-items: stretch;
    width: 100%;
    height: 100%;
  }
  
  .about { grid-column: 1; grid-row: 1; min-width: 0; }
  .tech  { grid-column: 1; grid-row: 2; min-width: 0; }
  .play  { grid-column: 2; grid-row: 1 / span 2; min-width: 0; }

  .card {
    background: var(--card-bg);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    padding: 28px 32px;
    transition: transform .4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow .4s ease, border-color .4s ease;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  
  /* the hover edge-glow for inner boxes exactly like Image 1 (yellow glow on 'About') */
  .card:hover {
    transform: translateY(-6px);
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent), 0 15px 40px var(--accent-glow);
  }

  .label {
    display: flex; align-items: center; gap: 8px;
    font-family: "JetBrains Mono", monospace; font-size: 12px;
    letter-spacing: 0.18em; color: var(--text-muted); margin-bottom: 24px;
    flex-shrink: 0;
  }
  
  .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); }
  .dot--blue { background: #3b82f6; }

  h2 { font-family: "Clash Display","Space Grotesk",sans-serif; font-weight: 700;
       font-size: clamp(1.4rem, 2.2vw, 2.1rem); margin: 0; letter-spacing: -0.01em; color: var(--text); flex-shrink: 0; }

  .about__head { display: flex; align-items: center; gap: 16px; margin-bottom: 20px; flex-shrink: 0; }
  .avatar { width: 48px; height: 48px; border-radius: 50%; flex: none;
    background: linear-gradient(135deg, var(--ball-b), var(--ball-a)); color: #fff;
    display: grid; place-items: center; font-weight: 700; font-family: "Space Grotesk",sans-serif; font-size: 1.1rem; }

  .bio { color: var(--text-muted); line-height: 1.5; font-size: 15px; margin: 0 0 24px; max-width: 48ch; flex-shrink: 0; }

  .facts { margin: auto 0 0; display: grid; gap: 0; flex: 1; align-content: end; }
  .facts > div { display: grid; grid-template-columns: 120px 1fr; gap: 16px;
    padding: 12px 0; border-top: 1px solid var(--grid-line); align-items: baseline; }
  .facts dt { font-family: "JetBrains Mono", monospace; font-size: 11px;
    letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-faint); margin: 0; }
  .facts dd { margin: 0; font-size: 13.5px; color: var(--text); }

  .marquee { margin-top: auto; overflow: hidden; flex-shrink: 0; -webkit-mask-image:
    linear-gradient(to right, transparent, #000 10%, #000 90%, transparent); }
  .marquee__track { display: flex; gap: 12px; width: max-content; animation: p2scroll 34s linear infinite; }
  .marquee:hover .marquee__track { animation-play-state: paused; }
  @keyframes p2scroll { to { transform: translateX(-50%); } }
  
  .chip { display: inline-flex; align-items: center; gap: 8px; white-space: nowrap;
    padding: 8px 14px; border: 1px solid var(--glass-border); border-radius: 999px; background: var(--mac-bg);
    font-family: "JetBrains Mono", monospace; font-size: 13px; color: var(--text); }
  .chip img { display: block; }

  .play { display: flex; flex-direction: column; }
  .play__panel { flex: 1; width: 100%; border-radius: 12px; overflow: hidden;
    background: radial-gradient(120% 120% at 50% 0%, #101a2e 0%, #0a0f1c 60%, #070a12 100%);
    display: grid; place-items: center; position: relative; }

  @media (max-width: 900px) {
    .p2 { height: auto; min-height: 100dvh; display: block; }
    .p2__inner { height: auto; padding: 12vh 4vw 6vh; display: block; }
    .mac-window { height: auto; max-height: none; }
    .mac-body { padding: 16px; }
    .bento { grid-template-columns: 1fr; grid-template-rows: auto; }
    .about, .tech, .play { grid-column: 1; grid-row: auto; }
    .play { min-height: 400px; }
    .facts > div { grid-template-columns: 100px 1fr; }
  }
  @media (prefers-reduced-motion: reduce) { .marquee__track { animation: none; } }
</style></style>