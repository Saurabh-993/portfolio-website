---
// Page2About.astro — clean professional About/Skills bento section.
// Put <ParticleMorph /> inside the dark box (import path may need adjusting).
import ParticleMorph from "../components/ui/ParticleMorph.astro";

const tech = [
  { label: "JavaScript", slug: "javascript" },
  { label: "TypeScript", slug: "typescript" },
  { label: "Python",     slug: "python" },
  { label: "Node.js",    slug: "nodedotjs" },
  { label: "Express",    slug: "express" },
  { label: "FastAPI",    slug: "fastapi" },
  { label: "REST APIs" },
  { label: "MongoDB",    slug: "mongodb" },
  { label: "PostgreSQL", slug: "postgresql" },
  { label: "MySQL",      slug: "mysql" },
  { label: "React",      slug: "react" },
  { label: "LangChain",  slug: "langchain" },
  { label: "LangGraph" },
  { label: "n8n",        slug: "n8n" },
  { label: "Git",        slug: "git" },
  { label: "GitHub",     slug: "github" },
];
const loop = [...tech, ...tech];
---

<section class="p2">
  <div class="p2__transition" aria-hidden="true"></div>

  <div class="p2__inner">
   <div class="bento-shell">
    <div class="bento">

      <article class="card about">
        <div class="label"><span class="dot"></span>ABOUT</div>
        <div class="about__head">
          <div class="avatar">S</div>
          <h2>Hi, I'm Saurabh.</h2>
        </div>
        <p class="bio">I build at the intersection of engineering and design — interfaces that feel
          alive, systems that stay simple underneath, and the kind of polish people only notice when
          it's missing.</p>
        <dl class="facts">
          <div><dt>Currently</dt><dd>creative frontend &amp; real-time graphics</dd></div>
          <div><dt>Focus</dt><dd>engineering &times; design, built end to end</dd></div>
          <div><dt>Edge</dt><dd>AI-augmented — I can learn, build &amp; research almost anything</dd></div>
        </dl>
      </article>

      <article class="card tech">
        <div class="label"><span class="dot"></span>STACK</div>
        <h2>Tech I build with</h2>
        <p class="bio">The stack I've gone deep on — what I reach for when an idea has to become real
          software, from interface to API to database. And with AI in the loop, I can pick up whatever
          a problem demands and ship it.</p>
        <div class="marquee">
          <div class="marquee__track">
            {loop.map((t) => (
              <span class="chip">
                {t.slug && <img src={`https://cdn.simpleicons.org/${t.slug}`} alt="" width="18" height="18" loading="lazy" />}
                {t.label}
              </span>
            ))}
          </div>
        </div>
      </article>

      <article class="card play">
        <div class="label"><span class="dot dot--blue"></span>PLAYGROUND</div>
        <div class="play__panel">
          <ParticleMorph />
        </div>
      </article>

    </div>
   </div>
  </div>
</section>

<style>
  .p2 { background: #f2f3f5; color: #16181d; }

  /* ---- animated aurora transition band (page 1 -> page 2) ---- */
  .p2__transition {
    position: relative;
    height: 34vh;
    overflow: hidden;
    background: var(--bg, #faf6ef);           /* top blends into page 1 */
  }
  /* the glowing aurora band (warm/orange in light mode) */
  .p2__transition::before {
    content: "";
    position: absolute;
    left: -25%; right: -25%; top: 30%; height: 55%;
    background: linear-gradient(90deg, #ffb84d, #ff8a3d, #ffcf7a, #ff9d3d, #ffb84d);
    background-size: 200% 100%;
    filter: blur(46px);
    opacity: 0.9;
    animation: p2aurora 12s linear infinite;
  }
  /* fade the band down into page 2's surface */
  .p2__transition::after {
    content: "";
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 26%, #f2f3f5 90%);
  }
  /* dark mode: cool green→teal→blue aurora (matches reference) */
  :global(html[data-theme='dark']) .p2__transition::before {
    background: linear-gradient(90deg, #17d38a, #12b6c7, #2b7fe6, #12b6c7, #17d38a);
    background-size: 200% 100%;
  }
  @keyframes p2aurora { to { background-position: 200% 0; } }

  .p2__inner {
    max-width: 1320px; margin: 0 auto; padding: 5vh 3vw 7vh;
    width: 100%; min-height: 100vh;
    display: grid; place-items: center;
  }

  /* OUTER container box that frames the three cards */
  .bento-shell {
    width: 100%;
    min-height: 80vh;
    display: flex;
    background: rgba(255, 255, 255, 0.45);
    border: 1px solid #e4e6ea;
    border-radius: 28px;
    padding: 22px;
    transition: box-shadow .45s ease, border-color .45s ease;
  }
  /* subtle inner-glow when hovering the outer box */
  .bento-shell:hover {
    border-color: rgba(99, 102, 241, .35);
    box-shadow: inset 0 0 90px rgba(99, 102, 241, .10), 0 26px 70px rgba(30, 20, 60, .08);
  }

  .bento {
    flex: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    grid-template-rows: minmax(0, 1fr) minmax(0, 1fr);
    gap: 20px;
    align-items: stretch;
    width: 100%;
  }
  .about { grid-column: 1; grid-row: 1; min-width: 0; overflow: hidden; }
  .tech  { grid-column: 1; grid-row: 2; min-width: 0; overflow: hidden; }
  .play  { grid-column: 2; grid-row: 1 / span 2; min-width: 0; }

  .card {
    background: #ffffff;
    border: 1px solid #e6e8ec;
    border-radius: 20px;
    padding: 30px 32px;
    transition: transform .3s ease, box-shadow .3s ease;
  }
  /* the hover edge-glow you asked for */
  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 0 0 1px rgba(99,102,241,.45), 0 14px 44px rgba(99,102,241,.20);
  }

  .label {
    display: flex; align-items: center; gap: 8px;
    font-family: "JetBrains Mono", monospace; font-size: 12px;
    letter-spacing: 0.18em; color: #8a8f98; margin-bottom: 18px;
  }
  .dot { width: 8px; height: 8px; border-radius: 50%; background: #e0a200; }
  .dot--blue { background: #3b82f6; }

  h2 { font-family: "Clash Display","Space Grotesk",sans-serif; font-weight: 700;
       font-size: clamp(1.5rem, 2.4vw, 2.1rem); margin: 0; letter-spacing: -0.01em; }

  .about__head { display: flex; align-items: center; gap: 14px; margin-bottom: 16px; }
  .avatar { width: 44px; height: 44px; border-radius: 50%; flex: none;
    background: linear-gradient(135deg,#f5a623,#8b5cf6); color: #fff;
    display: grid; place-items: center; font-weight: 700; font-family: "Space Grotesk",sans-serif; }

  .bio { color: #4a4f57; line-height: 1.6; font-size: 15px; margin: 0 0 22px; max-width: 46ch; }

  .facts { margin: 0; display: grid; gap: 0; }
  .facts > div { display: grid; grid-template-columns: 120px 1fr; gap: 16px;
    padding: 12px 0; border-top: 1px solid #eceef1; align-items: baseline; }
  .facts dt { font-family: "JetBrains Mono", monospace; font-size: 11px;
    letter-spacing: 0.14em; text-transform: uppercase; color: #9aa0a8; margin: 0; }
  .facts dd { margin: 0; font-size: 14px; color: #23262c; }

  .marquee { margin-top: 24px; overflow: hidden; -webkit-mask-image:
    linear-gradient(to right, transparent, #000 8%, #000 92%, transparent); }
  .marquee__track { display: flex; gap: 12px; width: max-content; animation: p2scroll 34s linear infinite; }
  .marquee:hover .marquee__track { animation-play-state: paused; }
  @keyframes p2scroll { to { transform: translateX(-50%); } }
  .chip { display: inline-flex; align-items: center; gap: 8px; white-space: nowrap;
    padding: 9px 15px; border: 1px solid #e6e8ec; border-radius: 999px; background: #fff;
    font-family: "JetBrains Mono", monospace; font-size: 13px; color: #33373d; }
  .chip img { display: block; }

  .play { display: flex; flex-direction: column; }
  .play__panel { flex: 1; min-height: 460px; border-radius: 14px; overflow: hidden;
    background: radial-gradient(120% 120% at 50% 0%, #101a2e 0%, #0a0f1c 60%, #070a12 100%); }

  @media (max-width: 860px) {
    .p2__inner { min-height: auto; }
    .bento-shell { min-height: auto; }
    .bento { grid-template-columns: 1fr; grid-template-rows: auto; }
    .about { grid-column: 1; grid-row: auto; overflow: visible; }
    .tech  { grid-column: 1; grid-row: auto; overflow: visible; }
    .play  { grid-column: 1; grid-row: auto; min-height: 420px; }
    .facts > div { grid-template-columns: 100px 1fr; }
  }
  @media (prefers-reduced-motion: reduce) { .marquee__track { animation: none; } }
</style>