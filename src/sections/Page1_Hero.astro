---
/**
 * Page1_Hero.astro — full-screen hero SCROLL SECTION (not a route).
 *
 * Layers (back → front):
 *   1. Subtle grid background, edge-faded with a radial mask (.grid-bg)
 *   2. Sun/Moon sketchy blob — decorative, top-right, behind the navbar
 *   3. Glassmorphic navbar (fixed, top-center) + theme toggle
 *   4. Profile badge (fixed, top-left) with recruiter quick-links
 *   5. Strikethrough headline — "I am a … builder"
 *   6. Liquid ball centerpiece — chaos in, reality out
 *   7. Big serif name anchored at the bottom
 *   8. Faint word-strip marquee as the section boundary
 */
import Navbar from '../components/ui/Navbar.astro';
import ProfileBadge from '../components/ui/ProfileBadge.astro';
import SunMoon from '../components/hero/SunMoon.astro';
import StrikeHeadline from '../components/hero/StrikeHeadline.astro';
import LiquidBall from '../components/hero/LiquidBall.astro';
import FlowingWords from "../components/hero/FlowingWords.astro";
import NameTrinkets from "../components/hero/NameTrinkets.astro";

/* Marquee texture words — light, low-contrast, reads as a divider */
const stripWords = [
  'design', 'systems', 'frontend', 'motion', 'architecture',
  'prototypes', 'interfaces', 'ideas', 'craft', 'detail',
];
---

<section class="section hero" id="hero">
  <!-- 1. grid background (styles in global.css) -->
  <div class="grid-bg"></div>

  <!-- 2. decorative celestial blob -->
  <SunMoon />

  <!-- 3 & 4. fixed chrome -->
  <Navbar />
  <ProfileBadge />

  <div class="hero-content">
    <!-- 5. core intro -->
    <div class="headline-wrap">
      <StrikeHeadline />
      <a class="open-pill" href="#connect" aria-label="Open to work — let's connect">
        <span class="open-dot" aria-hidden="true"></span>
        <span class="open-text">Open to work</span>
      </a>
    </div>

    <!-- 6. centerpiece -->
    <div class="hero-center" style="position:relative; display:grid; place-items:center;">
      <FlowingWords />
      <LiquidBall />
      <!-- lightweight revolving orb — mobile stand-in for the 3D ball -->
      <svg class="hero-orb" viewBox="0 0 220 220" aria-hidden="true">
        <defs>
          <radialGradient id="orb-core-grad" cx="42%" cy="38%" r="66%">
            <stop class="cs0" offset="0%" />
            <stop class="cs1" offset="48%" />
            <stop class="cs2" offset="100%" />
          </radialGradient>
        </defs>
        <circle class="orb-core" cx="110" cy="110" r="46" fill="url(#orb-core-grad)" />
        <circle class="orb-ring ring1" cx="110" cy="110" r="66" />
        <circle class="orb-ring ring2" cx="110" cy="110" r="88" />
        <g class="orb-orbit orb-o1"><circle class="orb-dot" cx="110" cy="22" r="5" /></g>
        <g class="orb-orbit orb-o2"><circle class="orb-dot" cx="110" cy="200" r="4" /></g>
      </svg>
    </div>

    <!-- 7. signature name -->
    <div class="name-wrap">
      <p class="big-name serif">SAURABH</p>
      <!-- sticker trinkets popping in over the letters -->
      <NameTrinkets />
    </div>
  </div>

  <!-- 8. word-strip boundary: content duplicated once for a seamless loop -->
  <div class="word-strip" aria-hidden="true">
    <div class="strip-track-mask">
      <div class="strip-track">
        {[0, 1].map(() => (
          <span class="strip-run">
            {stripWords.map((w) => (
              <span class="strip-word">{w}</span>
            ))}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* Clash Display (Fontshare) — for the big signature name only */
  @import url('https://api.fontshare.com/v2/css?f[]=clash-display@700&display=swap');

  .hero {
    height: 100dvh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding-top: 96px; /* clear the fixed navbar */
    min-height: 0;
  }

  .headline-wrap {
    text-align: center;
    padding: clamp(0.5rem, 2vh, 2rem) 1rem 0;
  }

  /* "Open to work" — clean glassmorphic capsule with a blinking green dot;
     doubles as a Connect link */
  .open-pill {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    margin-top: clamp(12px, 1.8vh, 20px);
    padding: 8px 16px 8px 13px;
    border-radius: 999px;
    text-decoration: none;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--text);
    background: color-mix(in srgb, var(--card-bg) 66%, transparent);
    border: 1px solid var(--glass-border);
    -webkit-backdrop-filter: blur(14px) saturate(1.3);
    backdrop-filter: blur(14px) saturate(1.3);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.10), inset 0 1px 0 rgba(255, 255, 255, 0.28);
    transition: transform 0.2s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .open-pill:hover {
    transform: translateY(-1px);
    border-color: rgba(34, 197, 94, 0.5);
    box-shadow: 0 10px 28px rgba(34, 197, 94, 0.20), inset 0 1px 0 rgba(255, 255, 255, 0.32);
  }
  .open-dot {
    width: 9px;
    height: 9px;
    flex: none;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 10px rgba(34, 197, 94, 0.95);
    animation: open-blink 1.5s ease-in-out infinite;
  }
  @keyframes open-blink {
    0%, 100% { opacity: 1;    box-shadow: 0 0 10px rgba(34, 197, 94, 0.95); }
    50%      { opacity: 0.3;  box-shadow: 0 0 4px  rgba(34, 197, 94, 0.4); }
  }
  @media (prefers-reduced-motion: reduce) { .open-dot { animation: none; } }

  /* ---- mobile revolving orb (stand-in for the 3D ball) ---- */
  .hero-orb { display: none; width: min(320px, 82vw); height: auto; grid-area: 1 / 1; }
  .hero-orb .cs0 { stop-color: #ffffff; stop-opacity: 0.92; }
  .hero-orb .cs1 { stop-color: var(--accent); stop-opacity: 0.5; }
  .hero-orb .cs2 { stop-color: var(--accent); stop-opacity: 0.06; }
  .orb-core { transform-box: view-box; transform-origin: 110px 110px; animation: orb-breath 4.2s ease-in-out infinite; }
  .orb-ring { fill: none; stroke: var(--accent); stroke-width: 2; opacity: 0.5;
    transform-box: view-box; transform-origin: 110px 110px; }
  .ring1 { stroke-dasharray: 11 15; animation: orb-spin 15s linear infinite; }
  .ring2 { stroke-dasharray: 4 18; opacity: 0.3; animation: orb-spin 22s linear infinite reverse; }
  .orb-orbit { transform-box: view-box; transform-origin: 110px 110px; }
  .orb-o1 { animation: orb-spin 8s linear infinite; }
  .orb-o2 { animation: orb-spin 12s linear infinite reverse; }
  .orb-dot { fill: var(--accent); filter: drop-shadow(0 0 6px var(--accent)); }
  @keyframes orb-spin { to { transform: rotate(360deg); } }
  @keyframes orb-breath { 0%, 100% { transform: scale(1); opacity: 0.9; } 50% { transform: scale(1.06); opacity: 1; } }
  @media (prefers-reduced-motion: reduce) { .orb-core, .orb-ring, .orb-orbit { animation: none; } }

  /* 7. Big name — full-width signature at the bottom */
  .name-wrap {
    position: relative; /* anchors the NameTrinkets overlay */
    width: 100%;
    overflow: visible;  /* trinkets may poke above the letters */
    line-height: 0.85;
  }
  .big-name {
    /* Clash Display: modern + striking, pairs with the Space Grotesk-style
       headline. (Elegant serif alternative: 'Fraunces', already loaded in
       Base.astro — just swap the family here.) */
    font-family: 'Clash Display', 'Fraunces', Georgia, sans-serif;
    font-size: clamp(4rem, 15.5vw, 15rem);
    font-weight: 700; /* Clash Display bold */
    text-align: center;
    letter-spacing: 0.015em; /* Clash likes tighter tracking than the serif did */
    white-space: nowrap;
    /* tucked into the bottom edge like a stamp */
    margin-bottom: -0.06em;
    user-select: none;
  }

  /* 8. Marquee — its own DISTINCT band: contained strip with a subtle
     contrasting background + hairline dividers, visually detached from the
     big name above it. Texture, not headline. */
  .word-strip {
    position: relative;
    z-index: 3;
    margin-top: clamp(6px, 1.2vh, 14px); /* daylight between name and band */
    background: var(--strip-bg);
    border-top: 1px solid var(--strip-line);
    border-bottom: 1px solid var(--strip-line);
    padding: 9px 0;
    overflow: hidden;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }
  /* fade the words at the ends, but keep the band edges themselves crisp */
  .strip-track-mask {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent, black 12%, black 88%, transparent);
    mask-image: linear-gradient(to right, transparent, black 12%, black 88%, transparent);
  }
  .strip-track {
    display: flex;
    width: max-content;
    animation: marquee 40s linear infinite;
  }
  .strip-run {
    display: flex;
    flex-shrink: 0;
  }
  .strip-word {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-faint);
    padding: 0 1.6rem;
  }
  /* track holds two identical runs → -50% loops seamlessly */
  @keyframes marquee {
    to { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .strip-track { animation: none; }
  }

  @media (max-width: 1023px) {
    .hero-content { padding-top: 84px; }
  }

  /* ---- mobile: swap the 3D ball for the orb, and lift the name up ---- */
  @media (max-width: 768px) {
    .hero-content { justify-content: center; gap: clamp(18px, 3.4vh, 40px); }
    .headline-wrap { order: 1; }
    .name-wrap     { order: 2; }   /* SAURABH sits just under the "Open to work" pill */
    .hero-center   { order: 3; }
    .hero-center :global(.liquid-ball) { display: none; }
    .hero-orb { display: block; }
    .big-name { font-size: clamp(3.2rem, 17vw, 6rem); margin-bottom: 0; }
    /* clean, uncluttered name — drop the sticker trinkets on small screens */
    .name-wrap :global(.name-trinkets) { display: none; }
  }
</style>

<script>
  // "Open to work" pill → smooth-scroll to the Connect section via Lenis.
  document.querySelector<HTMLAnchorElement>('.open-pill')?.addEventListener('click', (e) => {
    const target = document.querySelector('#connect');
    if (!target) return;
    e.preventDefault();
    // @ts-ignore — Lenis is exposed by Base.astro when motion is allowed
    const lenis = window.lenis;
    if (lenis) lenis.scrollTo(target); else target.scrollIntoView({ behavior: 'smooth' });
  });
</script>
