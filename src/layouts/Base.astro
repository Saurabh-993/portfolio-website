---
/**
 * Base.astro — shared layout for the whole site.
 * Responsibilities:
 *  - <head>: meta, fonts (Fraunces serif + Inter)
 *  - Theme boot: set data-theme BEFORE first paint (localStorage → OS pref)
 *  - Lenis smooth scroll + GSAP/ScrollTrigger wiring (skipped for reduced motion)
 */
import '../styles/global.css';
import LiquidCursor from '../components/ui/LiquidCursor.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Saurabh — Builder',
  description = 'Portfolio of Saurabh: designer, coder, architect — builder.',
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Fonts: Fraunces (display serif) + Inter (UI) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,900&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!--
      Theme boot — inline & blocking so there is no flash of wrong theme.
      Order: saved choice in localStorage → prefers-color-scheme → light.
    -->
    <script is:inline>
      (() => {
        let theme = 'light';
        try {
          const saved = localStorage.getItem('theme');
          if (saved === 'light' || saved === 'dark') theme = saved;
          else if (matchMedia('(prefers-color-scheme: dark)').matches) theme = 'dark';
        } catch (_) {}
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>

  <body>
    <slot />

    <!-- gooey liquid blob trailing the cursor — behind content, site-wide -->
    <LiquidCursor />

    <!-- Lenis + GSAP global init -->
    <script>
      import Lenis from 'lenis';
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import { MotionPathPlugin } from 'gsap/MotionPathPlugin';

      gsap.registerPlugin(ScrollTrigger, MotionPathPlugin);

      const reducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!reducedMotion) {
        // Smooth scrolling, driven by GSAP's ticker so ScrollTrigger stays in sync.
        const lenis = new Lenis({ lerp: 0.1 });

        lenis.on('scroll', ScrollTrigger.update);
        gsap.ticker.add((time) => lenis.raf(time * 1000));
        gsap.ticker.lagSmoothing(0);

        // Expose for components (e.g. navbar anchor links → lenis.scrollTo)
        // @ts-ignore
        window.lenis = lenis;
      }
    </script>
  </body>
</html>
